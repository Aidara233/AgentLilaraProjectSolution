@using AgentCoreProcessor.WebUI.Navigation
@using Microsoft.JSInterop
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AgentCoreProcessor.WebUI.Shell.ProviderRegistry Registry
@implements IDisposable

<nav class="app-sidebar">
    <a href="/" class="sidebar-brand">
        <i class="bi bi-robot"></i>
        <span>Lilara</span>
    </a>
    <hr class="sidebar-divider" />
    <ul class="sidebar-nav">
        @foreach (var item in NavConfig.Items)
        {
            @if (item.Children.Count == 0)
            {
                <li @key="item.Href">
                    <NavLink class="nav-link" href="@item.Href"
                             Match="@(item.Href == "/" ? NavLinkMatch.All : NavLinkMatch.Prefix)">
                        <i class="bi @item.Icon"></i> @item.Title
                    </NavLink>
                </li>
            }
            else
            {
                <NavSection @key="item.Title" Item="item" ExpandedSet="expandedSet" Version="version" />
            }
        }
    </ul>
    @if (navGroups.Count > 0)
    {
        <hr class="sidebar-divider" />
        <ul class="sidebar-nav">
            @foreach (var group in navGroups)
            {
                @if (group.IsSinglePage && group.Pages.Count == 1)
                {
                    var p = group.Pages[0];
                    <li @key="@($"p-{p.Route}")">
                        <NavLink class="nav-link" href="@($"/p/{p.Route}")" Match="NavLinkMatch.Prefix">
                            <i class="bi @(p.Meta.Icon ?? "bi-circle")"></i> @p.Meta.Title
                        </NavLink>
                    </li>
                }
                else
                {
                    <NavSection @key="@($"pg-{group.Name}")" Item="@ToNavItem(group)" ExpandedSet="expandedSet" Version="version" />
                }
            }
        </ul>
    }
    <hr class="sidebar-divider" />
    <div class="sidebar-footer">
        <button class="btn-theme-toggle" @onclick="ToggleTheme" title="切换主题">
            <i class="bi @themeIcon"></i>
            <span>@themeLabel</span>
        </button>
        <form method="post" action="/api/auth/logout">
            <button type="submit" class="btn-logout">
                <i class="bi bi-box-arrow-left"></i> 退出
            </button>
        </form>
    </div>
</nav>

@code {
    private HashSet<string> expandedSet = new();
    private int version = 0;
    private string currentTheme = "dark";
    private List<AgentCoreProcessor.WebUI.Shell.NavGroup> navGroups = new();

    private string themeIcon => currentTheme switch
    {
        "dark" => "bi-moon-stars",
        "tech" => "bi-lightning",
        "light" => "bi-sun",
        _ => "bi-circle-half"
    };
    private string themeLabel => currentTheme switch
    {
        "dark" => "暗色",
        "tech" => "科技",
        "light" => "亮色",
        _ => "主题"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            currentTheme = await JS.InvokeAsync<string>("getTheme");
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        currentTheme = await JS.InvokeAsync<string>("toggleTheme");
    }

    protected override void OnInitialized()
    {
        ExpandForCurrentPath();
        Nav.LocationChanged += OnLocationChanged;
        navGroups = Registry.BuildNavTree();
        Registry.OnChanged += OnRegistryChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        ExpandForCurrentPath();
        version++;
        InvokeAsync(StateHasChanged);
    }

    private void OnRegistryChanged()
    {
        navGroups = Registry.BuildNavTree();
        InvokeAsync(StateHasChanged);
    }

    private Navigation.NavItem ToNavItem(AgentCoreProcessor.WebUI.Shell.NavGroup group) => new()
    {
        Title = group.Name,
        Icon = group.Icon ?? "bi-folder",
        Children = group.Pages.Select(p => new Navigation.NavItem
        {
            Title = p.Meta.Title,
            Href = $"/p/{p.Route}",
            Icon = p.Meta.Icon ?? ""
        }).ToList()
    };

    private void ExpandForCurrentPath()
    {
        var path = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        foreach (var item in NavConfig.Items)
        {
            ExpandIfContains(item, path);
        }
    }

    private void ExpandIfContains(NavItem item, string currentPath)
    {
        if (item.Children.Count == 0) return;

        if (ContainsPath(item, currentPath))
        {
            expandedSet.Add(item.Title);
        }

        foreach (var child in item.Children)
        {
            ExpandIfContains(child, currentPath);
        }
    }

    private static bool ContainsPath(NavItem item, string currentPath)
    {
        if (item.Href != null && currentPath.Equals(item.Href, StringComparison.OrdinalIgnoreCase))
            return true;

        foreach (var child in item.Children)
        {
            if (child.Href != null && currentPath.Equals(child.Href, StringComparison.OrdinalIgnoreCase))
                return true;
            if (child.Children.Count > 0 && ContainsPath(child, currentPath))
                return true;
        }

        return false;
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        Registry.OnChanged -= OnRegistryChanged;
    }
}
