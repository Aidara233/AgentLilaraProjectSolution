@using AgentCoreProcessor.WebUI.Navigation
@inject NavigationManager Nav
@implements IDisposable

<li class="nav-item mt-1">
    <a class="nav-link text-white d-flex align-items-center nav-section-toggle @(expanded ? "" : "collapsed")"
       @onclick="Toggle" @onclick:preventDefault role="button">
        @if (!string.IsNullOrEmpty(Item.Icon))
        {
            <i class="bi @Item.Icon me-2"></i>
        }
        <span class="flex-grow-1">@Item.Title</span>
        <i class="bi bi-chevron-down nav-chevron ms-auto"></i>
    </a>

    @if (expanded)
    {
        <ul class="nav flex-column ms-3 mt-1">
            @foreach (var child in Item.Children)
            {
                @if (child.Children.Count == 0)
                {
                    <li class="nav-item">
                        <NavLink class="nav-link text-white py-1" href="@child.Href"
                                 Match="NavLinkMatch.All">
                            @if (!string.IsNullOrEmpty(child.Icon))
                            {
                                <i class="bi @child.Icon me-2"></i>
                            }
                            @child.Title
                        </NavLink>
                    </li>
                }
                else
                {
                    <NavSection Item="child" />
                }
            }
        </ul>
    }
</li>

@code {
    [Parameter] public NavItem Item { get; set; } = new();

    private bool expanded = false;

    protected override void OnInitialized()
    {
        expanded = ShouldExpand();
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        var shouldExpand = ShouldExpand();
        if (shouldExpand != expanded)
        {
            expanded = shouldExpand;
            InvokeAsync(StateHasChanged);
        }
    }

    private bool ShouldExpand()
    {
        var uri = Nav.ToBaseRelativePath(Nav.Uri);
        var path = "/" + uri;
        return ContainsActivePath(Item, path);
    }

    private static bool ContainsActivePath(NavItem item, string currentPath)
    {
        if (item.Href != null && currentPath.Equals(item.Href, StringComparison.OrdinalIgnoreCase))
            return true;

        foreach (var child in item.Children)
        {
            if (child.Href != null && currentPath.Equals(child.Href, StringComparison.OrdinalIgnoreCase))
                return true;
            if (child.Children.Count > 0 && ContainsActivePath(child, currentPath))
                return true;
        }

        return false;
    }

    private void Toggle()
    {
        expanded = !expanded;
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
