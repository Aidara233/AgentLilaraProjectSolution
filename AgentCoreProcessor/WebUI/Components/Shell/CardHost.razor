@using AgentLilara.PluginSDK.WebUI
@using AgentCoreProcessor.WebUI.Shell

<div class="card card-grid-item" style="@ColStyle @RowSpanStyle @HeightStyle @MinWidthStyle @OverflowStyle @CardFlexStyle">
    @if (!string.IsNullOrEmpty(Title))
    {
        <div class="card-header d-flex align-items-center">
            <span class="card-title">@Title</span>
            <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="OnRefreshClick" title="刷新">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    }
    <div class="card-body" style="@BodyOverflowStyle">
        @if (State?.Error != null)
        {
            <div class="card-error-state">
                <i class="bi bi-exclamation-triangle text-danger"></i>
                <span>@State.Error</span>
                <button class="btn btn-sm btn-outline-danger" @onclick="OnRefreshClick">重试</button>
            </div>
        }
        else if (State?.IsLoading == true && State.LastData == null)
        {
            <div class="card-loading-state">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                <span>加载中...</span>
            </div>
        }
        else
        {
            @ChildContent
        }
    </div>
</div>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public CardLayout Layout { get; set; } = new();
    [Parameter] public DataSourceState? State { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }

    private string ColStyle => Layout.GridColumnStart != null
        ? $"grid-column: {Layout.GridColumnStart} / span {Layout.PreferredCols};"
        : $"grid-column: span {Layout.PreferredCols};";
    private string HeightStyle => Layout.Height != null ? $"height:{Layout.Height};" : "";
    private string MinWidthStyle => Layout.MinWidth != null ? $"min-width:{Layout.MinWidth};" : "";
    private string RowSpanStyle => Layout.RowSpan > 1 ? $"grid-row: span {Layout.RowSpan};" : "";
    private string OverflowStyle => Layout.Height != null ? "overflow: hidden;" : "";
    private string BodyOverflowStyle => Layout.Height != null ? "overflow-y: auto; flex: 1; min-height: 0;" : "";
    private string CardFlexStyle => Layout.Height != null ? "display:flex; flex-direction:column;" : "";

    private async Task OnRefreshClick() => await OnRefresh.InvokeAsync();
}
