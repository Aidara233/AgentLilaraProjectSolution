@using AgentCoreProcessor.WebUI.Components.Shared

@if (Alerts.Any())
{
    <div class="alert-panel">
        <div class="alert-panel-header">
            <i class="bi bi-exclamation-triangle"></i>
            <span>警告</span>
            <span class="badge">@Alerts.Count</span>
        </div>
        @foreach (var alert in Alerts.OrderByDescending(a => a.Level))
        {
            <div class="alert-item">
                <i class="bi @GetIcon(alert.Level) @GetColorClass(alert.Level)"></i>
                <span class="alert-source">[@alert.Source]</span>
                <span>@alert.Message</span>
                @if (alert.LinkHref != null)
                {
                    <a href="@alert.LinkHref" class="alert-link">
                        <i class="bi bi-arrow-right"></i>
                    </a>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public List<AlertItem> Alerts { get; set; } = new();

    private static string GetIcon(AlertLevel level) => level switch
    {
        AlertLevel.Error => "bi-x-circle-fill",
        AlertLevel.Warning => "bi-exclamation-triangle-fill",
        _ => "bi-info-circle-fill"
    };

    private static string GetColorClass(AlertLevel level) => level switch
    {
        AlertLevel.Error => "alert-icon-error",
        AlertLevel.Warning => "alert-icon-warn",
        _ => "alert-icon-info"
    };
}
