@using AgentLilara.PluginSDK.WebUI
@using System.Text.Json.Nodes

<div class="status-card p-3">
    <div class="status-fields">
        @foreach (var field in Schema.Fields)
        {
            <div class="status-field-row">
                <span class="status-field-label">@field.Label</span>
                <span class="status-field-value @GetValueClass(field)">
                    @GetFieldValue(field)
                </span>
            </div>
        }
    </div>

    @if (Schema.Actions?.Count > 0)
    {
        <div class="status-actions">
            @foreach (var action in Schema.Actions)
            {
                <button class="btn btn-sm @(action.Danger ? "btn-outline-danger" : "btn-ghost")"
                        @onclick="() => HandleAction(action)">
                    @if (!string.IsNullOrEmpty(action.Icon))
                    {
                        <i class="bi @action.Icon me-1"></i>
                    }
                    @action.Label
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public StatusSchema Schema { get; set; } = null!;
    [Parameter] public JsonNode? Data { get; set; }
    [Parameter] public EventCallback<string> OnAction { get; set; }

    private string GetFieldValue(StatusField field)
    {
        if (Data is not JsonObject obj) return "-";
        var val = obj[field.Field];
        return val?.ToString() ?? "-";
    }

    private string GetValueClass(StatusField field)
    {
        if (field.Type == StatusFieldType.Badge)
            return "badge";
        if (field.Type == StatusFieldType.Indicator)
        {
            var val = GetFieldValue(field).ToLower();
            var color = val switch
            {
                "running" or "active" or "online" or "ok" => "color: var(--status-ok)",
                "stopped" or "offline" or "error" => "color: var(--status-error)",
                "idle" or "sleeping" or "paused" => "color: var(--status-warn)",
                _ => ""
            };
            return $"status-indicator\" style=\"{color}";
        }
        return "";
    }

    private async Task HandleAction(ActionButton action)
    {
        await OnAction.InvokeAsync(action.Id);
    }
}
