@using AgentLilara.PluginSDK.WebUI
@using System.Text.Json.Nodes
@inject NavigationManager Nav

<div class="table-card">
    @if (Schema.Searchable || Schema.Filters?.Count > 0)
    {
        <div class="table-card-toolbar mb-2 d-flex gap-2 flex-wrap align-items-center">
            @if (Schema.Searchable)
            {
                <input class="form-control form-control-sm" style="max-width:200px" placeholder="搜索..." @bind="_search" @bind:event="oninput" @onkeyup="OnSearchInput" />
            }
            @if (Schema.Filters != null)
            {
                foreach (var filter in Schema.Filters)
                {
                    <select class="form-select form-select-sm" style="max-width:140px"
                            @bind="_filters[filter.Field]" @bind:after="ApplyFilter">
                        @if (filter.AllowEmpty)
                        {
                            <option value="">@filter.Label</option>
                        }
                        @foreach (var opt in filter.Options)
                        {
                            <option value="@opt.Value">@opt.Label</option>
                        }
                    </select>
                }
            }
        </div>
    }

    <div class="table-responsive">
        <table class="table-dark-custom">
            <thead>
                <tr>
                    @foreach (var col in Schema.Columns)
                    {
                        <th style="@(col.Width != null ? $"width:{col.Width}" : "")"
                            class="@(col.Sortable ? "sortable-col" : "")"
                            @onclick="() => { if (col.Sortable) ToggleSort(col.Field); }">
                            @col.Header
                            @if (_sortBy == col.Field)
                            {
                                <i class="bi @(_sortDesc ? "bi-sort-down" : "bi-sort-up") ms-1"></i>
                            }
                        </th>
                    }
                    @if (Schema.RowActions?.Count > 0)
                    {
                        <th>操作</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (DisplayRows != null)
                {
                    var rowIndex = 0;
                    @foreach (var row in DisplayRows)
                    {
                        var link = row["_link"]?.ToString();
                        var idx = rowIndex;
                        var isSelectable = link == null && OnRowSelect.HasDelegate;
                        var isSelected = isSelectable && _selectedIndex == idx;
                        <tr class="@(link != null ? "row-clickable" : "") @(isSelectable ? "row-selectable" : "") @(isSelected ? "row-selected" : "")"
                            @onclick="() => HandleRowClick(link, idx, row)">
                            @foreach (var col in Schema.Columns)
                            {
                                <td>@RenderCell(row, col)</td>
                            }
                            @if (Schema.RowActions?.Count > 0)
                            {
                                <td>
                                    @foreach (var action in Schema.RowActions)
                                    {
                                        <button class="btn btn-sm @(action.Danger ? "btn-outline-danger" : "btn-outline-secondary") me-1"
                                                @onclick="() => HandleRowAction(action, row)" @onclick:stopPropagation>
                                            @action.Label
                                        </button>
                                    }
                                </td>
                            }
                        </tr>
                        rowIndex++;
                    }
                }
                else
                {
                    <tr><td colspan="@(Schema.Columns.Count + (Schema.RowActions?.Count > 0 ? 1 : 0))" class="text-center text-muted-custom" style="padding:1.5rem">暂无数据</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (Schema.Paginated)
    {
        <div class="table-card-pagination d-flex align-items-center justify-content-between mt-2 px-1">
            <span class="text-muted small">共 @LocalTotalCount 条</span>
            <div class="d-flex gap-1">
                <button class="btn btn-sm btn-outline-secondary" disabled="@(_page <= 1)" @onclick="PrevPage">上一页</button>
                <span class="btn btn-sm disabled">@_page / @TotalPages</span>
                <button class="btn btn-sm btn-outline-secondary" disabled="@(_page >= TotalPages)" @onclick="NextPage">下一页</button>
            </div>
        </div>
    }
    else if (LocalTotalCount > 0)
    {
        <div class="table-card-pagination d-flex align-items-center mt-2 px-1">
            <span class="text-muted small">共 @LocalTotalCount 条</span>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public TableSchema Schema { get; set; } = null!;
    [Parameter] public JsonNode? Data { get; set; }
    [Parameter] public int? TotalCount { get; set; }
    [Parameter] public EventCallback<DataQuery> OnQueryChanged { get; set; }
    [Parameter] public EventCallback<(string ActionId, JsonNode Row)> OnRowAction { get; set; }
    [Parameter] public EventCallback<JsonNode> OnRowSelect { get; set; }

    private List<JsonNode>? _rows;
    private string? _search;
    private string? _sortBy;
    private bool _sortDesc;
    private int _page = 1;
    private int _pageSize;
    private int _selectedIndex = -1;
    private Dictionary<string, string> _filters = new();

    private List<JsonNode>? FilteredRows
    {
        get
        {
            if (_rows == null) return null;
            var items = _rows.AsEnumerable();

            // 客户端搜索
            if (!string.IsNullOrWhiteSpace(_search))
            {
                var lower = _search.ToLowerInvariant();
                items = items.Where(r =>
                    Schema.Columns.Any(col =>
                        (r[col.Field]?.ToString() ?? "").ToLowerInvariant().Contains(lower)));
            }

            // 客户端筛选器
            foreach (var (field, value) in _filters)
            {
                if (!string.IsNullOrEmpty(value))
                    items = items.Where(r => (r[field]?.ToString() ?? "") == value);
            }

            // 客户端排序
            if (!string.IsNullOrEmpty(_sortBy))
            {
                items = _sortDesc
                    ? items.OrderByDescending(r => r[_sortBy]?.ToString() ?? "")
                    : items.OrderBy(r => r[_sortBy]?.ToString() ?? "");
            }

            return items.ToList();
        }
    }

    private int LocalTotalCount => FilteredRows?.Count ?? 0;

    private List<JsonNode>? DisplayRows
    {
        get
        {
            var filtered = FilteredRows;
            if (filtered == null) return null;
            if (!Schema.Paginated) return filtered;
            return filtered.Skip((_page - 1) * _pageSize).Take(_pageSize).ToList();
        }
    }

    private int TotalPages => Schema.Paginated && _pageSize > 0
        ? Math.Max(1, (int)Math.Ceiling(LocalTotalCount / (double)_pageSize))
        : 1;

    protected override void OnParametersSet()
    {
        _pageSize = Schema.DefaultPageSize;
        if (Data is JsonArray arr)
            _rows = arr.Where(n => n != null).Select(n => n!).ToList();
        else
            _rows = null;

        // 初始化筛选器字典中不存在的 key
        if (Schema.Filters != null)
        {
            foreach (var filter in Schema.Filters)
            {
                if (!_filters.ContainsKey(filter.Field))
                    _filters[filter.Field] = "";
            }
        }
    }

    private string GetCellValue(JsonNode row, ColumnDef col)
    {
        var val = row[col.Field];
        return val?.ToString() ?? "";
    }

    private RenderFragment RenderCell(JsonNode row, ColumnDef col) => __builder =>
    {
        var val = row[col.Field]?.ToString() ?? "";
        if (col.Format == ColumnFormat.Image)
        {
            var src = row["_img_src"]?.ToString() ?? val;
            <img src="@src" class="table-thumbnail" style="width:80px;height:60px;object-fit:cover;border-radius:4px;" loading="lazy" />
        }
        else if (col.Format == ColumnFormat.Link)
        {
            var href = row["_link"]?.ToString();
            if (href != null)
            {
                <a href="@href" class="table-link" @onclick="() => Nav.NavigateTo(href)" @onclick:preventDefault>@val</a>
            }
            else
            {
                @val
            }
        }
        else
        {
            @val
        }
    };

    private void ToggleSort(string field)
    {
        if (_sortBy == field) _sortDesc = !_sortDesc;
        else { _sortBy = field; _sortDesc = false; }
        _page = 1;
    }

    private void OnSearchInput(KeyboardEventArgs e)
    {
        _page = 1;
    }

    private void ApplyFilter()
    {
        _page = 1;
    }

    private async Task PrevPage()
    {
        if (_page > 1) { _page--; await EmitQuery(); }
    }

    private async Task NextPage()
    {
        if (_page < TotalPages) { _page++; await EmitQuery(); }
    }

    private async Task EmitQuery()
    {
        List<DataFilter>? filters = null;
        if (_filters.Count > 0)
        {
            filters = new List<DataFilter>();
            foreach (var (field, value) in _filters)
            {
                if (!string.IsNullOrEmpty(value))
                    filters.Add(new DataFilter { Field = field, Operator = "eq", Value = value });
            }
        }

        await OnQueryChanged.InvokeAsync(new DataQuery
        {
            Page = _page,
            PageSize = _pageSize,
            Search = _search,
            SortBy = _sortBy,
            SortDesc = _sortDesc,
            Filters = filters
        });
    }

    private async Task HandleRowAction(RowAction action, JsonNode row)
    {
        if (!string.IsNullOrEmpty(action.Confirm))
        {
            // 简单确认：实际页面可替换为模态框
        }
        await OnRowAction.InvokeAsync((action.Id, row));
    }

    private async Task HandleRowClick(string? link, int index, JsonNode row)
    {
        if (link != null)
        {
            Nav.NavigateTo(link);
            return;
        }
        if (OnRowSelect.HasDelegate)
        {
            _selectedIndex = index;
            await OnRowSelect.InvokeAsync(row);
        }
    }
}
