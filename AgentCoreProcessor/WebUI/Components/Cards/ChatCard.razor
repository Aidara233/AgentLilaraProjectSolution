@using AgentLilara.PluginSDK.WebUI
@using System.Text.Json.Nodes
@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="chat-card d-flex flex-column h-100">
    <div class="chat-messages flex-grow-1 overflow-auto p-2" style="min-height:0;" @ref="_msgContainer">
        @foreach (var msg in _messages)
        {
            var isBot = msg.IsBot;
            <div class="chat-message d-flex mb-2">
                <div class="chat-bubble @(isBot ? "chat-bot" : "chat-user")">
                    @if (!string.IsNullOrEmpty(msg.Sender))
                    {
                        <div class="chat-sender">@msg.Sender</div>
                    }
                    <div>@msg.Text</div>
                </div>
            </div>
        }
        @if (!_messages.Any())
        {
            <div class="text-muted text-center py-3">暂无消息</div>
        }
    </div>

    @if (Schema.ShowInput)
    {
        <div class="chat-input-area border-top pt-2 mt-2">
            @if (Schema.ShowSenderSwitch && Schema.Senders?.Count > 0)
            {
                <div class="mb-2">
                    <select class="form-select form-select-sm" @bind="_selectedSender">
                        @foreach (var s in Schema.Senders)
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>
            }
            <div class="d-flex gap-2 align-items-center">
                <input class="form-control form-control-sm" placeholder="输入消息..."
                       @bind="_inputText" @bind:event="oninput"
                       @onkeyup="OnInputKeyUp" />
                <button class="btn btn-sm btn-primary" style="min-width:56px; white-space:nowrap;" @onclick="HandleSend">发送</button>
                <button class="btn btn-sm btn-ghost" style="min-width:32px;" @onclick="ToggleAutoScroll"
                        title="@(_autoScroll ? "自动滚动：开" : "自动滚动：关")">
                    <i class="bi @(_autoScroll ? "bi-chevron-bar-down" : "bi-chevron-down")"></i>
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public ChatSchema Schema { get; set; } = null!;
    [Parameter] public JsonNode? Data { get; set; }
    [Parameter] public EventCallback<JsonNode> OnSubmit { get; set; }

    private List<ChatMessage> _messages = new();
    private string _inputText = "";
    private string _selectedSender = "";
    private bool _autoScroll = true;
    private ElementReference _msgContainer;
    private bool _needsScroll;

    private record ChatMessage(string Sender, string Text, bool IsBot);

    protected override void OnParametersSet()
    {
        var prevCount = _messages.Count;
        _messages = new List<ChatMessage>();
        if (Data is JsonArray arr)
        {
            foreach (var item in arr)
            {
                if (item is not JsonObject obj) continue;
                var sender = obj["sender"]?.ToString() ?? "";
                var text = obj["text"]?.ToString() ?? "";
                var role = obj["role"]?.ToString() ?? "";
                var isBot = obj["isBot"]?.GetValue<bool>()
                    ?? role is "assistant" or "bot" or "system";
                _messages.Add(new ChatMessage(sender, text, isBot));
            }
        }

        if (string.IsNullOrEmpty(_selectedSender) && Schema.Senders?.Count > 0)
            _selectedSender = Schema.Senders[0];

        // Auto-scroll when new messages arrive
        if (_autoScroll && _messages.Count > prevCount)
            _needsScroll = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_autoScroll && _needsScroll)
        {
            _needsScroll = false;
            await ScrollToBottom();
        }
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "arguments[0].scrollTop = arguments[0].scrollHeight", _msgContainer);
        }
        catch { }
    }

    private void ToggleAutoScroll()
    {
        _autoScroll = !_autoScroll;
        if (_autoScroll) _needsScroll = true;
    }

    private async Task OnInputKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleSend();
    }

    private async Task HandleSend()
    {
        if (string.IsNullOrWhiteSpace(_inputText)) return;

        var payload = new JsonObject
        {
            ["sender"] = _selectedSender,
            ["text"] = _inputText
        };
        _inputText = "";
        await OnSubmit.InvokeAsync(payload);
        if (_autoScroll) _needsScroll = true;
    }

    public async ValueTask DisposeAsync()
    {
        try { await ScrollToBottom(); } catch { }
    }
}
