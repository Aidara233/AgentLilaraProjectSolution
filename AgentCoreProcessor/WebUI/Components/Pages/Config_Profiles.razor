@page "/config/profiles"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Engine
@using AgentCoreProcessor.Tool.Host
@inject MasterEngine Engine

<div class="page-title">
    <i class="bi bi-diagram-3"></i> 组件配置
</div>

<div class="d-flex gap-3" style="min-height:600px;">
    @* ---- 左侧：Profile 树 ---- *@
    <div class="card" style="width:280px; flex-shrink:0;">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Profile 树</span>
            <button class="btn-ghost" style="font-size:var(--font-size-sm);" @onclick="ShowCreateDialog">
                <i class="bi bi-plus-circle"></i>
            </button>
        </div>
        <div class="card-body p-2" style="overflow-y:auto;">
            @if (treeRoot != null)
            {
                <div class="profile-tree">
                    @RenderNode(treeRoot, 0)
                </div>
            }
        </div>
    </div>

    @* ---- 右侧：详情面板 ---- *@
    <div class="card flex-grow-1">
        @if (selectedProfile == null)
        {
            <div class="card-body text-muted-custom d-flex align-items-center justify-content-center">
                点击左侧节点查看详情
            </div>
        }
        else
        {
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>
                    <strong>@selectedName</strong>
                    @if (!string.IsNullOrEmpty(selectedProfile.Description))
                    {
                        <small class="text-muted-custom ms-2">@selectedProfile.Description</small>
                    }
                </span>
                <div class="d-flex gap-1">
                    @if (selectedName != "_root")
                    {
                        @if (defaultProfile != selectedName)
                        {
                            <button class="btn-ghost" style="font-size:var(--font-size-sm);" @onclick="SetAsDefault">
                                <i class="bi bi-star me-1"></i>设为默认
                            </button>
                        }
                        <button class="btn-ghost" style="font-size:var(--font-size-sm);color:var(--danger-color);" @onclick="ShowDeleteDialog">
                            <i class="bi bi-trash me-1"></i>删除
                        </button>
                    }
                </div>
            </div>
<!-- PLACEHOLDER_DETAIL -->
            <div class="card-body" style="overflow-y:auto;">
                @* 频道映射 *@
                <div class="mb-3">
                    <h6 style="color:var(--text-secondary);font-size:var(--font-size-sm);">使用此 Profile 的频道</h6>
                    @{ var channels = GetChannelsForProfile(selectedName); }
                    @if (channels.Count == 0)
                    {
                        <span class="text-muted-custom" style="font-size:var(--font-size-sm);">无</span>
                    }
                    else
                    {
                        @foreach (var ch in channels)
                        {
                            <span class="badge-status badge-idle me-1 mb-1">
                                @(ch == "_default" ? "默认" : ch)
                            </span>
                        }
                    }
                </div>

                @* 组件状态 *@
                <div class="mb-3">
                    <h6 style="color:var(--text-secondary);font-size:var(--font-size-sm);">组件状态</h6>
                    <table class="table-dark-custom">
                        <thead><tr><th>组件</th><th>状态</th><th>来源</th></tr></thead>
                        <tbody>
                        @foreach (var comp in GetResolvedComponents())
                        {
                            <tr style="@(!comp.IsOwn ? "opacity:0.6;" : "")">
                                <td>@comp.Name</td>
                                <td>
                                    <select class="inline-edit-select" style="width:120px;"
                                            value="@comp.State"
                                            @onchange="e => ChangeComponentState(comp.Name, e.Value?.ToString())">
                                        <option value="enabled">启用</option>
                                        <option value="disabled">可激活</option>
                                        <option value="unavailable">不可用</option>
                                        @if (selectedName != "_root")
                                        {
                                            <option value="">继承</option>
                                        }
                                    </select>
                                </td>
                                <td style="font-size:var(--font-size-sm);">
                                    @(comp.IsOwn ? "本节点" : "继承")
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                @* 工具屏蔽 *@
                <div class="mb-3">
                    <h6 style="color:var(--text-secondary);font-size:var(--font-size-sm);">
                        工具屏蔽
                        <button class="btn-ghost ms-2" style="font-size:var(--font-size-sm);" @onclick="ShowAddBlockDialog">
                            <i class="bi bi-plus"></i>
                        </button>
                    </h6>
                    @if (selectedProfile.BlockedTools.Count == 0 && selectedProfile.UnblockedTools.Count == 0)
                    {
                        <span class="text-muted-custom" style="font-size:var(--font-size-sm);">无自定义屏蔽</span>
                    }
                    else
                    {
                        @foreach (var t in selectedProfile.BlockedTools)
                        {
                            <span class="badge-status badge-error me-1 mb-1">
                                <i class="bi bi-x-circle-fill me-1"></i>@t
                                <button class="btn-ghost" style="font-size:10px;padding:0 2px;" @onclick="() => RemoveBlocked(t)">×</button>
                            </span>
                        }
                        @foreach (var t in selectedProfile.UnblockedTools)
                        {
                            <span class="badge-status badge-working me-1 mb-1">
                                <i class="bi bi-check-circle-fill me-1"></i>@t (解除)
                                <button class="btn-ghost" style="font-size:10px;padding:0 2px;" @onclick="() => RemoveUnblocked(t)">×</button>
                            </span>
                        }
                    }
                </div>

                @* 描述编辑 *@
                <div class="mb-3">
                    <h6 style="color:var(--text-secondary);font-size:var(--font-size-sm);">描述</h6>
                    <input type="text" class="form-control form-control-sm" style="max-width:400px;"
                           @bind="editDescription" @bind:event="oninput" />
                    <button class="btn-ghost mt-1" style="font-size:var(--font-size-sm);" @onclick="SaveDescription">
                        <i class="bi bi-check me-1"></i>保存描述
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<!-- PLACEHOLDER_DIALOGS -->
@if (showCreateDialog)
{
<div class="modal-overlay" @onclick="() => showCreateDialog = false">
    <div class="card" style="width:360px;" @onclick:stopPropagation="true">
        <div class="card-header">新建 Profile</div>
        <div class="card-body">
            <label class="small text-muted-custom">名称</label>
            <input type="text" class="form-control form-control-sm mb-2" @bind="newProfileName" placeholder="例如: channel-beta" />
            <label class="small text-muted-custom">继承自</label>
            <select class="form-control form-control-sm mb-2" @bind="newProfileParent">
                @foreach (var name in profileNames)
                {
                    <option value="@name">@name</option>
                }
            </select>
            <label class="small text-muted-custom">描述</label>
            <input type="text" class="form-control form-control-sm" @bind="newProfileDesc" placeholder="可选" />
        </div>
        <div class="card-body" style="border-top:1px solid var(--border-color);display:flex;gap:0.5rem;justify-content:flex-end;">
            <button class="btn-ghost" @onclick="() => showCreateDialog = false">取消</button>
            <button class="btn-ghost" style="color:var(--accent-color);" @onclick="CreateProfile">创建</button>
        </div>
    </div>
</div>
}

@if (showDeleteDialog)
{
<div class="modal-overlay" @onclick="() => showDeleteDialog = false">
    <div class="card" style="width:360px;" @onclick:stopPropagation="true">
        <div class="card-header">删除 Profile: @selectedName</div>
        <div class="card-body">
            @{ var usedBy = GetChannelsForProfile(selectedName); }
            @if (usedBy.Count > 0)
            {
                <div style="color:var(--danger-color);margin-bottom:0.5rem;">
                    <i class="bi bi-exclamation-triangle me-1"></i>有 @usedBy.Count 个频道正在使用此 Profile！
                </div>
            }
            <p class="small">确定要删除吗？此操作不可撤销。</p>
        </div>
        <div class="card-body" style="border-top:1px solid var(--border-color);display:flex;gap:0.5rem;justify-content:flex-end;">
            <button class="btn-ghost" @onclick="() => showDeleteDialog = false">取消</button>
            <button class="btn-ghost" style="color:var(--danger-color);" @onclick="DeleteProfile">确认删除</button>
        </div>
    </div>
</div>
}

@if (showAddBlockDialog)
{
<div class="modal-overlay" @onclick="() => showAddBlockDialog = false">
    <div class="card" style="width:360px;" @onclick:stopPropagation="true">
        <div class="card-header">添加工具屏蔽</div>
        <div class="card-body">
            <label class="small text-muted-custom">工具名（支持通配符 *）</label>
            <input type="text" class="form-control form-control-sm mb-2" @bind="newBlockedTool" placeholder="例如: delete_file 或 dream_*" />
            <div class="form-check">
                <input class="form-check-input" type="checkbox" @bind="newBlockIsUnblock" />
                <label class="form-check-label small">解除屏蔽（unblock）</label>
            </div>
        </div>
        <div class="card-body" style="border-top:1px solid var(--border-color);display:flex;gap:0.5rem;justify-content:flex-end;">
            <button class="btn-ghost" @onclick="() => showAddBlockDialog = false">取消</button>
            <button class="btn-ghost" style="color:var(--accent-color);" @onclick="AddBlockedTool">添加</button>
        </div>
    </div>
</div>
}

<!-- PLACEHOLDER_STYLE -->
<style>
    .profile-tree { padding: 0.5rem 0; }
    .tree-node {
        position: relative;
        padding: 0.4rem 0.6rem;
        margin: 2px 0;
        border-radius: var(--radius-sm);
        cursor: pointer;
        font-size: var(--font-size-sm);
        transition: background 0.15s;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .tree-node:hover { background: var(--bg-hover); }
    .tree-node.selected { background: var(--accent-color-dim); border: 1px solid var(--accent-color); }
    .tree-node .node-icon { opacity: 0.6; }
    .tree-node .default-badge {
        font-size: 10px;
        color: var(--warning);
    }
    .tree-indent { padding-left: 1.2rem; border-left: 1px solid var(--border-color); margin-left: 0.6rem; }
    .modal-overlay {
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.5); z-index: 1000;
        display: flex; align-items: center; justify-content: center;
    }
</style>

@code {
    private List<string> profileNames = new();
    private string? selectedName;
    private ToolProfile? selectedProfile;
    private string defaultProfile = "";
    private TreeNode? treeRoot;
    private string editDescription = "";

    // 创建对话框
    private bool showCreateDialog;
    private string newProfileName = "";
    private string newProfileParent = "_root";
    private string newProfileDesc = "";

    // 删除对话框
    private bool showDeleteDialog;

    // 工具屏蔽对话框
    private bool showAddBlockDialog;
    private string newBlockedTool = "";
    private bool newBlockIsUnblock;

    protected override void OnInitialized()
    {
        Refresh();
    }

    private void Refresh()
    {
        profileNames = Engine.ToolProfiles.GetProfileNames();
        defaultProfile = Engine.ToolProfiles.GetDefaultProfile();
        treeRoot = BuildTree();
    }

    private void SelectProfile(string name)
    {
        selectedName = name;
        selectedProfile = Engine.ToolProfiles.GetProfile(name);
        editDescription = selectedProfile?.Description ?? "";
    }

    // ---- 树构建 ----
    private record TreeNode(string Name, List<TreeNode> Children);

    private TreeNode BuildTree()
    {
        var childMap = new Dictionary<string, List<string>>();
        foreach (var name in profileNames)
        {
            var p = Engine.ToolProfiles.GetProfile(name);
            var parent = p?.Inherits ?? "";
            if (!childMap.ContainsKey(parent)) childMap[parent] = new();
            if (!string.IsNullOrEmpty(parent))
                childMap[parent].Add(name);
        }
        return BuildNode("_root", childMap);
    }

    private TreeNode BuildNode(string name, Dictionary<string, List<string>> childMap)
    {
        var children = childMap.TryGetValue(name, out var list) ? list : new();
        return new TreeNode(name, children.Select(c => BuildNode(c, childMap)).ToList());
    }

    private RenderFragment RenderNode(TreeNode node, int depth) => __builder =>
    {
        var isSelected = node.Name == selectedName;
        var isDefault = node.Name == defaultProfile;
        <div class="tree-node @(isSelected ? "selected" : "")" @onclick="() => SelectProfile(node.Name)">
            <i class="bi bi-circle-fill node-icon" style="font-size:6px;"></i>
            <span>@node.Name</span>
            @if (isDefault)
            {
                <i class="bi bi-star-fill default-badge" title="默认"></i>
            }
        </div>
        @if (node.Children.Count > 0)
        {
            <div class="tree-indent">
                @foreach (var child in node.Children)
                {
                    @RenderNode(child, depth + 1)
                }
            </div>
        }
    };

    // ---- 组件状态解析 ----
    private record ComponentInfo(string Name, string State, bool IsOwn);

    private List<ComponentInfo> GetResolvedComponents()
    {
        if (selectedName == null || selectedProfile == null) return new();
        var allComponents = new HashSet<string>();
        foreach (var name in profileNames)
        {
            var p = Engine.ToolProfiles.GetProfile(name);
            if (p != null)
                foreach (var k in p.Components.Keys) allComponents.Add(k);
        }
        foreach (var reg in Component.ComponentRegistry.GetAll())
        {
            var attr = AgentLilara.PluginSDK.ComponentAttribute.GetFrom(reg.Type);
            if (attr != null) allComponents.Add(attr.Name);
        }

        return allComponents.OrderBy(n => n).Select(n =>
        {
            var isOwn = selectedProfile.Components.ContainsKey(n);
            var state = isOwn ? selectedProfile.Components[n] : "";
            return new ComponentInfo(n, state, isOwn);
        }).ToList();
    }

    private List<string> GetChannelsForProfile(string profileName)
    {
        return Engine.ToolProfiles.GetChannelMapping()
            .Where(kv => kv.Value == profileName)
            .Select(kv => kv.Key)
            .ToList();
    }

    // ---- 操作 ----
    private void ChangeComponentState(string component, string? value)
    {
        if (selectedProfile == null || selectedName == null) return;
        if (string.IsNullOrEmpty(value))
        {
            selectedProfile.Components.Remove(component);
        }
        else
        {
            selectedProfile.Components[component] = value;
        }
        Engine.ToolProfiles.Save();
        StateHasChanged();
    }

    private void SaveDescription()
    {
        if (selectedProfile == null) return;
        selectedProfile.Description = editDescription;
        Engine.ToolProfiles.Save();
    }

    private void SetAsDefault()
    {
        if (selectedName == null) return;
        Engine.ToolProfiles.SetDefaultProfile(selectedName);
        defaultProfile = selectedName;
    }

    private void RemoveBlocked(string tool)
    {
        selectedProfile?.BlockedTools.Remove(tool);
        Engine.ToolProfiles.Save();
    }

    private void RemoveUnblocked(string tool)
    {
        selectedProfile?.UnblockedTools.Remove(tool);
        Engine.ToolProfiles.Save();
    }

    // ---- 对话框操作 ----
    private void ShowCreateDialog()
    {
        newProfileName = "";
        newProfileParent = selectedName ?? "_root";
        newProfileDesc = "";
        showCreateDialog = true;
    }

    private void ShowDeleteDialog() => showDeleteDialog = true;
    private void ShowAddBlockDialog()
    {
        newBlockedTool = "";
        newBlockIsUnblock = false;
        showAddBlockDialog = true;
    }

    private void CreateProfile()
    {
        if (string.IsNullOrWhiteSpace(newProfileName)) return;
        if (profileNames.Contains(newProfileName)) return;

        var profile = new ToolProfile
        {
            Inherits = newProfileParent,
            Description = string.IsNullOrWhiteSpace(newProfileDesc) ? null : newProfileDesc
        };
        // 直接操作配置（ToolProfileManager 需要暴露添加方法）
        Engine.ToolProfiles.AddProfile(newProfileName, profile);
        showCreateDialog = false;
        Refresh();
        SelectProfile(newProfileName);
    }

    private void DeleteProfile()
    {
        if (selectedName == null || selectedName == "_root") return;
        Engine.ToolProfiles.RemoveProfile(selectedName);
        showDeleteDialog = false;
        selectedName = null;
        selectedProfile = null;
        Refresh();
    }

    private void AddBlockedTool()
    {
        if (selectedProfile == null || string.IsNullOrWhiteSpace(newBlockedTool)) return;
        if (newBlockIsUnblock)
            selectedProfile.UnblockedTools.Add(newBlockedTool.Trim());
        else
            selectedProfile.BlockedTools.Add(newBlockedTool.Trim());
        Engine.ToolProfiles.Save();
        showAddBlockDialog = false;
    }
}
