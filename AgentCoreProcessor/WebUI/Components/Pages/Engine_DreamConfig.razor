@page "/dream/config"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Config
@using Newtonsoft.Json
@using System.IO

<div class="page-title">
    <i class="bi bi-gear"></i> 做梦 — 配置
</div>

@if (saveMessage != null)
{
    <div class="alert-bar @(saveSuccess ? "alert-ok" : "alert-error") mb-3">
        <i class="bi @(saveSuccess ? "bi-check-circle" : "bi-x-circle")"></i>
        <span>@saveMessage</span>
    </div>
}

<div class="row g-4">
    <!-- 时间阈值 -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-clock me-1 text-accent"></i> 时间阈值
            </div>
            <div class="card-body">
                <div class="config-field">
                    <label>走神冷却期（秒）</label>
                    <input type="number" @bind="cfg.DaydreamCooldown" />
                </div>
                <div class="config-field">
                    <label>小睡空闲阈值（秒）</label>
                    <input type="number" @bind="cfg.NapIdleThreshold" />
                </div>
                <div class="config-field">
                    <label>大睡空闲阈值（秒）</label>
                    <input type="number" @bind="cfg.DeepSleepIdleThreshold" />
                </div>
                <div class="config-field">
                    <label>调度检查间隔（秒）</label>
                    <input type="number" @bind="cfg.ScheduleInterval" />
                </div>
                <div class="config-field">
                    <label>许可超时自动批准（秒）</label>
                    <input type="number" @bind="cfg.PermissionTimeout" />
                </div>
            </div>
        </div>
    </div>

    <!-- 大睡时间窗口 -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-moon-stars me-1 text-accent"></i> 大睡时间窗口
            </div>
            <div class="card-body">
                <div class="config-field">
                    <label>开始时间</label>
                    <input type="text" @bind="cfg.DeepSleepTimeStart" placeholder="HH:mm" />
                </div>
                <div class="config-field">
                    <label>结束时间</label>
                    <input type="text" @bind="cfg.DeepSleepTimeEnd" placeholder="HH:mm" />
                </div>
                <div class="config-field">
                    <label>峰值时间</label>
                    <input type="text" @bind="cfg.DeepSleepTimePeak" placeholder="HH:mm" />
                </div>
                <div class="config-field">
                    <label>大睡硬性时间上限（分钟）</label>
                    <input type="number" @bind="cfg.DeepSleepMaxMinutes" />
                </div>
            </div>
        </div>
    </div>

    <!-- 片段限制 -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-layers me-1 text-accent"></i> 片段限制
            </div>
            <div class="card-body">
                <div class="config-field">
                    <label>小睡最大片段数</label>
                    <input type="number" @bind="cfg.MaxFragmentsPerNap" />
                </div>
                <div class="config-field">
                    <label>大睡最大片段数</label>
                    <input type="number" @bind="cfg.MaxFragmentsPerDeepSleep" />
                </div>
            </div>
        </div>
    </div>

    <!-- 睡觉评分 -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-graph-up me-1 text-accent"></i> 睡觉评分
            </div>
            <div class="card-body">
                <div class="config-field">
                    <label>黄色阈值（触发许可请求）</label>
                    <input type="number" step="0.1" @bind="cfg.YellowThreshold" />
                </div>
                <div class="config-field">
                    <label>评分偏置（正=嗜睡，负=夜猫子）</label>
                    <input type="number" step="0.1" @bind="cfg.ScoreBase" />
                </div>
                <div class="config-field">
                    <label>红色条件：临时记忆倍率</label>
                    <input type="number" step="0.1" @bind="cfg.RedTempMultiplier" />
                </div>
                <div class="config-field">
                    <label>红色条件：最大睡觉间隔（小时）</label>
                    <input type="number" step="0.1" @bind="cfg.RedMaxSleepGapHours" />
                </div>
            </div>
        </div>
    </div>

    <!-- Token 预算 -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-coin me-1 text-accent"></i> Token 预算
            </div>
            <div class="card-body">
                <div class="config-field">
                    <label>大睡片段预算</label>
                    <input type="number" @bind="cfg.DeepSleepTokenBudget" />
                </div>
                <div class="config-field">
                    <label>Review 基础预算</label>
                    <input type="number" @bind="cfg.ReviewTokenBudget" />
                </div>
                <div class="config-field">
                    <label>Review 备用预算</label>
                    <input type="number" @bind="cfg.ReviewReserveBudget" />
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 保存按钮 -->
<div class="mt-4 d-flex gap-2">
    <button class="btn-primary-custom" @onclick="Save">
        <i class="bi bi-check2"></i> 保存配置
    </button>
    <button class="btn-ghost" @onclick="Reload">
        <i class="bi bi-arrow-clockwise"></i> 重新加载
    </button>
</div>

@code {
    private DreamConfigModel cfg = new();
    private string? saveMessage;
    private bool saveSuccess;

    private static string ConfigPath =>
        Path.Combine(PathConfig.StoragePath, "Dream", "DreamConfig.json");

    protected override void OnInitialized()
    {
        LoadConfig();
    }

    private void LoadConfig()
    {
        try
        {
            if (File.Exists(ConfigPath))
            {
                var json = File.ReadAllText(ConfigPath);
                cfg = JsonConvert.DeserializeObject<DreamConfigModel>(json) ?? new();
            }
        }
        catch (Exception ex)
        {
            saveMessage = $"加载失败: {ex.Message}";
            saveSuccess = false;
        }
    }

    private void Save()
    {
        try
        {
            var dir = Path.GetDirectoryName(ConfigPath);
            if (dir != null) Directory.CreateDirectory(dir);
            var json = JsonConvert.SerializeObject(cfg, Formatting.Indented);
            File.WriteAllText(ConfigPath, json);
            saveMessage = "配置已保存";
            saveSuccess = true;
        }
        catch (Exception ex)
        {
            saveMessage = $"保存失败: {ex.Message}";
            saveSuccess = false;
        }
    }

    private void Reload()
    {
        LoadConfig();
        saveMessage = "已重新加载";
        saveSuccess = true;
    }

    private class DreamConfigModel
    {
        public int DaydreamCooldown { get; set; } = 120;
        public int NapIdleThreshold { get; set; } = 600;
        public int DeepSleepIdleThreshold { get; set; } = 1800;
        public string DeepSleepTimeStart { get; set; } = "02:00";
        public string DeepSleepTimeEnd { get; set; } = "06:00";
        public string DeepSleepTimePeak { get; set; } = "00:00";
        public int PermissionTimeout { get; set; } = 3600;
        public int ScheduleInterval { get; set; } = 30;
        public int MaxFragmentsPerNap { get; set; } = 5;
        public int MaxFragmentsPerDeepSleep { get; set; } = 50;
        public float YellowThreshold { get; set; } = 5.0f;
        public float ScoreBase { get; set; } = 0.0f;
        public float RedTempMultiplier { get; set; } = 3.0f;
        public float RedMaxSleepGapHours { get; set; } = 48.0f;
        public int DeepSleepTokenBudget { get; set; } = 100000;
        public int ReviewTokenBudget { get; set; } = 50000;
        public int ReviewReserveBudget { get; set; } = 15000;
        public int DeepSleepMaxMinutes { get; set; } = 120;
    }
}
