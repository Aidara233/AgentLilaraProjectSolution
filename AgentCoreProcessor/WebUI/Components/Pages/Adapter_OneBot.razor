@page "/adapters/onebot"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Adapter
@using System.Collections.Generic
@inject AdapterManager Adapters
@inject NavigationManager Nav
@implements IDisposable

<div class="page-title">
    <i class="bi bi-chat-square-dots"></i> 适配器 — OneBot
</div>

<div class="row g-2 mb-4 align-items-center">
    @foreach (var inst in instances)
    {
        <div class="col-auto">
            <button class="@(inst.Id == selectedId ? "btn-primary-custom" : "btn-ghost")"
                    style="padding:0.3rem 0.8rem; font-size:0.85rem;"
                    @onclick="() => Select(inst.Id)">
                <i class="bi bi-circle-fill" style="font-size:0.5rem; color:@StatusColor(inst);"></i>
                @inst.Id
            </button>
        </div>
    }
    <div class="col-auto">
        <button class="btn-ghost" style="padding:0.3rem 0.8rem; font-size:0.85rem;" @onclick="GoCreate">
            <i class="bi bi-plus"></i> 新建
        </button>
    </div>
</div>

@if (selected == null)
{
    <div class="page-placeholder">
        <i class="bi bi-chat-square-dots"></i>
        <span>选择一个 OneBot 实例查看详情</span>
    </div>
}
else
{
    var cfg = Adapters.GetConfigById(selectedId);
    <div class="row g-3 mb-4">
        <div class="col-md-3"><StatCard Label="状态" Value="@StateLabel(selected.State)" ValueClass="@StateClass(selected.State)" /></div>
        <div class="col-md-3"><StatCard Label="收到" Value="@selected.MessagesReceived.ToString()" /></div>
        <div class="col-md-3"><StatCard Label="发送" Value="@selected.MessagesSent.ToString()" /></div>
        <div class="col-md-3"><StatCard Label="重连" Value="@selected.ReconnectCount.ToString()" /></div>
    </div>
    <!--PART2-->
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-gear me-1 text-accent"></i> 控制</div>
        <div class="card-body">
            <div class="row g-3 align-items-center">
                <div class="col-auto">
                    @if (selected.Enabled)
                    { <button class="btn-ghost" style="color:var(--status-error);" @onclick="() => Disable(selectedId)">禁用</button> }
                    else
                    { <button class="btn-ghost" @onclick="() => Enable(selectedId)">启用</button> }
                </div>
                <div class="col-auto">
                    <label class="config-label" style="margin:0;display:inline;">自动启动</label>
                    <input type="checkbox" checked="@(cfg?.AutoStart ?? true)" @onchange="e => SetAutoStart((bool)(e.Value ?? false))" />
                </div>
                <div class="col-auto">
                    <label class="config-label" style="margin:0;display:inline;">调试模式启动</label>
                    <input type="checkbox" checked="@(cfg?.AutoStartDebug ?? false)" @onchange="e => SetAutoStartDebug((bool)(e.Value ?? false))" />
                </div>
            </div>
            @if (selected.LastError != null)
            {
                <div class="alert-bar mt-2" style="--alert-color: var(--status-error);">最后错误 (@selected.LastErrorAt?.ToString("MM-dd HH:mm")): @selected.LastError</div>
            }
        </div>
    </div>
    <!--PART3-->
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-sliders me-1 text-accent"></i> 连接配置</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="config-label">WebSocket URL</label>
                    <input class="config-input" @bind="editWsUrl" />
                </div>
                <div class="col-md-4">
                    <label class="config-label">Token</label>
                    <input class="config-input" type="password" @bind="editToken" />
                </div>
                <div class="col-md-4">
                    <label class="config-label">过滤模式</label>
                    <select class="config-input" @bind="editFilterMode">
                        <option value="whitelist">白名单</option>
                        <option value="blacklist">黑名单</option>
                        <option value="none">不过滤</option>
                    </select>
                </div>
                <div class="col-md-8">
                    <label class="config-label">Bot 名称（逗号分隔）</label>
                    <input class="config-input" @bind="editBotNames" />
                </div>
                <div class="col-12">
                    <label class="config-label">@(editFilterMode == "blacklist" ? "黑名单" : "白名单")（逗号分隔）</label>
                    <input class="config-input" @bind="editFilterList" />
                </div>
                <div class="col-auto">
                    <button class="btn-primary-custom" @onclick="SaveConfig">保存配置</button>
                </div>
                @if (!string.IsNullOrEmpty(saveMsg))
                { <div class="col-auto" style="align-self:center;"><span class="text-ok">@saveMsg</span></div> }
            </div>
        </div>
    </div>
    <!--PART4-->
    <div class="card">
        <div class="card-header"><i class="bi bi-lightning me-1 text-accent"></i> 操作面板</div>
        <div class="card-body">
            @{ var adapter = Adapters.GetAdapterById(selectedId); }
            @if (adapter != null)
            {
                var acts = adapter.GetAvailableActions();
                <div class="row g-3">
                @foreach (var act in acts)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card" style="background:var(--bg-secondary); border:1px solid var(--border);">
                            <div class="card-body" style="padding:0.75rem;">
                                <strong style="font-size:0.85rem;">@act.Label</strong>
                                <div style="font-size:0.75rem; color:var(--text-muted); margin-bottom:0.5rem;">@act.Description</div>
                                @foreach (var p in act.Params)
                                {
                                    var paramKey = act.Name + "_" + p.Name;
                                    <input class="config-input mb-1" placeholder="@p.Label"
                                           style="font-size:0.8rem; padding:0.25rem 0.5rem;"
                                           value="@GetParam(paramKey)"
                                           @onchange="e => SetParam(paramKey, e.Value?.ToString())" />
                                }
                                <button class="btn-ghost" style="font-size:0.75rem; padding:0.2rem 0.5rem;"
                                        @onclick="() => ExecuteAction(act)">执行</button>
                                @if (actionResults.TryGetValue(act.Name, out var result))
                                {
                                    <div style="margin-top:0.4rem; font-size:0.75rem; max-height:8rem; overflow:auto; padding:0.3rem; background:var(--bg-primary); border-radius:4px;">
                                        @if (result.Success)
                                        {
                                            <span class="text-ok">成功</span>
                                            @if (!string.IsNullOrEmpty(result.Result))
                                            { <pre style="margin:0.2rem 0 0; white-space:pre-wrap; font-size:0.7rem; color:var(--text-secondary);">@Truncate(result.Result, 500)</pre> }
                                        }
                                        else
                                        { <span class="text-error">失败: @result.Error</span> }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
                </div>
            }
        </div>
    </div>
}

@code {
    private List<AdapterStatus> instances = new();
    private string selectedId = "";
    private AdapterStatus? selected;
    private System.Threading.Timer? refreshTimer;
    private string editWsUrl = "", editToken = "", editFilterMode = "whitelist", editBotNames = "", editFilterList = "";
    private string? saveMsg;
    private Dictionary<string, string> actionParams = new();
    private Dictionary<string, ActionResult> actionResults = new();

    [SupplyParameterFromQuery] public string? Id { get; set; }

    protected override void OnInitialized()
    {
        RefreshInstances();
        if (!string.IsNullOrEmpty(Id) && instances.Any(i => i.Id == Id))
            Select(Id);
        else if (instances.Count > 0)
            Select(instances[0].Id);
        refreshTimer = new System.Threading.Timer(_ =>
        {
            RefreshInstances();
            if (!string.IsNullOrEmpty(selectedId))
                selected = instances.FirstOrDefault(i => i.Id == selectedId);
            InvokeAsync(StateHasChanged);
        }, null, 3000, 3000);
    }

    private void RefreshInstances() =>
        instances = Adapters.GetAllStatuses().Where(s => s.Platform.Equals("qq", StringComparison.OrdinalIgnoreCase)).ToList();

    private void Select(string id)
    {
        selectedId = id;
        selected = instances.FirstOrDefault(i => i.Id == id);
        LoadEditFields();
        actionResults.Clear();
    }

    private void LoadEditFields()
    {
        var cfg = Adapters.GetConfigById(selectedId);
        if (cfg == null) return;
        editWsUrl = cfg.Settings["wsUrl"]?.ToString() ?? "";
        editToken = cfg.Settings["token"]?.ToString() ?? "";
        editFilterMode = cfg.Settings["filterMode"]?.ToString() ?? "whitelist";
        editBotNames = string.Join(", ", cfg.Settings["botNames"]?.ToObject<List<string>>() ?? new());
        var listKey = editFilterMode == "blacklist" ? "blacklist" : "whitelist";
        editFilterList = string.Join(", ", cfg.Settings[listKey]?.ToObject<List<string>>() ?? new());
        saveMsg = null;
    }

    private void SaveConfig()
    {
        var cfg = Adapters.GetConfigById(selectedId);
        if (cfg == null) return;
        cfg.Settings["wsUrl"] = editWsUrl;
        cfg.Settings["token"] = editToken;
        cfg.Settings["filterMode"] = editFilterMode;
        cfg.Settings["botNames"] = new Newtonsoft.Json.Linq.JArray(editBotNames.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));
        var listKey = editFilterMode == "blacklist" ? "blacklist" : "whitelist";
        cfg.Settings[listKey] = new Newtonsoft.Json.Linq.JArray(editFilterList.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));
        Adapters.UpdateConfig(cfg);
        saveMsg = "已保存";
    }

    private async Task Enable(string id) { await Adapters.EnableAsync(id); RefreshInstances(); selected = instances.FirstOrDefault(i => i.Id == id); }
    private async Task Disable(string id) { await Adapters.DisableAsync(id); RefreshInstances(); selected = instances.FirstOrDefault(i => i.Id == id); }
    private void SetAutoStart(bool val) { var c = Adapters.GetConfigById(selectedId); if (c != null) { c.AutoStart = val; Adapters.UpdateConfig(c); } }
    private void SetAutoStartDebug(bool val) { var c = Adapters.GetConfigById(selectedId); if (c != null) { c.AutoStartDebug = val; Adapters.UpdateConfig(c); } }

    private async Task ExecuteAction(AdapterAction act)
    {
        var a = Adapters.GetAdapterById(selectedId);
        if (a == null) return;
        var parms = new Dictionary<string, string>();
        foreach (var p in act.Params)
            if (actionParams.TryGetValue($"{act.Name}_{p.Name}", out var v) && !string.IsNullOrEmpty(v))
                parms[p.Name] = v;
        actionResults[act.Name] = await a.ExecuteActionAsync(act.Name, parms);
    }

    private void GoCreate() => Nav.NavigateTo("/adapters");
    private string GetParam(string key) => actionParams.TryGetValue(key, out var v) ? v : "";
    private void SetParam(string key, string? val) => actionParams[key] = val ?? "";
    private static string StatusColor(AdapterStatus s) => s.State switch
    {
        AdapterConnectionState.Connected => "var(--status-ok)",
        AdapterConnectionState.Error => "var(--status-error)",
        _ => "var(--text-muted)"
    };
    private static string StateClass(AdapterConnectionState st) => st switch
    {
        AdapterConnectionState.Connected => "text-ok",
        AdapterConnectionState.Reconnecting => "text-warning-custom",
        AdapterConnectionState.Error => "text-error",
        _ => "text-muted-custom"
    };
    private static string StateLabel(AdapterConnectionState st) => st switch
    {
        AdapterConnectionState.Connected => "已连接",
        AdapterConnectionState.Reconnecting => "重连中",
        AdapterConnectionState.Error => "错误",
        AdapterConnectionState.Connecting => "连接中",
        AdapterConnectionState.Stopped => "已停止",
        _ => "未知"
    };
    private static string Truncate(string s, int max) => s.Length <= max ? s : s[..max] + "...";
    public void Dispose() => refreshTimer?.Dispose();
}
