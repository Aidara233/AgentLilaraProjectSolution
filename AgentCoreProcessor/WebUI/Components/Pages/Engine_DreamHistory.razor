@page "/dream/history"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Config
@using AgentCoreProcessor.Database
@using AgentCoreProcessor.Engine
@inject MasterEngine Engine
@using System.IO

<div class="page-title">
    <i class="bi bi-clock-history"></i> 做梦 — 历史
</div>

<div class="d-flex gap-2 mb-4">
    <button class="btn-ghost" @onclick="Reload">
        <i class="bi bi-arrow-clockwise"></i> 刷新
    </button>
</div>

<!-- 近期会话 -->
<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-list-ul me-1 text-accent"></i> 近期睡觉会话
    </div>
    <div class="card-body p-0">
        @if (sessions.Count == 0)
        {
            <div class="p-3 text-muted-custom">暂无历史记录</div>
        }
        else
        {
            <table class="table-dark-custom">
                <thead>
                    <tr>
                        <th>时间</th>
                        <th>级别</th>
                        <th>时长</th>
                        <th>片段数</th>
                        <th>状态</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in sessions)
                    {
                        <tr @onclick="() => ToggleSession(session.Id)" style="cursor:pointer;">
                            <td>@session.StartTime.ToString("MM-dd HH:mm")</td>
                            <td>
                                <span class="badge-status @LevelBadge(session.Level)">@LevelLabel(session.Level)</span>
                            </td>
                            <td>@FormatDuration(session.EndTime - session.StartTime)</td>
                            <td>@session.FragmentsExecuted</td>
<!-- PLACEHOLDER_CONTINUE -->
                            <td>
                                @if (session.WasInterrupted)
                                {
                                    <span class="text-warning-custom">被打断</span>
                                }
                                else
                                {
                                    <span class="text-ok">完成</span>
                                }
                            </td>
                            <td>
                                <i class="bi @(expandedSession == session.Id ? "bi-chevron-up" : "bi-chevron-down")"></i>
                            </td>
                        </tr>
                        @if (expandedSession == session.Id && fragments.Count > 0)
                        {
                            @foreach (var frag in fragments)
                            {
                                <tr @onclick="() => ToggleFragment(frag.Id)" @onclick:stopPropagation="true"
                                    style="cursor:pointer; background:var(--bg-secondary);">
                                    <td style="padding-left:2rem;">
                                        <span class="badge-status @(frag.Success ? "badge-info" : "badge-error")">
                                            @FragmentLabel(frag.Type)
                                        </span>
                                    </td>
                                    <td colspan="3">@frag.Summary</td>
                                    <td>@($"{frag.DurationSeconds:F1}s")</td>
                                    <td>
                                        @if (expandedFragment == frag.Id) { <i class="bi bi-chevron-up"></i> }
                                    </td>
                                </tr>
                                @if (expandedFragment == frag.Id)
                                {
                                    <tr>
                                        <td colspan="6" style="padding:0.5rem 1rem 0.75rem 3rem; background:var(--bg-tertiary);">
                                            @if (!string.IsNullOrEmpty(frag.InputMemoryIds))
                                            {
                                                <div class="io-section">
                                                    <span class="io-label">输入</span>
                                                    @foreach (var mem in GetInputMemories(frag))
                                                    {
                                                        <div class="io-item">
                                                            <span class="text-muted-custom">#@mem.Id</span>
                                                            <span>@mem.Content</span>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(frag.OutputRaw))
                                            {
                                                <div class="io-section">
                                                    <span class="io-label">输出</span>
                                                    <pre class="output-raw">@frag.OutputRaw</pre>
                                                </div>
                                            }
                                            @if (details.Count > 0)
                                            {
                                                <div class="io-section">
                                                    <span class="io-label">操作</span>
                                                    <div class="detail-list">
                                                        @foreach (var d in details)
                                                        {
                                                            <div class="detail-row">
                                                                <span class="badge-status badge-express">@d.Action</span>
                                                                @if (d.MemoryId != null) { <span class="text-muted-custom">#@d.MemoryId</span> }
                                                                @if (d.OldValue != null && d.NewValue != null) { <span>@d.OldValue → @d.NewValue</span> }
                                                                @if (d.Note != null) { <span class="text-muted-custom">@d.Note</span> }
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    }
                </tbody>
            </table>
        }
    </div>
</div>
<!-- PLACEHOLDER_STATS -->

<!-- 每日统计 -->
<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-bar-chart me-1 text-accent"></i> 每日统计（近 7 天）
    </div>
    <div class="card-body p-0">
        @if (stats.DailyRecords.Count == 0)
        {
            <div class="p-3 text-muted-custom">暂无统计数据</div>
        }
        else
        {
            <table class="table-dark-custom">
                <thead>
                    <tr>
                        <th>日期</th>
                        <th>临时记忆峰值</th>
                        <th>已处理</th>
                        <th>未做梦峰值</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in stats.DailyRecords.OrderByDescending(r => r.Date))
                    {
                        <tr>
                            <td>@record.Date</td>
                            <td>@record.TempPeak</td>
                            <td class="text-accent">@record.Processed</td>
                            <td>@record.UndreamedPeak</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <StatCard Label="基线均值" Value="@stats.Baseline.AvgDailyTempIntake.ToString("F1")" />
    </div>
    <div class="col-md-4">
        <StatCard Label="基线更新" Value="@(string.IsNullOrEmpty(stats.Baseline.LastUpdate) ? "—" : stats.Baseline.LastUpdate)" />
    </div>
    <div class="col-md-4">
        <StatCard Label="连续红色天数" Value="@stats.ConsecutiveRedDays.ToString()"
                  ValueClass="@(stats.ConsecutiveRedDays > 0 ? "error" : "")" />
    </div>
</div>

<style>
    .detail-list { display: flex; flex-direction: column; gap: 0.25rem; }
    .detail-row { display: flex; gap: 0.5rem; align-items: center; font-size: 0.85rem; flex-wrap: wrap; }
    .io-section { margin-bottom: 0.75rem; }
    .io-label { display: block; font-size: 0.75rem; font-weight: 600; color: var(--text-accent); margin-bottom: 0.25rem; text-transform: uppercase; }
    .io-item { font-size: 0.85rem; padding: 0.15rem 0; display: flex; gap: 0.5rem; }
    .output-raw { font-size: 0.8rem; background: var(--bg-primary); padding: 0.5rem; border-radius: 4px; max-height: 200px; overflow-y: auto; white-space: pre-wrap; word-break: break-all; margin: 0; }
</style>

@code {
    private List<DreamSession> sessions = new();
    private List<DreamFragment> fragments = new();
    private List<DreamFragmentDetail> details = new();
    private Dictionary<int, string> memoryCache = new();
    private DreamStats stats = new();
    private int? expandedSession;
    private int? expandedFragment;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        sessions = await Engine.DreamLogs.GetRecentSessionsAsync(30);
        var statsPath = Path.Combine(PathConfig.StoragePath, "Dream", "DreamStats.json");
        stats = DreamStats.Load(statsPath);
    }

    private async Task Reload()
    {
        await LoadData();
        expandedSession = null;
        expandedFragment = null;
    }

    private async Task ToggleSession(int sessionId)
    {
        if (expandedSession == sessionId)
        {
            expandedSession = null;
            fragments.Clear();
            details.Clear();
        }
        else
        {
            expandedSession = sessionId;
            expandedFragment = null;
            fragments = await Engine.DreamLogs.GetFragmentsBySessionAsync(sessionId);
            details.Clear();
        }
    }

    private async Task ToggleFragment(int fragmentId)
    {
        if (expandedFragment == fragmentId)
        {
            expandedFragment = null;
            details.Clear();
        }
        else
        {
            expandedFragment = fragmentId;
            details = await Engine.DreamLogs.GetDetailsByFragmentAsync(fragmentId);
            var frag = fragments.FirstOrDefault(f => f.Id == fragmentId);
            if (frag?.InputMemoryIds != null)
                await LoadMemoryCache(frag.InputMemoryIds);
        }
    }

    private async Task LoadMemoryCache(string inputIds)
    {
        var ids = ParseAllIds(inputIds);
        var missing = ids.Where(id => !memoryCache.ContainsKey(id)).ToList();
        if (missing.Count > 0)
        {
            var entries = await Engine.Memories.GetByIdsAsync(missing);
            foreach (var e in entries)
                memoryCache[e.Id] = e.Content;
            // 也查临时记忆（整合时输入的是临时记忆 ID）
            var tempEntries = await Engine.TempMemories.GetByIdsAsync(missing.Except(entries.Select(e => e.Id)).ToList());
            foreach (var t in tempEntries)
                memoryCache[t.Id] = t.Content;
        }
    }

    private List<(int Id, string Content)> GetInputMemories(DreamFragment frag)
    {
        if (string.IsNullOrEmpty(frag.InputMemoryIds)) return new();
        var ids = ParseAllIds(frag.InputMemoryIds);
        return ids.Select(id => (id, memoryCache.GetValueOrDefault(id, "(未找到)"))).ToList();
    }

    private static List<int> ParseAllIds(string input)
    {
        var ids = new List<int>();
        foreach (var part in input.Split('|', ',', ';', ':'))
        {
            var trimmed = part.Trim();
            if (trimmed == "target" || trimmed == "candidates") continue;
            if (int.TryParse(trimmed, out var id))
                ids.Add(id);
        }
        return ids.Distinct().ToList();
    }

    private static string LevelBadge(string level) => level switch
    {
        "DeepSleep" => "badge-working",
        "Nap" => "badge-info",
        "Daydream" => "badge-express",
        _ => "badge-info"
    };

    private static string LevelLabel(string level) => level switch
    {
        "DeepSleep" => "大睡",
        "Nap" => "小睡",
        "Daydream" => "走神",
        _ => level
    };

    private static string FragmentLabel(string type) => type switch
    {
        "Consolidation" => "整合",
        "Weight" => "权重",
        "Link" => "关联",
        "Combine" => "组合",
        _ => type
    };

    private static string FormatDuration(TimeSpan ts)
    {
        if (ts.TotalHours >= 1) return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        if (ts.TotalMinutes >= 1) return $"{ts.Minutes}m {ts.Seconds}s";
        return $"{ts.Seconds}s";
    }
}
