@page "/engine/channels"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.WebUI.Services
@inject SystemMonitor Monitor
@inject NavigationManager Nav
@implements IDisposable

<div class="page-title">
    <i class="bi bi-chat-dots"></i> 频道循环 — 频道列表
</div>

<!-- 统计卡片 -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <StatCard Label="活跃频道" Value="@snap.Workers.Count.ToString()"
                  ValueClass="@(snap.Workers.Count > 0 ? "accent" : "")" />
    </div>
    <div class="col-md-3">
        <StatCard Label="处理中"
                  Value="@snap.Workers.Count(w => w.IsBusy).ToString()"
                  ValueClass="@(snap.Workers.Any(w => w.IsBusy) ? "error" : "")" />
    </div>
    <div class="col-md-3">
        <StatCard Label="活跃频道"
                  Value="@snap.Workers.Count(w => w.IsAlive).ToString()"
                  ValueClass="accent" />
    </div>
    <div class="col-md-3">
        <StatCard Label="Working 模式"
                  Value="@snap.Workers.Count(w => w.IsWorkingMode).ToString()" />
    </div>
</div>

<!-- 频道表格 -->
@if (snap.Workers.Count == 0)
{
    <div class="card">
        <div class="card-body text-muted-custom">当前无活跃频道</div>
    </div>
}
else
{
    <div class="card">
        <div class="card-header">
            <i class="bi bi-diagram-3 me-1 text-accent"></i> 活跃频道
        </div>
        <div class="card-body p-0">
            <table class="table-dark-custom">
                <thead>
                    <tr>
                        <th>频道</th>
                        <th>模式</th>
                        <th>状态</th>
                        <th>冲动值</th>
                        <th>阈值</th>
                        <th>轮次</th>
                        <th>参与者</th>
                        <th>已处理</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var w in snap.Workers.OrderByDescending(w => w.Impulse))
                    {
                        <tr style="cursor:pointer" @onclick="() => NavToChannel(w.ChannelId)">
                            <td>
                                <span class="text-accent">#@w.ChannelId</span>
                                @if (!string.IsNullOrEmpty(w.ChannelName))
                                {
                                    <span class="text-muted-custom ms-1">@w.ChannelName</span>
                                }
                            </td>
                            <td>
                                <span class="badge-status @(w.IsWorkingMode ? "badge-working" : "badge-express")">
                                    @(w.IsWorkingMode ? "Working" : "Express")
                                </span>
                            </td>
                            <td>
                                @if (w.IsBusy)
                                {
                                    <span class="text-error">处理中</span>
                                }
                                else if (w.HasRecentError)
                                {
                                    <span style="color:var(--status-warn);" title="@w.LastErrorMessage">
                                        <i class="bi bi-exclamation-triangle"></i> 错误×@w.ConsecutiveFailures
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted-custom">等待</span>
                                }
                            </td>
                            <td>
                                <span class="@ImpulseClass(w.Impulse)">@w.Impulse.ToString("F1")</span>
                            </td>
                            <td>@w.Threshold.ToString("F0")</td>
                            <td>@w.TotalRounds</td>
                            <td>@w.ParticipantCount</td>
                            <td>@w.ProcessedMessageCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private SystemSnapshot snap = new();

    protected override void OnInitialized()
    {
        snap = Monitor.Current;
        Monitor.OnStateChanged += OnStateChanged;
    }

    private void OnStateChanged()
    {
        snap = Monitor.Current;
        InvokeAsync(StateHasChanged);
    }

    private void NavToChannel(int channelId)
    {
        Nav.NavigateTo($"/engine/channels/{channelId}");
    }

    private static string ImpulseClass(float impulse) => impulse switch
    {
        >= 80f => "text-error",
        >= 50f => "text-warning-custom",
        _ => ""
    };

    public void Dispose() => Monitor.OnStateChanged -= OnStateChanged;
}
