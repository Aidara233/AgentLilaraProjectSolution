@page "/engine"
@page "/engine/manage"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.WebUI.Services
@using AgentCoreProcessor.Engine
@using AgentCoreProcessor.Engine.Vision
@inject SystemMonitor Monitor
@inject MasterEngine Engine
@implements IDisposable

<div class="page-title">
    <i class="bi bi-cpu"></i> 引擎控制
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stat-label">静音模式</div>
                        <div class="stat-value">@(snap.MuteMode ? "已开启" : "已关闭")</div>
                    </div>
                    <button class="@(snap.MuteMode ? "btn-accent" : "btn-ghost")"
                            @onclick="ToggleMute">
                        <i class="bi @(snap.MuteMode ? "bi-volume-mute" : "bi-volume-up") me-1"></i>
                        @(snap.MuteMode ? "关闭静音" : "开启静音")
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="stat-label">系统状态</div>
                <div class="stat-value @(snap.IsIdle ? "ok" : "error")">
                    @(snap.IsIdle ? "空闲" : "忙碌") — @FormatDuration(snap.IdleDuration)
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-cpu me-1 text-accent"></i> 活跃引擎
    </div>
    <div class="card-body p-0">
        @if (snap.EngineSummary.Count == 0)
        {
            <div class="p-3 text-muted-custom">无活跃引擎</div>
        }
        else
        {
            <table class="table-dark-custom">
                <thead>
                    <tr>
                        <th>引擎类型</th>
                        <th>数量</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (type, count) in snap.EngineSummary)
                    {
                        <tr>
                            <td>@type</td>
                            <td>@count</td>
                            <td>
                                <button class="btn-ghost" style="color:var(--status-error); border-color:var(--status-error);"
                                        @onclick="() => StopEngines(type)">
                                    <i class="bi bi-stop-circle me-1"></i>停止
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (visionSnap != null)
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-eye me-1 text-accent"></i> 视觉引擎</span>
            <div class="d-flex gap-1">
                <button class="btn-ghost" @onclick="TriggerVision" title="立即处理">
                    <i class="bi bi-play-circle me-1"></i>触发
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-3">
                    <div class="stat-label">状态</div>
                    <div class="stat-value @(visionSnap.IsBusy ? "error" : "ok")">@(visionSnap.IsBusy ? "处理中" : "空闲")</div>
                </div>
                <div class="col-md-3">
                    <div class="stat-label">活跃任务</div>
                    <div class="stat-value">@visionSnap.ActiveTasks</div>
                </div>
                <div class="col-md-3">
                    <div class="stat-label">已处理</div>
                    <div class="stat-value">@visionSnap.TotalProcessed</div>
                </div>
                <div class="col-md-3">
                    <div class="stat-label">错误</div>
                    <div class="stat-value @(visionSnap.VisionErrors + visionSnap.OcrErrors > 0 ? "error" : "")">V:@visionSnap.VisionErrors / O:@visionSnap.OcrErrors</div>
                </div>
            </div>
            <div class="row g-2 mt-2">
                <div class="col-md-4">
                    <span class="small text-muted-custom">Vision: @(visionSnap.VisionAvailable ? "可用" : "不可用")</span>
                </div>
                <div class="col-md-4">
                    <span class="small text-muted-custom">OCR: @(visionSnap.OcrAvailable ? "可用" : "不可用")</span>
                </div>
                <div class="col-md-4">
                    <span class="small text-muted-custom">并发: V@(visionSnap.Config.VisionConcurrency)/O@(visionSnap.Config.OcrConcurrency)</span>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div style="background:var(--status-info-dim); color:var(--status-info); padding:0.75rem 1rem; border-radius:var(--radius-md); display:flex; align-items:center; justify-content:space-between;">
        <span>@statusMessage</span>
        <button class="btn-ghost" style="padding:0.2rem 0.5rem;" @onclick="() => statusMessage = null">
            <i class="bi bi-x"></i>
        </button>
    </div>
}

@code {
    private SystemSnapshot snap = new();
    private VisionEngineSnapshot? visionSnap;
    private string? statusMessage;

    protected override void OnInitialized()
    {
        snap = Monitor.Current;
        RefreshVisionSnap();
        Monitor.OnStateChanged += OnStateChanged;
    }

    private void OnStateChanged()
    {
        snap = Monitor.Current;
        RefreshVisionSnap();
        InvokeAsync(StateHasChanged);
    }

    private void RefreshVisionSnap()
    {
        var check = Engine.GetSpawnCheck<VisionEngineSpawnCheck>();
        visionSnap = check?.ActiveInstance?.GetSnapshot();
    }

    private void TriggerVision()
    {
        var check = Engine.GetSpawnCheck<VisionEngineSpawnCheck>();
        check?.ActiveInstance?.SignalGate();
        statusMessage = "已触发视觉引擎处理";
    }

    private void ToggleMute()
    {
        Engine.MuteMode = !Engine.MuteMode;
        statusMessage = Engine.MuteMode ? "静音模式已开启" : "静音模式已关闭";
    }

    private void StopEngines(string type)
    {
        Engine.RequestStopEnginesByType(type);
        statusMessage = $"已请求停止所有 {type} 引擎";
    }

    private static string FormatDuration(TimeSpan ts)
    {
        if (ts.TotalHours >= 1) return $"{ts.Hours}h {ts.Minutes}m";
        if (ts.TotalMinutes >= 1) return $"{ts.Minutes}m {ts.Seconds}s";
        return $"{ts.Seconds}s";
    }

    public void Dispose()
    {
        Monitor.OnStateChanged -= OnStateChanged;
    }
}
