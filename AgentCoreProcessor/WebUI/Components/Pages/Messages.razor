@page "/messages"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Engine
@using AgentCoreProcessor.Database
@inject MasterEngine Engine

<h4 class="mb-3">消息历史</h4>

<div class="row g-2 mb-3">
    <div class="col-md-3">
        <select class="form-select form-select-sm" @bind="selectedChannelId" @bind:after="LoadMessages">
            <option value="0">选择频道...</option>
            @foreach (var ch in channels)
            {
                <option value="@ch.Id">#@ch.Id @ch.Name</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <div class="input-group input-group-sm">
            <input type="text" class="form-control" placeholder="搜索消息内容..."
                   @bind="keyword" @bind:event="oninput" />
            <button class="btn btn-outline-primary" @onclick="LoadMessages">
                <i class="bi bi-search"></i>
            </button>
        </div>
    </div>
    <div class="col-md-2">
        <small class="text-muted">共 @totalCount 条</small>
    </div>
</div>

@if (selectedChannelId > 0)
{
    <div class="card">
        <div class="card-body p-0">
            @if (messages.Count == 0)
            {
                <div class="p-3 text-muted text-center">无消息</div>
            }
            else
            {
                <div class="list-group list-group-flush" style="max-height:calc(100vh - 280px); overflow-y:auto">
                    @foreach (var m in messages)
                    {
                        <div class="list-group-item py-2 @(m.IsFromBot ? "bg-light" : "")">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <span class="fw-semibold @(m.IsFromBot ? "text-primary" : "")">
                                        @(m.IsFromBot ? "Lilara" : (string.IsNullOrEmpty(m.SenderName) ? "用户" : m.SenderName))
                                    </span>
                                    @if (m.IsFromBot)
                                    {
                                        <span class="badge bg-primary ms-1">Bot</span>
                                    }
                                </div>
                                <small class="text-muted">@m.Time.ToString("MM-dd HH:mm:ss")</small>
                            </div>
                            <div class="mt-1" style="white-space:pre-wrap; word-break:break-all">@m.Content</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @if (totalCount > pageSize)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">上一页</button>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">@currentPage / @totalPages</span>
                </li>
                <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">下一页</button>
                </li>
            </ul>
        </nav>
    }
}

@code {
    private List<Channel> channels = new();
    private List<UserMessage> messages = new();
    private int selectedChannelId = 0;
    private string keyword = "";
    private int totalCount = 0;
    private int currentPage = 1;
    private const int pageSize = 50;
    private int totalPages => (int)Math.Ceiling((double)totalCount / pageSize);

    protected override async Task OnInitializedAsync()
    {
        channels = await Engine.Session.GetAllChannelsAsync();
    }

    private async Task LoadMessages()
    {
        if (selectedChannelId <= 0) { messages.Clear(); return; }
        currentPage = 1;
        await FetchPage();
    }

    private async Task GoToPage(int page)
    {
        currentPage = Math.Clamp(page, 1, Math.Max(1, totalPages));
        await FetchPage();
    }

    private async Task FetchPage()
    {
        var offset = (currentPage - 1) * pageSize;
        var kw = string.IsNullOrWhiteSpace(keyword) ? null : keyword.Trim();
        totalCount = await Engine.Session.GetMessageCountByChannelAsync(selectedChannelId);
        messages = await Engine.Session.SearchMessagesByChannelAsync(selectedChannelId, kw, offset, pageSize);
        messages.Reverse();
    }
}
