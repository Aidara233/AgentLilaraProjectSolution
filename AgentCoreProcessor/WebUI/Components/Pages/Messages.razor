@page "/messages"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Engine
@using AgentCoreProcessor.Database
@inject MasterEngine Engine

<div class="page-title">
    <i class="bi bi-chat-left-text"></i> 消息历史
</div>

<div class="row g-2 mb-3">
    <div class="col-md-3">
        <select class="form-select form-select-sm" @bind="selectedChannelId" @bind:after="LoadMessages">
            <option value="0">选择频道...</option>
            @foreach (var ch in channels)
            {
                <option value="@ch.Id">#@ch.Id @ch.Name</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <div class="d-flex gap-1">
            <input type="text" class="form-control form-control-sm" placeholder="搜索消息内容..."
                   @bind="keyword" @bind:event="oninput" />
            <button class="btn-ghost" @onclick="LoadMessages">
                <i class="bi bi-search"></i>
            </button>
        </div>
    </div>
    <div class="col-md-2">
        <small class="text-muted-custom">共 @totalCount 条</small>
    </div>
</div>

@if (selectedChannelId > 0)
{
    <div class="card">
        <div class="card-body p-0">
            @if (messages.Count == 0)
            {
                <div class="p-3 text-muted-custom" style="text-align:center;">无消息</div>
            }
            else
            {
                <div style="max-height:calc(100vh - 280px); overflow-y:auto">
                    @foreach (var m in messages)
                    {
                        <div class="msg-item @(m.IsFromBot ? "msg-bot" : "")">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <span class="fw-semibold @(m.IsFromBot ? "text-accent" : "")">
                                        @(m.IsFromBot ? "Lilara" : (string.IsNullOrEmpty(m.SenderName) ? "用户" : m.SenderName))
                                    </span>
                                    @if (m.IsFromBot)
                                    {
                                        <span class="badge-status badge-info ms-1">Bot</span>
                                    }
                                </div>
                                <small class="text-muted-custom">@m.Time.ToString("MM-dd HH:mm:ss")</small>
                            </div>
                            <div class="mt-1" style="white-space:pre-wrap; word-break:break-all; color:var(--text-primary);">@m.Content</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @if (totalCount > pageSize)
    {
        <div class="d-flex justify-content-center gap-2 mt-3">
            <button class="btn-ghost" disabled="@(currentPage <= 1)" @onclick="() => GoToPage(currentPage - 1)">上一页</button>
            <span style="color:var(--text-muted); padding:0.4rem 0.5rem; font-size:var(--font-size-sm);">@currentPage / @totalPages</span>
            <button class="btn-ghost" disabled="@(currentPage >= totalPages)" @onclick="() => GoToPage(currentPage + 1)">下一页</button>
        </div>
    }
}

@code {
    private List<Channel> channels = new();
    private List<UserMessage> messages = new();
    private int selectedChannelId = 0;
    private string keyword = "";
    private int totalCount = 0;
    private int currentPage = 1;
    private const int pageSize = 50;
    private int totalPages => (int)Math.Ceiling((double)totalCount / pageSize);

    protected override async Task OnInitializedAsync()
    {
        channels = await Engine.Session.GetAllChannelsAsync();
    }

    private async Task LoadMessages()
    {
        if (selectedChannelId <= 0) { messages.Clear(); return; }
        currentPage = 1;
        await FetchPage();
    }

    private async Task GoToPage(int page)
    {
        currentPage = Math.Clamp(page, 1, Math.Max(1, totalPages));
        await FetchPage();
    }

    private async Task FetchPage()
    {
        var offset = (currentPage - 1) * pageSize;
        var kw = string.IsNullOrWhiteSpace(keyword) ? null : keyword.Trim();
        totalCount = await Engine.Session.GetMessageCountByChannelAsync(selectedChannelId);
        messages = await Engine.Session.SearchMessagesByChannelAsync(selectedChannelId, kw, offset, pageSize);
        messages.Reverse();
    }
}
