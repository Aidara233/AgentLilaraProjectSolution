@page "/console"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Engine
@using AgentCoreProcessor.Database
@using AgentCoreProcessor.Adapter
@inject MasterEngine Engine
@inject EventBus Bus
@implements IDisposable

<div class="page-title">
    <i class="bi bi-terminal"></i> 控制台
</div>

<div class="row g-3">
    <!-- 左侧：频道选择 + 操作 -->
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-header">频道</div>
            <div class="card-body">
                <select class="form-select form-select-sm mb-2" @bind="selectedChannelId" @bind:after="OnChannelChanged">
                    <option value="0">选择频道...</option>
                    @foreach (var ch in channels)
                    {
                        <option value="@ch.Id">#@ch.Id @ch.Name</option>
                    }
                </select>
                <div class="d-flex gap-1">
                    <input type="text" class="form-control form-control-sm" placeholder="新频道名..." @bind="newChannelName" />
                    <button class="btn-ghost" style="padding:0.3rem 0.6rem;" @onclick="CreateChannel">
                        <i class="bi bi-plus"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">发送模式</div>
            <div class="card-body">
                <label class="console-radio">
                    <input type="radio" name="sendMode" checked="@(sendMode == "user")" @onchange='() => sendMode = "user"' />
                    <span>模拟用户</span>
                </label>
                <label class="console-radio">
                    <input type="radio" name="sendMode" checked="@(sendMode == "bot")" @onchange='() => sendMode = "bot"' />
                    <span>替 Bot 说话</span>
                </label>
                <label class="console-radio">
                    <input type="radio" name="sendMode" checked="@(sendMode == "custom")" @onchange='() => sendMode = "custom"' />
                    <span>自定义发送者</span>
                </label>
                @if (sendMode == "user")
                {
                    <div class="mt-2" style="padding-left:0.2rem;">
                        <label class="console-check">
                            <input type="checkbox" @bind="simulateMention" /> 模拟 @@提及
                        </label>
                        <label class="console-check">
                            <input type="checkbox" @bind="simulatePrivate" /> 模拟私聊
                        </label>
                    </div>
                }
                @if (sendMode == "custom")
                {
                    <input type="text" class="form-control form-control-sm mt-2" placeholder="发送者名称"
                           @bind="customSenderName" />
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div style="background:var(--status-info-dim); color:var(--status-info); padding:0.5rem 0.75rem; border-radius:var(--radius-sm); font-size:var(--font-size-sm);">
                @statusMessage
            </div>
        }
    </div>

    <!-- 右侧：消息流 + 输入 -->
    <div class="col-md-9">
        <div class="card" style="height:calc(100vh - 140px); display:flex; flex-direction:column;">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>
                    @if (selectedChannelId > 0)
                    {
                        <span class="text-accent">#@selectedChannelId</span>
                        <span class="ms-1">@selectedChannelName</span>
                    }
                    else
                    {
                        <span class="text-muted-custom">选择一个频道开始</span>
                    }
                </span>
                <button class="btn-ghost" style="padding:0.3rem 0.5rem;" @onclick="RefreshMessages" disabled="@(selectedChannelId == 0)">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>

            <!-- 消息流 -->
            <div class="card-body flex-grow-1" style="overflow-y:auto; padding:0.75rem;">
                @if (selectedChannelId == 0)
                {
                    <div class="text-muted-custom" style="text-align:center; margin-top:3rem;">选择左侧频道查看消息</div>
                }
                else if (messages.Count == 0)
                {
                    <div class="text-muted-custom" style="text-align:center; margin-top:3rem;">暂无消息</div>
                }
                else
                {
                    @foreach (var m in messages)
                    {
                        <div class="chat-bubble @(m.IsFromBot ? "chat-bot" : "chat-user")">
                            <div class="chat-meta">
                                <span class="chat-sender">
                                    @(m.IsFromBot ? "Lilara" : (string.IsNullOrEmpty(m.SenderName) ? "用户" : m.SenderName))
                                </span>
                                <span class="chat-time">@m.Time.ToString("HH:mm:ss")</span>
                            </div>
                            <div class="chat-content">@m.Content</div>
                        </div>
                    }
                }
            </div>

            <!-- 输入框 -->
            <div style="padding:0.75rem; border-top:1px solid var(--border);">
                <div class="d-flex gap-1">
                    <input type="text" class="form-control" placeholder="@InputPlaceholder"
                           @bind="inputText" @bind:event="oninput"
                           @onkeydown="HandleKeyDown"
                           disabled="@(selectedChannelId == 0)" />
                    <button class="btn-accent" style="padding:0.4rem 0.8rem;"
                            @onclick="SendMessage"
                            disabled="@(selectedChannelId == 0 || string.IsNullOrWhiteSpace(inputText))">
                        <i class="bi bi-send"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Channel> channels = new();
    private List<UserMessage> messages = new();
    private int selectedChannelId = 0;
    private string selectedChannelName = "";
    private string newChannelName = "";
    private string inputText = "";
    private string sendMode = "user";
    private bool simulateMention = false;
    private bool simulatePrivate = false;
    private string customSenderName = "TestUser";
    private string? statusMessage;
    private System.Threading.Timer? pollTimer;
    private int lastMessageCount = 0;

    private string InputPlaceholder => sendMode switch
    {
        "bot" => "替 Lilara 说话...",
        "custom" => $"以 {customSenderName} 身份发送...",
        _ => "发送消息..."
    };

    protected override async Task OnInitializedAsync()
    {
        channels = await Engine.Session.GetAllChannelsAsync();
    }

    private async Task OnChannelChanged()
    {
        StopPolling();
        if (selectedChannelId > 0)
        {
            var ch = channels.FirstOrDefault(c => c.Id == selectedChannelId);
            selectedChannelName = ch?.Name ?? "";
            await RefreshMessages();
            StartPolling();
        }
        else
        {
            selectedChannelName = "";
            messages.Clear();
        }
    }

    private async Task RefreshMessages()
    {
        if (selectedChannelId <= 0) return;
        messages = await Engine.Session.GetContextByChannelAsync(selectedChannelId, 50);
        lastMessageCount = messages.Count;
    }

    private void StartPolling()
    {
        pollTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                var latest = await Engine.Session.GetContextByChannelAsync(selectedChannelId, 50);
                if (latest.Count != lastMessageCount)
                {
                    messages = latest;
                    lastMessageCount = latest.Count;
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch { }
        }, null, 2000, 2000);
    }

    private void StopPolling()
    {
        pollTimer?.Dispose();
        pollTimer = null;
    }

    private async Task HandleKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(inputText))
            await SendMessage();
    }

    private async Task SendMessage()
    {
        if (selectedChannelId <= 0 || string.IsNullOrWhiteSpace(inputText)) return;
        var text = inputText.Trim();
        inputText = "";

        switch (sendMode)
        {
            case "user":
                await SendAsUser(text);
                break;
            case "bot":
                await SendAsBot(text);
                break;
            case "custom":
                await SendAsCustom(text);
                break;
        }

        await Task.Delay(500);
        await RefreshMessages();
    }

    private Task SendAsUser(string text)
    {
        var ch = channels.FirstOrDefault(c => c.Id == selectedChannelId);
        var channelName = ch?.Name ?? $"web_{selectedChannelId}";

        var msg = new IncomingMessage
        {
            Platform = "WebConsole",
            PlatformUserId = "web-admin",
            ChannelId = channelName,
            Content = text,
            DisplayName = "WebAdmin",
            Time = DateTime.Now,
            IsPrivate = simulatePrivate,
            IsMentioned = simulateMention
        };

        Bus.PublishMessage(msg);
        statusMessage = "消息已发送";
        return Task.CompletedTask;
    }

    private async Task SendAsBot(string text)
    {
        await Engine.Session.SaveBotMessageAsync(selectedChannelId, text, null);
        statusMessage = "Bot 消息已注入";
    }

    private Task SendAsCustom(string text)
    {
        var ch = channels.FirstOrDefault(c => c.Id == selectedChannelId);
        var channelName = ch?.Name ?? $"web_{selectedChannelId}";

        var msg = new IncomingMessage
        {
            Platform = "WebConsole",
            PlatformUserId = $"custom-{customSenderName.ToLowerInvariant()}",
            ChannelId = channelName,
            Content = text,
            DisplayName = customSenderName,
            Time = DateTime.Now,
            IsPrivate = false,
            IsMentioned = false
        };

        Bus.PublishMessage(msg);
        statusMessage = $"以 {customSenderName} 身份发送";
        return Task.CompletedTask;
    }

    private async Task CreateChannel()
    {
        if (string.IsNullOrWhiteSpace(newChannelName)) return;
        var name = newChannelName.Trim();
        newChannelName = "";

        var msg = new IncomingMessage
        {
            Platform = "WebConsole",
            PlatformUserId = "web-admin",
            ChannelId = name,
            Content = "(频道已创建)",
            DisplayName = "WebAdmin",
            Time = DateTime.Now,
            IsPrivate = false
        };

        Bus.PublishMessage(msg);
        await Task.Delay(1000);
        channels = await Engine.Session.GetAllChannelsAsync();
        statusMessage = $"频道 {name} 已创建";
    }

    public void Dispose()
    {
        StopPolling();
    }
}
