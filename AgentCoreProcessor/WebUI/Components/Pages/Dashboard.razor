@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.WebUI.Services
@inject SystemMonitor Monitor
@inject LogStreamService LogStream
@implements IDisposable

<div class="page-title">
    <i class="bi bi-speedometer2"></i> 总览
</div>

<!-- 警告面板 -->
<AlertPanel Alerts="snap.Alerts" />

<!-- 系统状态卡片 -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <StatCard Label="系统状态"
                  Value="@(snap.IsIdle ? "空闲" : "忙碌")"
                  CssClass="@(snap.IsIdle ? "idle" : "busy")"
                  ValueClass="@(snap.IsIdle ? "ok" : "error")" />
    </div>
    <div class="col-md-3">
        <StatCard Label="空闲时长"
                  Value="@FormatDuration(snap.IdleDuration)"
                  CssClass="info" />
    </div>
    <div class="col-md-3">
        <StatCard Label="上次消息"
                  Value="@snap.LastMessageTime.ToString("HH:mm:ss")"
                  CssClass="info" />
    </div>
    <div class="col-md-3">
        <StatCard Label="静音模式"
                  Value="@(snap.MuteMode ? "开启" : "关闭")"
                  CssClass="@(snap.MuteMode ? "muted" : "idle")" />
    </div>
</div>

<!-- 引擎摘要 + 做梦状态 -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-cpu me-1 text-accent"></i> 引擎摘要
            </div>
            <div class="card-body">
                @if (snap.EngineSummary.Count == 0)
                {
                    <span class="text-muted-custom">无活跃引擎</span>
                }
                else
                {
                    @foreach (var (type, count) in snap.EngineSummary)
                    {
                        <span class="badge-status badge-info me-2">@type: @count</span>
                    }
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-moon-stars me-1 text-accent"></i> 做梦状态
            </div>
            <div class="card-body">
                @if (snap.DreamState == null)
                {
                    <span class="text-muted-custom">未加载</span>
                }
                else
                {
                    var d = snap.DreamState;
                    <div class="d-flex flex-wrap gap-3">
                        <div>
                            <div class="stat-label">状态</div>
                            <span class="@(d.HasActiveDream ? "text-info-custom" : "text-secondary-custom")">
                                @(d.HasActiveDream ? "做梦中" : "清醒")
                            </span>
                        </div>
                        <div>
                            <div class="stat-label">上次走神</div>
                            <span>@(d.LastDaydreamTime?.ToString("HH:mm:ss") ?? "从未")</span>
                        </div>
                        <div>
                            <div class="stat-label">待执行</div>
                            <span>@d.PendingLevel</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- 活跃 Worker -->
<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-diagram-3 me-1 text-accent"></i> 活跃 Worker
    </div>
    <div class="card-body p-0">
        @if (snap.Workers.Count == 0)
        {
            <div class="p-3 text-muted-custom">无活跃 Worker</div>
        }
        else
        {
            <table class="table-dark-custom">
                <thead>
                    <tr>
                        <th>频道</th>
                        <th>模式</th>
                        <th>状态</th>
                        <th>冲动值</th>
                        <th>阈值</th>
                        <th>轮次</th>
                        <th>参与者</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var w in snap.Workers)
                    {
                        <tr @onclick="() => NavToWorker(w.ChannelId)">
                            <td>
                                #@w.ChannelId
                                @if (!string.IsNullOrEmpty(w.ChannelName))
                                {
                                    <span class="text-muted-custom ms-1">@w.ChannelName</span>
                                }
                            </td>
                            <td>
                                <span class="badge-status @(w.IsWorkingMode ? "badge-working" : "badge-express")">
                                    @(w.IsWorkingMode ? "Working" : "Express")
                                </span>
                            </td>
                            <td>
                                @if (w.IsBusy)
                                {
                                    <span class="text-error">处理中</span>
                                }
                                else
                                {
                                    <span class="text-muted-custom">等待</span>
                                }
                            </td>
                            <td>@w.Impulse.ToString("F1")</td>
                            <td>@w.Threshold.ToString("F0")</td>
                            <td>@w.TotalRounds</td>
                            <td>@w.ParticipantCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- 实时日志 -->
<div class="card">
    <div class="card-header">
        <i class="bi bi-terminal me-1 text-accent"></i> 实时日志
        <small class="text-muted-custom ms-2">(最近 30 条)</small>
    </div>
    <div class="card-body p-0">
        <div class="log-container p-2">
            @foreach (var entry in recentLogs)
            {
                <div class="log-entry @(entry.IsError ? "log-error" : "")">
                    <span class="log-time">@entry.Time.ToString("HH:mm:ss.fff")</span>
                    <span class="log-source ms-1">[@entry.Source]</span>
                    <span class="ms-1">@entry.Message</span>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private SystemSnapshot snap = new();
    private List<LogEntry> recentLogs = new();

    [Inject] private NavigationManager Nav { get; set; } = default!;

    protected override void OnInitialized()
    {
        snap = Monitor.Current;
        recentLogs = LogStream.GetRecent(30);
        Monitor.OnStateChanged += OnStateChanged;
        LogStream.OnNewEntry += OnNewLog;
    }

    private void OnStateChanged()
    {
        snap = Monitor.Current;
        InvokeAsync(StateHasChanged);
    }

    private void OnNewLog(LogEntry entry)
    {
        recentLogs.Insert(0, entry);
        if (recentLogs.Count > 30)
            recentLogs.RemoveAt(recentLogs.Count - 1);
        InvokeAsync(StateHasChanged);
    }

    private void NavToWorker(int channelId)
    {
        Nav.NavigateTo($"/worker/{channelId}");
    }

    private static string FormatDuration(TimeSpan ts)
    {
        if (ts.TotalHours >= 1) return $"{ts.Hours}h {ts.Minutes}m";
        if (ts.TotalMinutes >= 1) return $"{ts.Minutes}m {ts.Seconds}s";
        return $"{ts.Seconds}s";
    }

    public void Dispose()
    {
        Monitor.OnStateChanged -= OnStateChanged;
        LogStream.OnNewEntry -= OnNewLog;
    }
}
