@page "/logs/tokens"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.WebUI.Services
@using AgentCoreProcessor.Database
@inject TokenStatsService StatsService

<div class="page-title">
    <i class="bi bi-bar-chart"></i> Token 统计
</div>

<div class="row g-2 mb-3">
    <div class="col-md-3">
        <select class="form-select form-select-sm" @bind="timeRange" @bind:after="RefreshAsync">
            <option value="today">今日</option>
            <option value="7d">近 7 天</option>
            <option value="30d">近 30 天</option>
            <option value="all">全部</option>
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn-ghost" @onclick="RefreshAsync">
            <i class="bi bi-arrow-clockwise"></i> 刷新
        </button>
    </div>
</div>

<!-- 缓存命中率概览 -->
@if (cacheStats != null)
{
<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card">
            <div class="card-body text-center">
                <div class="text-muted-custom" style="font-size:var(--font-size-sm);">总输入 Token</div>
                <div style="font-size:1.5rem; font-weight:600;">@FormatTokens(cacheStats.TotalInputTokens)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body text-center">
                <div class="text-muted-custom" style="font-size:var(--font-size-sm);">缓存命中</div>
                <div style="font-size:1.5rem; font-weight:600; color:var(--accent-color);">@FormatTokens(cacheStats.TotalCacheRead + cacheStats.TotalCacheHit)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body text-center">
                <div class="text-muted-custom" style="font-size:var(--font-size-sm);">缓存创建</div>
                <div style="font-size:1.5rem; font-weight:600;">@FormatTokens(cacheStats.TotalCacheCreation)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body text-center">
                <div class="text-muted-custom" style="font-size:var(--font-size-sm);">命中率</div>
                <div style="font-size:1.5rem; font-weight:600; color:var(--accent-color);">@cacheStats.HitRate.ToString("F1")%</div>
            </div>
        </div>
    </div>
</div>
}

<div class="row g-3">
    <!-- 按 Core -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-cpu me-1 text-accent"></i> 按 Core</div>
            <div class="card-body p-0">
                <table class="table-dark-custom">
                    <thead><tr><th>Core</th><th>调用</th><th>输入</th><th>输出</th><th>缓存命中</th></tr></thead>
                    <tbody>
                    @foreach (var s in byCore)
                    {
                        <tr>
                            <td>@s.CoreName</td>
                            <td>@s.CallCount</td>
                            <td>@FormatTokens(s.TotalInput)</td>
                            <td>@FormatTokens(s.TotalOutput)</td>
                            <td style="color:var(--accent-color);">@FormatTokens(s.TotalCacheRead + s.TotalCacheHit)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- 按模型 -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-robot me-1 text-accent"></i> 按模型</div>
            <div class="card-body p-0">
                <table class="table-dark-custom">
                    <thead><tr><th>模型</th><th>调用</th><th>输入</th><th>输出</th><th>缓存命中</th></tr></thead>
                    <tbody>
                    @foreach (var s in byModel)
                    {
                        <tr>
                            <td>@(s.Model ?? "unknown")</td>
                            <td>@s.CallCount</td>
                            <td>@FormatTokens(s.TotalInput)</td>
                            <td>@FormatTokens(s.TotalOutput)</td>
                            <td style="color:var(--accent-color);">@FormatTokens(s.TotalCacheRead + s.TotalCacheHit)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private string timeRange = "today";
    private List<CoreTokenSummary> byCore = new();
    private List<ModelTokenSummary> byModel = new();
    private CacheStats? cacheStats;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        var since = GetSince();
        byCore = await StatsService.GetByCoreAsync(since);
        byModel = await StatsService.GetByModelAsync(since);
        cacheStats = await StatsService.GetCacheStatsAsync(since);
    }

    private DateTime? GetSince() => timeRange switch
    {
        "today" => DateTime.Today,
        "7d" => DateTime.Now.AddDays(-7),
        "30d" => DateTime.Now.AddDays(-30),
        _ => null
    };

    private static string FormatTokens(long tokens)
    {
        if (tokens < 1000) return tokens.ToString();
        if (tokens < 1_000_000) return $"{tokens / 1000.0:F1}k";
        return $"{tokens / 1_000_000.0:F2}M";
    }
}
