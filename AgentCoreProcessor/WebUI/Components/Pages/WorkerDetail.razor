@page "/worker/{ChannelId:int}"
@page "/engine/channels/{ChannelId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.WebUI.Services
@using AgentCoreProcessor.Engine
@inject SystemMonitor Monitor
@inject MasterEngine Engine
@inject NavigationManager Nav
@implements IDisposable

<div class="d-flex align-items-center gap-2 mb-4">
    <a href="/engine/channels" class="btn-ghost" style="padding:0.3rem 0.6rem;">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div class="page-title" style="margin-bottom:0;">
        <i class="bi bi-diagram-3"></i> Worker #@ChannelId
    </div>
</div>

@if (worker == null)
{
    <div style="background:var(--status-warn-dim); color:var(--status-warn); padding:0.75rem 1rem; border-radius:var(--radius-md);">
        该频道无活跃 Worker
    </div>
}
else
{
    @if (worker.HasRecentError)
    {
        <div class="alert-bar mb-3" style="background:var(--status-warn-dim); border-left:3px solid var(--status-warn); color:var(--status-warn);">
            <i class="bi bi-exclamation-triangle"></i>
            <div>
                <div>API 错误 — 连续失败 @worker.ConsecutiveFailures 次，累计 @worker.TotalErrorCount 次</div>
                <div style="font-size:var(--font-size-sm); opacity:0.8; font-family:monospace; margin-top:0.2rem;">
                    @worker.LastErrorMessage
                    <span class="ms-2">(@FormatTimeAgo(worker.LastErrorTime!.Value))</span>
                </div>
            </div>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">基本信息</div>
                <div class="card-body">
                    <div class="detail-grid">
                        <span class="detail-label">频道 ID</span>
                        <span class="text-accent">#@worker.ChannelId</span>
                        <span class="detail-label">模式</span>
                        <span class="badge-status @(worker.IsWorkingMode ? "badge-working" : "badge-express")">
                            @(worker.IsWorkingMode ? "Working" : "Express")
                        </span>
                        <span class="detail-label">状态</span>
                        <span class="@(worker.IsBusy ? "text-error" : "text-muted-custom")">@(worker.IsBusy ? "处理中" : "等待")</span>
                        <span class="detail-label">会话中</span>
                        <span>@(worker.IsInWorkingSession ? "是" : "否")</span>
                        <span class="detail-label">外部触发</span>
                        <span>@worker.ConsecutiveExternalTriggers 次</span>
                        <span class="detail-label">上次完成</span>
                        <span>@(worker.LastCompletionTime?.ToString("HH:mm:ss") ?? "-")</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">冲动值</div>
                <div class="card-body">
                    <div class="detail-grid">
                        <span class="detail-label">当前值</span>
                        <span>@worker.Impulse.ToString("F1")</span>
                        <span class="detail-label">阈值</span>
                        <span>@worker.Threshold.ToString("F0")</span>
                        <span class="detail-label">频道亲和度</span>
                        <span>@worker.ChannelAffinity.ToString("F2")</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>记忆提取</span>
                    <div class="form-check form-switch" style="margin:0;">
                        <input class="form-check-input" type="checkbox" checked="@worker.AutoExtractionEnabled"
                               @onchange="ToggleAutoExtraction" />
                    </div>
                </div>
                <div class="card-body">
                    <div class="detail-grid">
                        <span class="detail-label">提取进度</span>
                        <span>
                            @worker.LastExtractedMessageId / @worker.TotalMessageCount
                            @if (worker.ExtractionRunning)
                            {
                                <span class="badge-status badge-working" style="margin-left:0.3rem;">处理中</span>
                            }
                        </span>
                        <span class="detail-label">活跃阈值</span>
                        <span>@worker.ActiveExtractionThreshold 条</span>
                        <span class="detail-label">潜水阈值</span>
                        <span>@worker.LurkingExtractionThreshold 条</span>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <button class="btn-accent" @onclick="TriggerExtraction" disabled="@extracting">
                            <i class="bi bi-journal-text me-1"></i>@(extracting ? "整理中..." : "立即整理")
                        </button>
                        @if (worker.ExtractionRunning)
                        {
                            <button class="btn-ghost" style="color:var(--status-error);" @onclick="StopExtraction">
                                <i class="bi bi-stop-circle me-1"></i>停止
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">循环状态</div>
                <div class="card-body">
                    <div class="detail-grid">
                        <span class="detail-label">总轮次</span>
                        <span>@worker.TotalRounds</span>
                        <span class="detail-label">静默轮次</span>
                        <span>@worker.SilentRounds</span>
                        <span class="detail-label">已授权工具</span>
                        <span>@worker.AuthorizedToolCount</span>
                        <span class="detail-label">参与者</span>
                        <span>@worker.ParticipantCount</span>
                        <span class="detail-label">已处理消息</span>
                        <span>@worker.ProcessedMessageCount</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">操作</div>
                <div class="card-body">
                    <div class="detail-grid">
                        <span class="detail-label">未回复消息</span>
                        <span>@worker.UnrespondedMessageCount</span>
                        <span class="detail-label">重要性</span>
                        <span>@worker.Importance</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int ChannelId { get; set; }

    private WorkerSnapshot? worker;
    private bool extracting = false;

    protected override void OnInitialized()
    {
        UpdateWorker();
        Monitor.OnStateChanged += OnStateChanged;
    }

    private void UpdateWorker()
    {
        worker = Monitor.Current.Workers.FirstOrDefault(w => w.ChannelId == ChannelId);
    }

    private void OnStateChanged()
    {
        UpdateWorker();
        InvokeAsync(StateHasChanged);
    }

    private async Task TriggerExtraction()
    {
        extracting = true;
        try
        {
            var spawnCheck = Engine.GetSpawnCheck<ChannelEngineSpawnCheck>();
            if (spawnCheck != null)
            {
                var channels = spawnCheck.GetActiveChannels();
                if (channels.TryGetValue(ChannelId, out var engine))
                    await engine.TriggerLurkingExtractionAsync();
            }
        }
        finally
        {
            extracting = false;
        }
    }

    private void ToggleAutoExtraction(ChangeEventArgs e)
    {
        var enabled = (bool)(e.Value ?? true);
        var spawnCheck = Engine.GetSpawnCheck<ChannelEngineSpawnCheck>();
        if (spawnCheck != null)
        {
            var channels = spawnCheck.GetActiveChannels();
            if (channels.TryGetValue(ChannelId, out var engine))
                engine.SetAutoExtraction(enabled);
        }
    }

    private void StopExtraction()
    {
        var spawnCheck = Engine.GetSpawnCheck<ChannelEngineSpawnCheck>();
        if (spawnCheck != null)
        {
            var channels = spawnCheck.GetActiveChannels();
            if (channels.TryGetValue(ChannelId, out var engine))
                engine.CancelExtraction();
        }
    }

    private static string FormatTimeAgo(DateTime time)
    {
        var elapsed = DateTime.Now - time;
        if (elapsed.TotalSeconds < 60) return $"{elapsed.TotalSeconds:F0}s 前";
        if (elapsed.TotalMinutes < 60) return $"{elapsed.TotalMinutes:F0}m 前";
        return $"{elapsed.TotalHours:F1}h 前";
    }

    public void Dispose()
    {
        Monitor.OnStateChanged -= OnStateChanged;
    }
}
