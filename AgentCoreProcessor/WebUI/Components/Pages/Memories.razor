@page "/memories"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Engine
@using AgentCoreProcessor.Database
@inject MasterEngine Engine

<div class="page-title">
    <i class="bi bi-database"></i> 记忆浏览器
</div>

<div class="tab-bar mb-3">
    <button class="tab-item @(tab == "main" ? "active" : "")" @onclick='() => SwitchTab("main")'>
        主记忆 <span class="tab-badge">@mainCount</span>
    </button>
    <button class="tab-item @(tab == "temp" ? "active" : "")" @onclick='() => SwitchTab("temp")'>
        临时记忆 <span class="tab-badge">@tempMemories.Count</span>
    </button>
</div>

<div class="row g-2 mb-3">
    <div class="col-md-3">
        <select class="form-select form-select-sm" @bind="selectedPersonId" @bind:after="Refresh">
            <option value="0">全部人物</option>
            @foreach (var p in persons)
            {
                <option value="@p.Id">@p.Id - @(string.IsNullOrEmpty(p.FastMemory) ? "(无备注)" : Truncate(p.FastMemory, 20))</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <div class="d-flex gap-1">
            <input type="text" class="form-control form-control-sm" placeholder="搜索记忆内容..." @bind="keyword" />
            <button class="btn-ghost" @onclick="Refresh">
                <i class="bi bi-search"></i>
            </button>
        </div>
    </div>
</div>

@if (tab == "main")
{
    <div class="card">
        <div class="card-body p-0">
            @if (mainMemories.Count == 0)
            {
                <div class="p-3 text-muted-custom" style="text-align:center;">无记忆条目</div>
            }
            else
            {
                <div style="max-height:calc(100vh - 300px); overflow-y:auto">
                    @foreach (var m in mainMemories)
                    {
                        <div class="msg-item">
                            <div class="d-flex justify-content-between">
                                <div class="d-flex gap-1 flex-wrap">
                                    @if (m.PersonId > 0)
                                    {
                                        <span class="badge-status badge-info">P:@m.PersonId</span>
                                    }
                                    @if (m.ChannelId > 0)
                                    {
                                        <span class="badge-status" style="background:var(--bg-elevated); color:var(--text-secondary);">Ch:@m.ChannelId</span>
                                    }
                                    <span class="badge-status @(m.Importance >= 0.7f ? "badge-working" : "")" style="@(m.Importance < 0.7f ? "background:var(--bg-elevated); color:var(--text-secondary);" : "")">
                                        重要度:@m.Importance.ToString("F1")
                                    </span>
                                    @if (m.Confidence == "low")
                                    {
                                        <span class="badge-status badge-working">低置信</span>
                                    }
                                </div>
                                <small class="text-muted-custom">@m.CreatedAt.ToString("MM-dd HH:mm")</small>
                            </div>
                            <div class="mt-1" style="color:var(--text-primary);">@m.Content</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            @if (tempMemories.Count == 0)
            {
                <div class="p-3 text-muted-custom" style="text-align:center;">无临时记忆</div>
            }
            else
            {
                <div style="max-height:calc(100vh - 300px); overflow-y:auto">
                    @foreach (var m in tempMemories)
                    {
                        <div class="msg-item">
                            <div class="d-flex justify-content-between">
                                <div class="d-flex gap-1">
                                    @if (m.PersonId > 0)
                                    {
                                        <span class="badge-status badge-info">P:@m.PersonId</span>
                                    }
                                    @if (m.ChannelId > 0)
                                    {
                                        <span class="badge-status" style="background:var(--bg-elevated); color:var(--text-secondary);">Ch:@m.ChannelId</span>
                                    }
                                </div>
                                <small class="text-muted-custom">@m.CreatedAt.ToString("MM-dd HH:mm")</small>
                            </div>
                            <div class="mt-1" style="color:var(--text-primary);">@m.Content</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private string tab = "main";
    private List<Person> persons = new();
    private List<MemoryEntry> mainMemories = new();
    private List<TempMemoryEntry> tempMemories = new();
    private int mainCount = 0;
    private int selectedPersonId = 0;
    private string keyword = "";

    protected override async Task OnInitializedAsync()
    {
        persons = await Engine.Session.GetAllPersonsAsync();
        mainCount = await Engine.Memories.GetCountAsync();
        await Refresh();
    }

    private async Task SwitchTab(string newTab)
    {
        tab = newTab;
        await Refresh();
    }

    private async Task Refresh()
    {
        if (tab == "main")
        {
            if (!string.IsNullOrWhiteSpace(keyword))
            {
                mainMemories = await Engine.Memories.SearchAsync(keyword.Trim(), 100);
            }
            else if (selectedPersonId > 0)
            {
                mainMemories = await Engine.Memories.GetByPersonAsync(selectedPersonId);
            }
            else
            {
                mainMemories = await Engine.Memories.GetRecentAsync(100);
            }
            mainCount = await Engine.Memories.GetCountAsync();
        }
        else
        {
            var all = await Engine.TempMemories.GetAllAsync();
            tempMemories = all;
            if (selectedPersonId > 0)
                tempMemories = tempMemories.Where(t => t.PersonId == selectedPersonId).ToList();
            if (!string.IsNullOrWhiteSpace(keyword))
                tempMemories = tempMemories.Where(t => t.Content.Contains(keyword, StringComparison.OrdinalIgnoreCase)).ToList();
        }
    }

    private static string Truncate(string s, int max) => s.Length <= max ? s : s[..max] + "...";
}
