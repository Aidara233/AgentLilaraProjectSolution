@page "/memories"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Engine
@using AgentCoreProcessor.Database
@inject MasterEngine Engine
@inject NavigationManager Nav

<div class="page-title">
    <i class="bi bi-database"></i> 记忆浏览器
</div>

<div class="tab-bar mb-3">
    <button class="tab-item @(tab == "main" ? "active" : "")" @onclick='() => SwitchTab("main")'>
        主记忆 <span class="tab-badge">@mainCount</span>
    </button>
    <button class="tab-item @(tab == "temp" ? "active" : "")" @onclick='() => SwitchTab("temp")'>
        临时记忆 <span class="tab-badge">@tempMemories.Count</span>
    </button>
</div>

<div class="row g-2 mb-3">
    <div class="col-md-3">
        <select class="form-select form-select-sm" @bind="selectedPersonId" @bind:after="Refresh">
            <option value="0">全部人物</option>
            @foreach (var p in persons)
            {
                <option value="@p.Id">@p.Id - @(string.IsNullOrEmpty(p.FastMemory) ? "(无备注)" : Truncate(p.FastMemory, 20))</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <div class="d-flex gap-1">
            <input type="text" class="form-control form-control-sm" placeholder="搜索记忆内容..." @bind="keyword" />
            <button class="btn-ghost" @onclick="Refresh">
                <i class="bi bi-search"></i>
            </button>
        </div>
    </div>
</div>

@if (tab == "main")
{
    <div class="card">
        <div class="card-body p-0">
            @if (mainMemories.Count == 0)
            {
                <div class="p-3 text-muted-custom" style="text-align:center;">无记忆条目</div>
            }
            else
            {
                <div style="max-height:calc(100vh - 300px); overflow-y:auto">
                    @foreach (var m in mainMemories)
                    {
                        <div class="msg-item @(flashMemoryId == m.Id ? "save-flash" : "")">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="d-flex gap-1 flex-wrap">
                                    @if (editingMemoryId == m.Id && editingField == "Type")
                                    {
                                        <select class="inline-edit-select" @bind="editType">
                                            <option value="knowledge">knowledge</option>
                                            <option value="fact">fact</option>
                                            <option value="feedback">feedback</option>
                                            <option value="inference">inference</option>
                                            <option value="event">event</option>
                                        </select>
                                        <span class="inline-edit-actions">
                                            <button class="save" @onclick="SaveMemoryEdit"><i class="bi bi-check"></i></button>
                                            <button class="cancel" @onclick="CancelEdit"><i class="bi bi-x"></i></button>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-editable badge-status badge-express"
                                              @onclick="@(() => StartEditMemory(m, FieldType))">@m.Type</span>
                                    }

                                    @if (editingMemoryId == m.Id && editingField == "Subject")
                                    {
                                        <input type="text" class="inline-edit-input" style="width:100px;"
                                               @bind="editSubject" placeholder="主题" />
                                        <span class="inline-edit-actions">
                                            <button class="save" @onclick="SaveMemoryEdit"><i class="bi bi-check"></i></button>
                                            <button class="cancel" @onclick="CancelEdit"><i class="bi bi-x"></i></button>
                                        </span>
                                    }
                                    else if (!string.IsNullOrEmpty(m.Subject))
                                    {
                                        <span class="inline-editable badge-status" style="background:var(--accent-color); color:#fff;"
                                              @onclick="@(() => StartEditMemory(m, FieldSubject))">@m.Subject</span>
                                    }
                                    else
                                    {
                                        <span class="inline-editable badge-status" style="background:var(--bg-elevated); color:var(--text-muted); font-style:italic;"
                                              @onclick="@(() => StartEditMemory(m, FieldSubject))">+主题</span>
                                    }

                                    @if (m.PersonId > 0)
                                    {
                                        <span class="badge-status badge-info">P:@m.PersonId</span>
                                    }
                                    @if (m.ChannelId > 0)
                                    {
                                        <span class="badge-status" style="background:var(--bg-elevated); color:var(--text-secondary);">Ch:@m.ChannelId</span>
                                    }

                                    @if (editingMemoryId == m.Id && editingField == "Importance")
                                    {
                                        <input type="number" step="0.1" min="0" max="1" class="inline-edit-input" style="width:60px;"
                                               @bind="editImportance" />
                                        <span class="inline-edit-actions">
                                            <button class="save" @onclick="SaveMemoryEdit"><i class="bi bi-check"></i></button>
                                            <button class="cancel" @onclick="CancelEdit"><i class="bi bi-x"></i></button>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-editable badge-status @(m.Importance >= 0.7f ? "badge-working" : "")"
                                              style="@(m.Importance < 0.7f ? "background:var(--bg-elevated); color:var(--text-secondary);" : "")"
                                              @onclick="@(() => StartEditMemory(m, FieldImportance))">
                                            重要度:@m.Importance.ToString("F1")
                                        </span>
                                    }

                                    @if (m.Confidence == "low")
                                    {
                                        <span class="badge-status badge-working">低置信</span>
                                    }
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <small class="text-muted-custom">@m.CreatedAt.ToString("MM-dd HH:mm")</small>
                                    <button class="btn-ghost" style="padding:0.15rem 0.4rem; font-size:0.7rem;"
                                            @onclick="() => GoToDetail(m.Id)" title="详情">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                    </button>
                                    <button class="btn-ghost" style="padding:0.15rem 0.4rem; font-size:0.7rem; color:var(--status-error);"
                                            @onclick="() => DeleteMemory(m)" title="删除">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            </div>
                            @if (editingMemoryId == m.Id && editingField == "Content")
                            {
                                <div class="mt-1">
                                    <textarea class="inline-edit-input" style="min-height:60px; resize:vertical;"
                                              @bind="editContent"></textarea>
                                    <span class="inline-edit-actions" style="margin-top:0.3rem;">
                                        <button class="save" @onclick="SaveMemoryEdit"><i class="bi bi-check"></i></button>
                                        <button class="cancel" @onclick="CancelEdit"><i class="bi bi-x"></i></button>
                                    </span>
                                </div>
                            }
                            else
                            {
                                <div class="mt-1 inline-editable" style="color:var(--text-primary); display:block;"
                                     @onclick="@(() => StartEditMemory(m, FieldContent))">@m.Content</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            @if (tempMemories.Count == 0)
            {
                <div class="p-3 text-muted-custom" style="text-align:center;">无临时记忆</div>
            }
            else
            {
                <div style="max-height:calc(100vh - 300px); overflow-y:auto">
                    @foreach (var m in tempMemories)
                    {
                        <div class="msg-item @(flashTempId == m.Id ? "save-flash" : "")">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="d-flex gap-1 flex-wrap">
                                    @if (m.PersonId != null)
                                    {
                                        <span class="badge-status badge-info">P:@m.PersonId</span>
                                    }
                                    @if (m.ChannelId != null)
                                    {
                                        <span class="badge-status" style="background:var(--bg-elevated); color:var(--text-secondary);">Ch:@m.ChannelId</span>
                                    }
                                    <span class="badge-status @(m.Confidence == "low" ? "badge-working" : "badge-express")">
                                        @m.Confidence
                                    </span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <small class="text-muted-custom">@m.CreatedAt.ToString("MM-dd HH:mm")</small>
                                    <button class="btn-ghost" style="padding:0.15rem 0.4rem; font-size:0.7rem; color:var(--status-error);"
                                            @onclick="() => DeleteTemp(m)" title="删除">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            </div>
                            @if (editingTempId == m.Id)
                            {
                                <div class="mt-1">
                                    <textarea class="inline-edit-input" style="min-height:60px; resize:vertical;"
                                              @bind="editContent"></textarea>
                                    <span class="inline-edit-actions" style="margin-top:0.3rem;">
                                        <button class="save" @onclick="SaveTempEdit"><i class="bi bi-check"></i></button>
                                        <button class="cancel" @onclick="CancelEdit"><i class="bi bi-x"></i></button>
                                    </span>
                                </div>
                            }
                            else
                            {
                                <div class="mt-1 inline-editable" style="color:var(--text-primary); display:block;"
                                     @onclick="() => StartEditTemp(m)">@m.Content</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private const string FieldType = "Type";
    private const string FieldSubject = "Subject";
    private const string FieldImportance = "Importance";
    private const string FieldContent = "Content";

    private string tab = "main";
    private List<Person> persons = new();
    private List<MemoryEntry> mainMemories = new();
    private List<TempMemoryEntry> tempMemories = new();
    private int mainCount = 0;
    private int selectedPersonId = 0;
    private string keyword = "";

    // 编辑状态
    private int editingMemoryId = 0;
    private int editingTempId = 0;
    private string editingField = "";
    private int flashMemoryId = 0;
    private int flashTempId = 0;

    // 编辑值
    private string editContent = "";
    private string editType = "";
    private string editSubject = "";
    private float editImportance;

    protected override async Task OnInitializedAsync()
    {
        persons = await Engine.Session.GetAllPersonsAsync();
        mainCount = await Engine.Memories.GetCountAsync();
        await Refresh();
    }

    private async Task SwitchTab(string newTab)
    {
        tab = newTab;
        CancelEdit();
        await Refresh();
    }

    private async Task Refresh()
    {
        if (tab == "main")
        {
            if (!string.IsNullOrWhiteSpace(keyword))
            {
                mainMemories = await Engine.Memories.SearchAsync(keyword.Trim(), 100);
            }
            else if (selectedPersonId > 0)
            {
                mainMemories = await Engine.Memories.GetByPersonAsync(selectedPersonId);
            }
            else
            {
                mainMemories = await Engine.Memories.GetRecentAsync(100);
            }
            mainCount = await Engine.Memories.GetCountAsync();
        }
        else
        {
            var all = await Engine.TempMemories.GetAllAsync();
            tempMemories = all.OrderByDescending(t => t.CreatedAt).ToList();
            if (selectedPersonId > 0)
                tempMemories = tempMemories.Where(t => t.PersonId == selectedPersonId).ToList();
            if (!string.IsNullOrWhiteSpace(keyword))
                tempMemories = tempMemories.Where(t => t.Content.Contains(keyword, StringComparison.OrdinalIgnoreCase)).ToList();
        }
    }

    private void StartEditMemory(MemoryEntry m, string field)
    {
        CancelEdit();
        editingMemoryId = m.Id;
        editingField = field;
        editContent = m.Content;
        editType = m.Type;
        editSubject = m.Subject ?? "";
        editImportance = m.Importance;
    }

    private void StartEditTemp(TempMemoryEntry m)
    {
        CancelEdit();
        editingTempId = m.Id;
        editContent = m.Content;
    }

    private async Task SaveMemoryEdit()
    {
        var memory = mainMemories.FirstOrDefault(m => m.Id == editingMemoryId);
        if (memory == null) return;

        switch (editingField)
        {
            case "Content": memory.Content = editContent; break;
            case "Type": memory.Type = editType; break;
            case "Subject": memory.Subject = string.IsNullOrWhiteSpace(editSubject) ? null : editSubject.Trim(); break;
            case "Importance": memory.Importance = editImportance; break;
        }

        await Engine.Memories.UpdateAsync(memory);
        flashMemoryId = memory.Id;
        editingMemoryId = 0;
        editingField = "";
        _ = ClearFlashAsync(() => flashMemoryId = 0);
    }

    private async Task SaveTempEdit()
    {
        var temp = tempMemories.FirstOrDefault(m => m.Id == editingTempId);
        if (temp == null) return;

        temp.Content = editContent;
        await Engine.TempMemories.UpdateAsync(temp);
        flashTempId = temp.Id;
        editingTempId = 0;
        _ = ClearFlashAsync(() => flashTempId = 0);
    }

    private async Task DeleteMemory(MemoryEntry m)
    {
        await Engine.Memories.DeleteAsync(m);
        mainMemories.Remove(m);
        mainCount--;
    }

    private async Task DeleteTemp(TempMemoryEntry m)
    {
        await Engine.TempMemories.DeleteAsync(m);
        tempMemories.Remove(m);
    }

    private void CancelEdit()
    {
        editingMemoryId = 0;
        editingTempId = 0;
        editingField = "";
    }

    private async Task ClearFlashAsync(Action clear)
    {
        await Task.Delay(600);
        clear();
        await InvokeAsync(StateHasChanged);
    }

    private static string Truncate(string s, int max) => s.Length <= max ? s : s[..max] + "...";

    private void GoToDetail(int id) => Nav.NavigateTo($"/memories/detail/{id}");
}
