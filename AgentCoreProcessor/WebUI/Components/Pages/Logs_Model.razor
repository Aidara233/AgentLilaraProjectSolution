@page "/logs/model"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.WebUI.Services
@inject ModelLogService LogService

<div class="page-title">
    <i class="bi bi-file-earmark-code"></i> 模型调用日志
</div>

<div class="row g-2 mb-3">
    <div class="col-md-3">
        <select class="form-select form-select-sm" @bind="coreFilter" @bind:after="Refresh">
            <option value="">全部 Core</option>
            @foreach (var name in coreNames)
            {
                <option value="@name">@name</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <select class="form-select form-select-sm" @bind="callerFilter" @bind:after="Refresh">
            <option value="">全部来源</option>
            @foreach (var c in callerNames)
            {
                <option value="@c">@c</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn-ghost" @onclick="Refresh">
            <i class="bi bi-arrow-clockwise"></i> 刷新
        </button>
    </div>
</div>

<div class="row g-3">
    <!-- 文件列表 -->
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <span><i class="bi bi-list-ul me-1 text-accent"></i> 日志文件</span>
                <span class="text-muted-custom" style="font-size:var(--font-size-sm); float:right;">@entries.Count 条</span>
            </div>
            <div class="card-body p-0" style="max-height:calc(100vh - 240px); overflow-y:auto;">
                @foreach (var e in entries)
                {
                    <div class="msg-item @(e.FileName == selectedFile ? "active" : "")"
                         style="cursor:pointer; @(e.FileName == selectedFile ? "background:var(--bg-elevated);" : "")"
                         @onclick="() => SelectFile(e.FileName)">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge-status badge-express">@e.CoreName</span>
                            <span>
                                @if (!string.IsNullOrEmpty(e.Caller))
                                {
                                    <small class="text-accent me-2">@e.Caller</small>
                                }
                                @if (e.InputTokens > 0)
                                {
                                    <small class="text-muted-custom">@e.InputTokens+@e.OutputTokens t</small>
                                }
                                else
                                {
                                    <small class="text-muted-custom">@FormatSize(e.FileSize)</small>
                                }
                            </span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted-custom">@e.Timestamp.ToString("MM-dd HH:mm:ss")</small>
                            @if (e.CacheReadTokens > 0)
                            {
                                <small style="color:var(--accent-color);">cache:@e.CacheReadTokens</small>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- 内容详情 -->
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-file-text me-1 text-accent"></i>
                @(string.IsNullOrEmpty(selectedFile) ? "选择一个日志文件" : selectedFile)
            </div>
            <div class="card-body p-0" style="max-height:calc(100vh - 240px); overflow-y:auto;">
                @if (string.IsNullOrEmpty(selectedFile))
                {
                    <div class="p-3 text-muted-custom" style="text-align:center;">点击左侧文件查看内容</div>
                }
                else if (detail != null)
                {
                    <!-- 结构化渲染 -->
                    <div style="padding:0.8rem;">
                        <!-- 元信息 -->
                        <div class="d-flex flex-wrap gap-2 mb-3" style="font-size:var(--font-size-sm);">
                            <span class="badge-status badge-express">@detail.CoreName</span>
                            @if (!string.IsNullOrEmpty(detail.Model))
                            {
                                <span class="badge-status badge-info">@detail.Model</span>
                            }
                            @if (!string.IsNullOrEmpty(detail.Provider))
                            {
                                <span class="badge-status" style="background:var(--bg-elevated); color:var(--text-secondary);">@detail.Provider</span>
                            }
                            @if (!string.IsNullOrEmpty(detail.Caller))
                            {
                                <span class="badge-status" style="background:var(--bg-elevated); color:var(--accent-color);">@detail.Caller</span>
                            }
                            @if (!string.IsNullOrEmpty(detail.Timestamp))
                            {
                                <span class="text-muted-custom">@detail.Timestamp</span>
                            }
                            @if (!string.IsNullOrEmpty(detail.SystemPromptHash))
                            {
                                <span class="text-muted-custom" title="System Prompt Hash">sys:@detail.SystemPromptHash</span>
                            }
                        </div>

                        <!-- Tools -->
                        @if (detail.Tools != null && detail.Tools.Count > 0)
                        {
                            <div class="mb-3 d-flex flex-wrap gap-1">
                                <span style="font-size:var(--font-size-sm); color:var(--text-muted); margin-right:0.3rem;">Tools:</span>
                                @foreach (var tool in detail.Tools)
                                {
                                    <span class="badge-status" style="background:var(--bg-tertiary); color:var(--text-secondary); font-size:0.7rem;">@tool</span>
                                }
                            </div>
                        }

                        <!-- Usage -->
                        @if (detail.Usage != null)
                        {
                            <div class="mb-3" style="padding:0.5rem 0.8rem; background:var(--bg-tertiary); border-radius:var(--radius-sm); font-size:var(--font-size-sm);">
                                <span style="color:var(--text-muted);">Token:</span>
                                <span style="color:var(--text-primary); margin-left:0.3rem;">@detail.Usage.InputTokens in / @detail.Usage.OutputTokens out</span>
                                @if (detail.Usage.CacheReadTokens > 0 || detail.Usage.CacheHitTokens > 0)
                                {
                                    <span style="color:var(--accent-color); margin-left:0.8rem;">cache read: @(detail.Usage.CacheReadTokens + detail.Usage.CacheHitTokens)</span>
                                }
                                @if (detail.Usage.CacheCreationTokens > 0)
                                {
                                    <span style="color:var(--text-muted); margin-left:0.8rem;">cache create: @detail.Usage.CacheCreationTokens</span>
                                }
                            </div>
                        }

                        <!-- Messages -->
                        @if (detail.Messages.Count > 0)
                        {
                            <div class="mb-3">
                                <div style="font-size:var(--font-size-sm); color:var(--text-muted); margin-bottom:0.3rem; font-weight:600;">Messages (@detail.Messages.Count)</div>
                                @foreach (var msg in detail.Messages)
                                {
                                    <div style="margin-bottom:0.5rem; border-left:2px solid @(msg.Role == "assistant" ? "var(--accent-color)" : "var(--border)"); padding-left:0.6rem;">
                                        <div style="font-size:0.7rem; color:@(msg.Role == "assistant" ? "var(--accent-color)" : "var(--text-muted)"); margin-bottom:0.15rem;">@msg.Role</div>
                                        <pre style="margin:0; font-size:var(--font-size-sm); white-space:pre-wrap; word-break:break-all; color:var(--text-primary); background:transparent;">@msg.Content</pre>
                                    </div>
                                }
                            </div>
                        }

                        <!-- Thinking -->
                        @if (!string.IsNullOrEmpty(detail.Thinking))
                        {
                            <div class="mb-3">
                                <div style="font-size:var(--font-size-sm); color:var(--text-muted); margin-bottom:0.3rem; font-weight:600;">Thinking</div>
                                <pre style="margin:0; padding:0.5rem; font-size:var(--font-size-sm); white-space:pre-wrap; word-break:break-all; color:var(--text-secondary); background:var(--bg-tertiary); border-radius:var(--radius-sm);">@detail.Thinking</pre>
                            </div>
                        }

                        <!-- Output -->
                        @if (!string.IsNullOrEmpty(detail.Output))
                        {
                            <div class="mb-3">
                                <div style="font-size:var(--font-size-sm); color:var(--text-muted); margin-bottom:0.3rem; font-weight:600;">Output</div>
                                <pre style="margin:0; padding:0.5rem; font-size:var(--font-size-sm); white-space:pre-wrap; word-break:break-all; color:var(--text-primary); background:var(--bg-tertiary); border-radius:var(--radius-sm);">@detail.Output</pre>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <!-- 旧格式 .log 或解析失败，原样显示 -->
                    <pre style="margin:0; padding:1rem; font-size:var(--font-size-sm); white-space:pre-wrap; word-break:break-all; color:var(--text-primary); background:transparent;">@content</pre>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<ModelLogEntry> entries = new();
    private List<string> coreNames = new();
    private List<string> callerNames = new();
    private string coreFilter = "";
    private string callerFilter = "";
    private string selectedFile = "";
    private string content = "";
    private ModelLogDetail? detail;

    protected override void OnInitialized()
    {
        coreNames = LogService.GetCoreNames();
        callerNames = LogService.GetCallers();
        Refresh();
    }

    private void Refresh()
    {
        entries = LogService.ListRecent(100,
            string.IsNullOrEmpty(coreFilter) ? null : coreFilter,
            string.IsNullOrEmpty(callerFilter) ? null : callerFilter);
        if (!string.IsNullOrEmpty(selectedFile) && !entries.Any(e => e.FileName == selectedFile))
        {
            selectedFile = "";
            content = "";
            detail = null;
        }
    }

    private void SelectFile(string fileName)
    {
        selectedFile = fileName;
        detail = LogService.ReadStructured(fileName);
        if (detail == null)
            content = LogService.ReadContent(fileName) ?? "无法读取文件";
        else
            content = "";
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes}B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1}KB";
        return $"{bytes / (1024.0 * 1024):F1}MB";
    }
}
