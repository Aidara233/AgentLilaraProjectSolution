@page "/mcp"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Engine
@using AgentCoreProcessor.MCP
@inject MasterEngine Engine

<h4 class="mb-3">MCP 插件管理</h4>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        @if (manager != null)
        {
            <span class="badge bg-info me-2">@manager.Connections.Count 个 Server</span>
            <span class="badge bg-secondary">@totalTools 个工具</span>
        }
        else
        {
            <span class="text-muted">MCP 管理器未初始化</span>
        }
    </div>
    <button class="btn btn-outline-primary btn-sm" @onclick="ReloadMcp" disabled="@(manager == null || isReloading)">
        <i class="bi bi-arrow-clockwise me-1"></i>
        @(isReloading ? "重载中..." : "重载配置")
    </button>
</div>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert @statusClass alert-dismissible py-2 small">
        @statusMessage
        <button type="button" class="btn-close btn-close-sm" @onclick='() => statusMessage = ""'></button>
    </div>
}

@if (manager == null || manager.Connections.Count == 0)
{
    <div class="card">
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-plug fs-1 d-block mb-2"></i>
            <p>暂无 MCP Server 连接</p>
            <small>编辑 Storage/MCP/McpServers.json 添加 Server 配置，然后点击"重载配置"</small>
        </div>
    </div>
}
else
{
    @foreach (var conn in manager.Connections)
    {
        <div class="card mb-3">
            <div class="card-header py-2 d-flex justify-content-between align-items-center">
                <div>
                    <i class="bi bi-plug me-1"></i>
                    <span class="fw-semibold">@conn.ServerName</span>
                    <small class="text-muted ms-2">(@conn.ServerId)</small>
                </div>
                <div>
                    @if (conn.IsConnected)
                    {
                        <span class="badge bg-success">已连接</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">未连接</span>
                    }
                    <span class="badge bg-secondary ms-1">@conn.Tools.Count 个工具</span>
                </div>
            </div>

            @if (conn.Tools.Count > 0)
            {
                <div class="card-body p-0">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>工具名</th>
                                <th>描述</th>
                                <th>权限</th>
                                <th>参数</th>
                                <th>ContinueLoop</th>
                                <th>RetainResult</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tool in conn.Tools)
                            {
                                <tr>
                                    <td class="fw-semibold text-nowrap">@tool.Name</td>
                                    <td class="small">@Truncate(tool.Description, 60)</td>
                                    <td>
                                        <span class="badge @PermBadge(tool.RequiredPermission)">
                                            @tool.RequiredPermission
                                        </span>
                                    </td>
                                    <td class="small text-muted">@tool.Parameters.Count</td>
                                    <td>@BoolIcon(tool.ContinueLoop)</td>
                                    <td>@BoolIcon(tool.RetainResult)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
}

@code {
    private McpServerManager? manager;
    private int totalTools;
    private bool isReloading;
    private string? statusMessage;
    private string statusClass = "alert-info";

    protected override void OnInitialized()
    {
        manager = Engine.McpManager;
        RefreshCounts();
    }

    private void RefreshCounts()
    {
        totalTools = manager?.Connections.Sum(c => c.Tools.Count) ?? 0;
    }

    private async Task ReloadMcp()
    {
        if (manager == null) return;
        isReloading = true;
        statusMessage = null;
        StateHasChanged();

        try
        {
            await manager.ReloadAsync();
            RefreshCounts();
            statusMessage = $"重载成功：{manager.Connections.Count} 个 Server，{totalTools} 个工具";
            statusClass = "alert-success";
        }
        catch (Exception ex)
        {
            statusMessage = $"重载失败：{ex.Message}";
            statusClass = "alert-danger";
        }
        finally
        {
            isReloading = false;
        }
    }

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..max] + "...";

    private static string PermBadge(Database.PermissionLevel level) => level switch
    {
        Database.PermissionLevel.Admin => "bg-danger",
        Database.PermissionLevel.Elevated => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private static MarkupString BoolIcon(bool v) =>
        new(v ? "<i class=\"bi bi-check-circle text-success\"></i>" : "<i class=\"bi bi-dash text-muted\"></i>");
}
