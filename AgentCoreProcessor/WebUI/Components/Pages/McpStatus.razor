@page "/mcp"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Engine
@using AgentCoreProcessor.MCP
@inject MasterEngine Engine

<div class="page-title">
    <i class="bi bi-plug"></i> MCP 插件管理
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        @if (manager != null)
        {
            <span class="badge-status badge-info me-2">@manager.Connections.Count 个 Server</span>
            <span class="badge-status">@totalTools 个工具</span>
        }
        else
        {
            <span class="text-muted-custom">MCP 管理器未初始化</span>
        }
    </div>
    <button class="btn-ghost" @onclick="ReloadMcp" disabled="@(manager == null || isReloading)">
        <i class="bi bi-arrow-clockwise me-1"></i>
        @(isReloading ? "重载中..." : "重载配置")
    </button>
</div>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div style="background:@statusBg; color:@statusColor; padding:0.6rem 1rem; border-radius:var(--radius-md); margin-bottom:1rem; display:flex; align-items:center; justify-content:space-between; font-size:var(--font-size-sm);">
        <span>@statusMessage</span>
        <button class="btn-ghost" style="padding:0.2rem 0.5rem;" @onclick='() => statusMessage = ""'>
            <i class="bi bi-x"></i>
        </button>
    </div>
}

@if (manager == null || manager.Connections.Count == 0)
{
    <div class="page-placeholder">
        <i class="bi bi-plug"></i>
        <span>暂无 MCP Server 连接</span>
        <small class="text-muted-custom" style="margin-top:0.5rem;">编辑 Storage/MCP/McpServers.json 添加 Server 配置，然后点击"重载配置"</small>
    </div>
}
else
{
    @foreach (var conn in manager.Connections)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <i class="bi bi-plug me-1 text-accent"></i>
                    <span>@conn.ServerName</span>
                    <small class="text-muted-custom ms-2">(@conn.ServerId)</small>
                </div>
                <div class="d-flex gap-1">
                    @if (conn.IsConnected)
                    {
                        <span class="badge-status badge-express">已连接</span>
                    }
                    else
                    {
                        <span class="badge-status badge-working">未连接</span>
                    }
                    <span class="badge-status">@conn.Tools.Count 个工具</span>
                </div>
            </div>

            @if (conn.Tools.Count > 0)
            {
                <div class="card-body p-0">
                    <table class="table-dark-custom">
                        <thead>
                            <tr>
                                <th>工具名</th>
                                <th>描述</th>
                                <th>权限</th>
                                <th>参数</th>
                                <th>ContinueLoop</th>
                                <th>RetainResult</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tool in conn.Tools)
                            {
                                <tr>
                                    <td style="font-weight:600; white-space:nowrap;">@tool.Name</td>
                                    <td style="font-size:var(--font-size-sm);">@Truncate(tool.Description, 60)</td>
                                    <td>
                                        <span class="badge-status @PermBadge(tool.RequiredPermission)">
                                            @tool.RequiredPermission
                                        </span>
                                    </td>
                                    <td class="text-muted-custom">@tool.Parameters.Count</td>
                                    <td>@BoolIcon(tool.ContinueLoop)</td>
                                    <td>@BoolIcon(tool.RetainResult)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
}

@code {
    private McpServerManager? manager;
    private int totalTools;
    private bool isReloading;
    private string? statusMessage;
    private string statusBg = "var(--status-info-dim)";
    private string statusColor = "var(--status-info)";

    protected override void OnInitialized()
    {
        manager = Engine.McpManager;
        RefreshCounts();
    }

    private void RefreshCounts()
    {
        totalTools = manager?.Connections.Sum(c => c.Tools.Count) ?? 0;
    }

    private async Task ReloadMcp()
    {
        if (manager == null) return;
        isReloading = true;
        statusMessage = null;
        StateHasChanged();

        try
        {
            await manager.ReloadAsync();
            RefreshCounts();
            statusMessage = $"重载成功：{manager.Connections.Count} 个 Server，{totalTools} 个工具";
            statusBg = "var(--status-ok-dim)";
            statusColor = "var(--status-ok)";
        }
        catch (Exception ex)
        {
            statusMessage = $"重载失败：{ex.Message}";
            statusBg = "var(--status-error-dim)";
            statusColor = "var(--status-error)";
        }
        finally
        {
            isReloading = false;
        }
    }

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..max] + "...";

    private static string PermBadge(Database.PermissionLevel level) => level switch
    {
        Database.PermissionLevel.Admin => "badge-working",
        Database.PermissionLevel.Elevated => "badge-info",
        _ => ""
    };

    private static MarkupString BoolIcon(bool v) =>
        new(v ? "<i class=\"bi bi-check-circle text-ok\"></i>" : "<i class=\"bi bi-dash text-muted-custom\"></i>");
}
