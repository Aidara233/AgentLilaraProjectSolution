@page "/engine/system"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.WebUI.Services
@inject SystemMonitor Monitor
@implements IDisposable

<div class="page-title">
    <i class="bi bi-arrow-repeat"></i> 系统循环 — 概览
</div>

@if (sys == null || !sys.IsAlive)
{
    <div class="alert-bar alert-error mb-3">
        <i class="bi bi-x-circle"></i>
        <span>SystemEngine 未运行@(sys?.RestartCount > 0 ? $" (已重启 {sys.RestartCount} 次)" : "")</span>
    </div>
    @if (sys?.LastErrorMessage != null)
    {
        <div class="alert-bar alert-error mb-3" style="border-left-color:var(--status-warn);">
            <i class="bi bi-exclamation-triangle"></i>
            <span style="font-family:monospace; font-size:var(--font-size-sm);">@sys.LastErrorMessage</span>
        </div>
    }
}
else
{
    <!-- 错误警告 -->
    @if (sys.HasRecentError)
    {
        <div class="alert-bar mb-3" style="background:var(--status-warn-dim); border-left:3px solid var(--status-warn); color:var(--status-warn);">
            <i class="bi bi-exclamation-triangle"></i>
            <div>
                <div>API 错误 — 连续失败 @sys.ConsecutiveFailures 次，累计 @sys.TotalErrorCount 次</div>
                <div style="font-size:var(--font-size-sm); opacity:0.8; font-family:monospace; margin-top:0.2rem;">
                    @sys.LastErrorMessage
                    <span class="ms-2">(@FormatTimeAgo(sys.LastErrorTime!.Value))</span>
                </div>
            </div>
        </div>
    }
    <!-- 状态卡片 -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <StatCard Label="状态" Value="运行中" ValueClass="ok" />
        </div>
        <div class="col-md-3">
            <a href="/engine/system/tasks" style="text-decoration:none; color:inherit;">
                <StatCard Label="任务队列" Value="@sys.TaskQueueDepth.ToString()"
                          ValueClass="@(sys.TaskQueueDepth > 0 ? "accent" : "")" />
            </a>
        </div>
        <div class="col-md-3">
            <a href="/engine/system/agents" style="text-decoration:none; color:inherit;">
                <StatCard Label="活跃子agent" Value="@sys.ActiveSubAgentCount.ToString()"
                          ValueClass="@(sys.ActiveSubAgentCount > 0 ? "accent" : "")" />
            </a>
        </div>
        <div class="col-md-3">
            <StatCard Label="上下文轮次" Value="@sys.ContextRoundCount.ToString()"
                      ValueClass="@(sys.HasContextSummary ? "accent" : "")" />
        </div>
    </div>

    <!-- 睡觉请求警告 -->
    @if (sys.HasPendingSleepRequest)
    {
        <div class="alert-bar alert-error mb-4" style="border-left-color:var(--status-warn); color:var(--status-warn);">
            <i class="bi bi-moon"></i>
            <span>睡觉请求待审批 — 评分 @(sys.SleepScore?.ToString("F1"))</span>
            <a href="/engine/system/sleep" class="btn-ghost ms-auto" style="padding:0.2rem 0.6rem; font-size:0.75rem;">查看</a>
        </div>
    }

    <div class="row g-4">
        <!-- 便签板 -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-pin-angle me-1 text-accent"></i> 便签板
                </div>
                <div class="card-body">
                    @if (sys.PinboardEntries.Count == 0)
                    {
                        <span class="text-muted-custom">空</span>
                    }
                    else
                    {
                        <div class="pinboard-list">
                            @foreach (var (label, content) in sys.PinboardEntries)
                            {
                                <div class="pinboard-item">
                                    <span class="pinboard-label">@label</span>
                                    <span class="pinboard-content">@content</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- 思考笔记 -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-journal-text me-1 text-accent"></i> 思考笔记
                </div>
                <div class="card-body">
                    @if (sys.ThinkingNotes.Count == 0)
                    {
                        <span class="text-muted-custom">空</span>
                    }
                    else
                    {
                        <div class="pinboard-list">
                            @foreach (var (key, value) in sys.ThinkingNotes)
                            {
                                <div class="pinboard-item">
                                    <span class="pinboard-label">@key</span>
                                    <span class="pinboard-content">@value</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- 快捷入口 -->
    <div class="row g-3 mt-3">
        <div class="col-md-4">
            <a href="/engine/system/tasks" class="card quick-link-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="bi bi-list-task text-accent" style="font-size:1.5rem;"></i>
                    <div>
                        <div style="font-weight:600;">任务队列</div>
                        <div class="text-muted-custom" style="font-size:var(--font-size-sm);">查看待处理任务和睡觉请求</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/engine/system/agents" class="card quick-link-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="bi bi-people text-accent" style="font-size:1.5rem;"></i>
                    <div>
                        <div style="font-weight:600;">子agent</div>
                        <div class="text-muted-custom" style="font-size:var(--font-size-sm);">管理活跃会话</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/engine/system/sleep" class="card quick-link-card">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="bi bi-moon-stars text-accent" style="font-size:1.5rem;"></i>
                    <div>
                        <div style="font-weight:600;">睡觉请求</div>
                        <div class="text-muted-custom" style="font-size:var(--font-size-sm);">评分因子和审批</div>
                    </div>
                </div>
            </a>
        </div>
    </div>
}

@code {
    private SystemEngineSnapshot? sys;

    protected override void OnInitialized()
    {
        sys = Monitor.Current.SystemEngine;
        Monitor.OnStateChanged += OnStateChanged;
    }

    private void OnStateChanged()
    {
        sys = Monitor.Current.SystemEngine;
        InvokeAsync(StateHasChanged);
    }

    private static string FormatTimeAgo(DateTime time)
    {
        var elapsed = DateTime.Now - time;
        if (elapsed.TotalSeconds < 60) return $"{elapsed.TotalSeconds:F0}s 前";
        if (elapsed.TotalMinutes < 60) return $"{elapsed.TotalMinutes:F0}m 前";
        return $"{elapsed.TotalHours:F1}h 前";
    }

    public void Dispose() => Monitor.OnStateChanged -= OnStateChanged;
}
