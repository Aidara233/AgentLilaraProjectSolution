@page "/config/tools"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Tool

<div class="page-title">
    <i class="bi bi-tools"></i> 工具管理
</div>

<div class="card">
    <div class="card-header">
        <span><i class="bi bi-list-check me-1 text-accent"></i> 已注册工具</span>
        <span class="text-muted-custom" style="font-size:var(--font-size-sm); float:right;">@tools.Count 个</span>
    </div>
    <div class="card-body p-0">
        <table class="table-dark-custom">
            <thead><tr><th>工具名</th><th>描述</th><th>权限</th><th>状态</th><th>操作</th></tr></thead>
            <tbody>
            @foreach (var tool in tools)
            {
                var isDisabled = ToolRegistry.IsDisabled(tool.Name);
                var reason = ToolRegistry.GetDisableReason(tool.Name);
                <tr style="@(isDisabled ? "opacity:0.6;" : "")">
                    <td><strong>@tool.Name</strong></td>
                    <td style="font-size:var(--font-size-sm); max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@tool.Description</td>
                    <td>
                        @if (tool.GetPermission() > AgentCoreProcessor.Tool.Contract.ToolPermission.Default)
                        {
                            <span class="badge-status badge-working">@tool.GetPermission()</span>
                        }
                        else
                        {
                            <span class="text-muted-custom">默认</span>
                        }
                    </td>
                    <td>
                        @if (isDisabled)
                        {
                            <span style="color:var(--danger-color);">已禁用: @reason</span>
                        }
                        else
                        {
                            <span style="color:var(--success-color);">启用</span>
                        }
                    </td>
                    <td>
                        @if (isDisabled)
                        {
                            <button class="btn-ghost" style="font-size:var(--font-size-sm);" @onclick="() => Enable(tool.Name)">
                                <i class="bi bi-check-circle"></i> 启用
                            </button>
                        }
                        else
                        {
                            <button class="btn-ghost" style="font-size:var(--font-size-sm); color:var(--danger-color);" @onclick="() => ShowDisableDialog(tool.Name)">
                                <i class="bi bi-x-circle"></i> 禁用
                            </button>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (showDialog)
{
<div style="position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:1000; display:flex; align-items:center; justify-content:center;" @onclick="CloseDialog">
    <div class="card" style="width:400px; max-width:90vw;" @onclick:stopPropagation="true">
        <div class="card-header">禁用工具: @dialogToolName</div>
        <div class="card-body">
            <label style="font-size:var(--font-size-sm); color:var(--text-secondary);">禁用原因</label>
            <input type="text" class="form-control form-control-sm" @bind="disableReason" placeholder="例如：服务维护中" />
        </div>
        <div class="card-body" style="border-top:1px solid var(--border-color); display:flex; gap:0.5rem; justify-content:flex-end;">
            <button class="btn-ghost" @onclick="CloseDialog">取消</button>
            <button class="btn-ghost" style="color:var(--danger-color);" @onclick="ConfirmDisable">确认禁用</button>
        </div>
    </div>
</div>
}

@code {
    private List<ITool> tools = new();
    private bool showDialog = false;
    private string dialogToolName = "";
    private string disableReason = "";

    protected override void OnInitialized()
    {
        tools = ToolRegistry.All.Values.OrderBy(t => t.Name).ToList();
    }

    private void ShowDisableDialog(string toolName)
    {
        dialogToolName = toolName;
        disableReason = "";
        showDialog = true;
    }

    private void CloseDialog() => showDialog = false;

    private void ConfirmDisable()
    {
        if (string.IsNullOrWhiteSpace(disableReason))
            disableReason = "管理员手动禁用";
        ToolRegistry.DisableTool(dialogToolName, disableReason);
        showDialog = false;
        StateHasChanged();
    }

    private void Enable(string toolName)
    {
        ToolRegistry.EnableTool(toolName);
        StateHasChanged();
    }
}
