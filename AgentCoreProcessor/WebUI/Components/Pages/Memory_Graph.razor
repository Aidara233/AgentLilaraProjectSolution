@page "/memory/graph"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Engine
@using AgentCoreProcessor.Database
@using Microsoft.JSInterop
@inject MasterEngine Engine
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

<div class="page-title">
    <i class="bi bi-diagram-3"></i> 记忆关联图谱
</div>

@if (_view == GraphView.clusters)
{
    @* ======== 簇列表层 ======== *@
    <div class="d-flex gap-3 align-items-center mb-3 flex-wrap">
        <div class="d-flex gap-1 align-items-center">
            <label class="text-muted-custom" style="font-size:0.8rem; white-space:nowrap;">最低节点数:</label>
            <input type="range" min="1" max="50" @bind="_minNodes" @bind:after="RebuildClusters" style="width:120px;" />
            <span class="text-muted-custom" style="font-size:0.8rem; min-width:2rem;">@_minNodes</span>
        </div>
        <span class="text-muted-custom" style="font-size:0.8rem;">
            显示 @_filteredClusters.Count / @_allClusters.Count 个簇 |
            总节点 @_filteredClusters.Sum(c => c.NodeCount) |
            碎屑桶 @_scrapNodes 个节点
        </span>
    </div>

    <div class="cluster-grid">
        @foreach (var cluster in _filteredClusters)
        {
            <div class="cluster-card" @onclick="() => OpenCluster(cluster)">
                <div class="cluster-card-header">
                    <span class="cluster-core-label" title="@cluster.CoreContent">
                        @(cluster.CoreContent.Length > 60 ? cluster.CoreContent[..60] + "…" : cluster.CoreContent)
                    </span>
                </div>
                <div class="cluster-card-body">
                    <div class="cluster-stat">
                        <i class="bi bi-diagram-2"></i> @cluster.NodeCount 节点
                    </div>
                    <div class="cluster-stat">
                        <i class="bi bi-arrow-left-right"></i> @cluster.EdgeCount 关联
                    </div>
                    <div class="cluster-types">
                        @foreach (var (type, count) in cluster.TypeCounts.OrderByDescending(t => t.Value).Take(4))
                        {
                            <span class="badge-type" style="background:@GetTypeColor(type)">@type @count</span>
                        }
                    </div>
                </div>
            </div>
        }
        @if (_scrapNodes > 0)
        {
            <div class="cluster-card cluster-scrap" @onclick="OpenScrapBucket">
                <div class="cluster-card-header">
                    <span class="cluster-core-label" style="color:var(--text-secondary);">
                        <i class="bi bi-recycle me-1"></i>碎屑桶
                    </span>
                </div>
                <div class="cluster-card-body">
                    <div class="cluster-stat"><i class="bi bi-diagram-2"></i> @_scrapNodes 节点</div>
                    <div class="cluster-stat"><i class="bi bi-arrow-left-right"></i> @_scrapEdges 关联</div>
                    <div class="cluster-types">
                        @foreach (var (type, count) in _scrapTypeCounts.OrderByDescending(t => t.Value).Take(4))
                        {
                            <span class="badge-type" style="background:@GetTypeColor(type)">@type @count</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    @* ======== 簇内图谱层 ======== *@
    <div class="d-flex gap-2 mb-3 align-items-center flex-wrap">
        <button class="btn-ghost" @onclick="BackToClusters">
            <i class="bi bi-arrow-left me-1"></i>返回簇列表
        </button>
        <span class="text-muted-custom" style="font-size:0.9rem;">
            <strong>@_currentClusterName</strong> — 可见 <strong>@_visibleNodeCount</strong> / @_currentCluster.NodeCount 节点
        </span>
        @if (_totalNodeCount > 20)
        {
            <div class="d-flex gap-1 align-items-center ms-2">
                <label class="text-muted-custom" style="font-size:0.75rem; white-space:nowrap;">显示:</label>
                <input type="range" min="10" max="200" step="10" @bind="_maxVisible"
                       @bind:after="RefilterGraph" style="width:100px;" />
                <span class="text-muted-custom" style="font-size:0.75rem;">@_maxVisible</span>
            </div>
        }
        <div class="ms-auto d-flex gap-2 align-items-center">
            <input type="text" class="form-control form-control-sm" style="width:200px;" placeholder="搜索节点..."
                   @bind="_searchText" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
            <button class="btn-ghost btn-sm" @onclick="ResetGraphView" title="重置视图">
                <i class="bi bi-arrows-fullscreen"></i>
            </button>
        </div>
    </div>

    <div class="d-flex" style="height:calc(100vh - 200px);">
        @* 图区域 *@
        <div style="flex:1; min-width:0; position:relative;">
            <div id="graph-loading" style="display:none; position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); z-index:10; text-align:center;">
                <div class="spinner-border text-accent mb-2" role="status"></div>
                <div class="text-muted-custom" style="font-size:0.8rem;">计算布局中...</div>
            </div>
            <div id="memory-graph-container"
                 style="width:100%; height:100%; border:1px solid var(--bg-elevated); border-radius:8px; background:var(--bg-primary);">
            </div>
        </div>

        @* 右侧详情面板 *@
        @if (_selectedNode != null)
        {
            <div class="graph-detail-panel">
                <div class="graph-detail-header">
                    <span class="badge-type" style="background:@GetTypeColor(_selectedNode.Type)">
                        @_selectedNode.Type
                    </span>
                    @if (_selectedNode.IsCore)
                    {
                        <span class="badge-type" style="background:#ffd54f; color:#000;">核心</span>
                    }
                    @if (_selectedNode.IsDerived)
                    {
                        <span class="text-muted-custom ms-1" title="衍生记忆">衍生</span>
                    }
                    <button class="btn-ghost btn-sm ms-auto" @onclick="ClearSelection" title="关闭">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
                <div class="graph-detail-body">
                    <div class="detail-label">#@_selectedNode.Id</div>
                    <div class="detail-content">@_selectedNode.Content</div>
                    <div class="detail-meta">
                        <div>置信度: @_selectedNode.Confidence</div>
                        <div>重要度: @(_selectedNode.Importance.ToString("F2"))</div>
                        <div>关联数: @_selectedNode.LinkCount</div>
                    </div>
                    @if (_selectedNode.Neighbors?.Count > 0)
                    {
                        <div class="detail-neighbors">
                            <div class="detail-label mb-1">关联记忆</div>
                            @foreach (var nb in _selectedNode.Neighbors.Take(8))
                            {
                                <div class="neighbor-item" @onclick="() => FocusNode(nb.Id)" @onclick:stopPropagation>
                                    <span class="badge-type" style="background:@GetTypeColor(nb.Type); font-size:0.65rem;">@nb.Type</span>
                                    <span class="ms-1" style="font-size:0.75rem;">@(nb.Content.Length > 30 ? nb.Content[..30] + "…" : nb.Content)</span>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="graph-detail-footer">
                    <button class="btn-ghost btn-sm" @onclick="GoToDetail">
                        <i class="bi bi-box-arrow-up-right me-1"></i>查看详情
                    </button>
                </div>
            </div>
        }
    </div>

    <div class="d-flex gap-3 align-items-center mt-2 flex-wrap" style="font-size:0.75rem;">
        <span class="text-muted-custom">图例:</span>
        @foreach (var kv in new Dictionary<string, string> {
            ["knowledge"] = "知识", ["fact"] = "事实", ["feedback"] = "反馈", ["inference"] = "推理", ["event"] = "事件"
        })
        {
            <span class="d-flex align-items-center gap-1">
                <span style="width:10px;height:10px;border-radius:50%;background:@GetTypeColor(kv.Key);display:inline-block;"></span>
                @kv.Value
            </span>
        }
        <span class="ms-2 text-muted-custom">| 节点大小 = 重要度 | 边距 = 关联强度 | 箭头 = 方向</span>
    </div>
}

@* ======== 样式 ======== *@
<style>
    .cluster-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(300px, 1fr)); gap:1rem; }
    .cluster-card {
        background:var(--bg-elevated); border:1px solid var(--border-color); border-radius:8px;
        padding:1rem; cursor:pointer; transition: all 0.2s;
        display:flex; flex-direction:column; gap:0.6rem;
    }
    .cluster-card:hover { border-color:var(--accent-color); background:var(--accent-color-dim); transform:translateY(-2px); }
    .cluster-scrap { opacity:0.6; }
    .cluster-scrap:hover { opacity:0.9; }

    .cluster-card-header { }
    .cluster-core-label { font-size:0.9rem; font-weight:500; color:var(--text-primary); line-height:1.4; }

    .cluster-card-body { display:flex; gap:1rem; align-items:center; flex-wrap:wrap; }
    .cluster-stat { font-size:0.8rem; color:var(--text-secondary); display:flex; align-items:center; gap:0.3rem; }
    .cluster-types { display:flex; gap:0.3rem; flex-wrap:wrap; }

    .badge-type {
        padding:0.1rem 0.5rem; border-radius:10px; font-size:0.7rem; color:#fff;
        text-transform:uppercase; white-space:nowrap;
    }

    /* 右侧详情面板 */
    .graph-detail-panel {
        width:320px; min-width:320px; border-left:1px solid var(--border-color);
        background:var(--bg-elevated); display:flex; flex-direction:column; overflow:hidden;
    }
    .graph-detail-header { display:flex; align-items:center; gap:0.4rem; padding:0.8rem; border-bottom:1px solid var(--border-color); }
    .graph-detail-body { flex:1; overflow-y:auto; padding:0.8rem; }
    .graph-detail-footer { padding:0.8rem; border-top:1px solid var(--border-color); }

    .detail-label { font-size:0.75rem; color:var(--text-secondary); }
    .detail-content { font-size:0.85rem; color:var(--text-primary); margin:0.5rem 0; line-height:1.5; }
    .detail-meta { font-size:0.75rem; color:var(--text-secondary); display:flex; flex-direction:column; gap:0.2rem; margin-bottom:0.5rem; }
    .detail-neighbors { margin-top:0.5rem; }
    .neighbor-item {
        padding:0.3rem 0.5rem; border-radius:4px; cursor:pointer; transition: background 0.15s;
        display:flex; align-items:center; gap:0.3rem; margin-bottom:2px;
    }
    .neighbor-item:hover { background:var(--bg-hover); }
</style>

@code {
    private enum GraphView { clusters, graph }
    private GraphView _view = GraphView.clusters;
    private int _minNodes = 3;
    private string _searchText = "";

    // 簇数据
    private List<MemoryCluster> _allClusters = new();
    private List<MemoryCluster> _filteredClusters = new();
    private int _scrapNodes;
    private int _scrapEdges;
    private Dictionary<string, int> _scrapTypeCounts = new();

    // 当前打开的簇
    private MemoryCluster _currentCluster = null!;
    private string _currentClusterName = "";
    private List<MemoryEntry> _clusterMemories = new();
    private DotNetObjectReference<Memory_Graph>? _dotNetRef;
    private bool _graphRendered;

    // 选中节点
    private NodeDetail? _selectedNode;

    // 原始数据
    private List<MemoryEntry> _allMemories = new();
    private List<MemoryLink> _allLinks = new();
    private Dictionary<int, MemoryEntry> _memDict = new();
    private Dictionary<int, List<MemoryLink>> _nodeLinks = new();

    // ======== 数据模型 ========

    private class MemoryCluster
    {
        public List<int> NodeIds { get; init; } = new();
        public int CoreNodeId { get; set; }
        public string CoreContent { get; set; } = "";
        public int NodeCount => NodeIds.Count;
        public int EdgeCount { get; set; }
        public Dictionary<string, int> TypeCounts { get; set; } = new();
        public bool IsScrap;
    }

    private class NodeDetail
    {
        public int Id { get; set; }
        public string Content { get; set; } = "";
        public string Type { get; set; } = "";
        public float Importance { get; set; }
        public string Confidence { get; set; } = "";
        public bool IsCore { get; set; }
        public bool IsDerived { get; set; }
        public int LinkCount { get; set; }
        public List<NeighborRef>? Neighbors { get; set; }
    }

    private class NeighborRef
    {
        public int Id { get; set; }
        public string Content { get; set; } = "";
        public string Type { get; set; } = "";
    }

    // ======== 初始化 ========

    protected override async Task OnInitializedAsync()
    {
        _allLinks = await Engine.MemoryLinks.GetAllLinksAsync();
        var nodeIds = new HashSet<int>();
        foreach (var l in _allLinks) { nodeIds.Add(l.SourceId); nodeIds.Add(l.TargetId); }
        if (nodeIds.Count > 0)
            _allMemories = await Engine.Memories.GetByIdsAsync(nodeIds.ToList());

        _memDict = _allMemories.ToDictionary(m => m.Id);

        _nodeLinks = new();
        foreach (var link in _allLinks)
        {
            if (!_nodeLinks.ContainsKey(link.SourceId)) _nodeLinks[link.SourceId] = new();
            if (!_nodeLinks.ContainsKey(link.TargetId)) _nodeLinks[link.TargetId] = new();
            _nodeLinks[link.SourceId].Add(link);
            _nodeLinks[link.TargetId].Add(link);
        }

        ComputeClusters();
        RebuildClusters();
    }

    // ======== 连通分量计算 ========

    private void ComputeClusters()
    {
        var visited = new HashSet<int>();
        var allNodeIds = new HashSet<int>(_nodeLinks.Keys);
        // 也包含只在 Memory 表中有但无 link 的节点
        foreach (var m in _allMemories) allNodeIds.Add(m.Id);

        _allClusters.Clear();

        foreach (var nodeId in allNodeIds)
        {
            if (visited.Contains(nodeId)) continue;

            // BFS 收集当前连通分量
            var component = new HashSet<int>();
            var queue = new Queue<int>();
            queue.Enqueue(nodeId);
            component.Add(nodeId);

            while (queue.Count > 0)
            {
                var current = queue.Dequeue();
                if (!_nodeLinks.TryGetValue(current, out var links)) continue;

                foreach (var link in links)
                {
                    var neighbor = link.SourceId == current ? link.TargetId : link.SourceId;
                    if (!visited.Contains(neighbor) && component.Add(neighbor))
                        queue.Enqueue(neighbor);
                }
            }

            foreach (var n in component) visited.Add(n);

            // 计算核心节点（边权重总和最高）
            int bestNode = component.First();
            double bestWeight = 0;
            foreach (var n in component)
            {
                double totalWeight = 0;
                if (_nodeLinks.TryGetValue(n, out var l))
                    totalWeight = l.Sum(link => link.Strength);
                if (totalWeight > bestWeight)
                {
                    bestWeight = totalWeight;
                    bestNode = n;
                }
            }

            // 统计该簇的边数（两端都在簇内）
            var edgeCount = 0;
            foreach (var n in component)
            {
                if (_nodeLinks.TryGetValue(n, out var l))
                    edgeCount += l.Count(link => component.Contains(link.SourceId) && component.Contains(link.TargetId));
            }
            edgeCount /= 2; // 每条边被算了两次

            // 类型分布
            var typeCounts = new Dictionary<string, int>();
            foreach (var n in component)
            {
                if (_memDict.TryGetValue(n, out var mem))
                {
                    var t = mem.Type ?? "fact";
                    typeCounts[t] = typeCounts.GetValueOrDefault(t) + 1;
                }
            }

            var coreContent = _memDict.TryGetValue(bestNode, out var coreMem)
                ? coreMem.Content : $"记忆 #{bestNode}";

            _allClusters.Add(new MemoryCluster
            {
                NodeIds = component.ToList(),
                CoreNodeId = bestNode,
                CoreContent = coreContent,
                EdgeCount = edgeCount,
                TypeCounts = typeCounts
            });
        }

        // 按节点数降序
        _allClusters = _allClusters.OrderByDescending(c => c.NodeCount).ToList();
    }

    private void RebuildClusters()
    {
        _filteredClusters = _allClusters.Where(c => c.NodeCount >= _minNodes).ToList();
        var scrap = _allClusters.Where(c => c.NodeCount < _minNodes).ToList();
        _scrapNodes = scrap.Sum(c => c.NodeCount);
        _scrapEdges = scrap.Sum(c => c.EdgeCount);
        _scrapTypeCounts = new();
        foreach (var c in scrap)
            foreach (var (t, n) in c.TypeCounts)
                _scrapTypeCounts[t] = _scrapTypeCounts.GetValueOrDefault(t) + n;

        StateHasChanged();
    }

    // ======== 簇操作 ========

    private async Task OpenCluster(MemoryCluster cluster)
    {
        _currentCluster = cluster;
        _currentClusterName = cluster.CoreContent.Length > 40
            ? cluster.CoreContent[..40] + "…"
            : cluster.CoreContent;
        _selectedNode = null;
        _view = GraphView.graph;
        StateHasChanged();

        // 等 DOM 渲染
        await Task.Delay(100);
        await RenderGraph(cluster);
    }

    private async Task OpenScrapBucket()
    {
        var scrap = _allClusters.Where(c => c.NodeCount < _minNodes).ToList();
        var allNodeIds = scrap.SelectMany(c => c.NodeIds).ToList();
        if (allNodeIds.Count == 0) return;

        // 碎屑桶里找核心
        var coreId = allNodeIds.First();
        double bestWeight = 0;
        foreach (var n in allNodeIds)
        {
            double w = 0;
            if (_nodeLinks.TryGetValue(n, out var l))
                w = l.Sum(link => link.Strength);
            if (w > bestWeight) { bestWeight = w; coreId = n; }
        }

        var coreContent = _memDict.TryGetValue(coreId, out var cm) ? cm.Content : $"记忆 #{coreId}";
        var edgeCount = scrap.Sum(c => c.EdgeCount);
        var typeCounts = new Dictionary<string, int>();
        foreach (var c in scrap) foreach (var (t, n) in c.TypeCounts) typeCounts[t] = typeCounts.GetValueOrDefault(t) + n;

        _currentCluster = new MemoryCluster
        {
            NodeIds = allNodeIds,
            CoreNodeId = coreId,
            CoreContent = coreContent,
            EdgeCount = edgeCount,
            TypeCounts = typeCounts,
            IsScrap = true
        };
        _currentClusterName = "碎屑桶";
        _selectedNode = null;
        _view = GraphView.graph;
        StateHasChanged();

        await Task.Delay(100);
        await RenderGraph(_currentCluster);
    }

    private void BackToClusters()
    {
        _view = GraphView.clusters;
        _selectedNode = null;
        _focusId = 0;
        JS.InvokeVoidAsync("destroyMemoryGraph");
        _graphRendered = false;
        RebuildClusters();
    }

    // ======== 图谱渲染 ========

    // Layout + grid state (positions mutable on focus change)
    private Dictionary<int, (double x, double y)> _cachedPositions = new();
    private Dictionary<int, int> _nodeGridIndex = new();       // nodeId → hex grid index
    private List<bool> _gridOccupied = new();                  // true = occupied
    private List<int> _gridOwner = new();                      // nodeId owning each grid spot, -1 = none
    private List<(int q, int r)> _hexPoints = new();
    private List<(double x, double y)> _hexCartesian = new();
    private List<MemoryLink> _cachedEdges = new();
    // Visibility tracking
    private HashSet<int> _currentlyVisibleIds = new();
    private int _focusId;
    private int _maxVisible = 60;
    private int _visibleNodeCount;
    private int _totalNodeCount;
    // Cached adjacency for placement
    private Dictionary<int, List<(int nb, double w)>> _adj = new();

    private async Task RenderGraph(MemoryCluster cluster)
    {
        _clusterMemories = _allMemories.Where(m => cluster.NodeIds.Contains(m.Id)).ToList();
        var nodeIdSet = cluster.NodeIds.ToHashSet();
        _cachedEdges = _allLinks
            .Where(l => nodeIdSet.Contains(l.SourceId) && nodeIdSet.Contains(l.TargetId))
            .ToList();

        _totalNodeCount = cluster.NodeIds.Count;
        _focusId = cluster.CoreNodeId;

        // Build adjacency cache for this cluster
        _adj.Clear();
        foreach (var id in cluster.NodeIds) _adj[id] = new();
        foreach (var link in _cachedEdges)
        {
            if (_adj.ContainsKey(link.SourceId) && _adj.ContainsKey(link.TargetId))
            {
                _adj[link.SourceId].Add((link.TargetId, link.Strength));
                _adj[link.TargetId].Add((link.SourceId, link.Strength));
            }
        }

        // Full layout (fills grid state fields)
        _cachedPositions = ComputeLayout(cluster.NodeIds, cluster.CoreNodeId);

        // Initial visible set
        _currentlyVisibleIds = GetTopWeightNodes(_focusId, _maxVisible).ToHashSet();

        // Only visible nodes claim grid spots — leave rest vacant for focus changes
        for (int i = 0; i < _gridOccupied.Count; i++) { _gridOccupied[i] = false; _gridOwner[i] = -1; }
        foreach (var id in _currentlyVisibleIds)
        {
            if (_nodeGridIndex.TryGetValue(id, out int gIdx))
            { _gridOccupied[gIdx] = true; _gridOwner[gIdx] = id; }
        }

        await SendVisibleGraph();
    }

    private async Task RefilterGraph()
    {
        // Slider changed _maxVisible → recalc visible set from same focus
        var newVisible = GetTopWeightNodes(_focusId, _maxVisible).ToHashSet();

        // Free positions of nodes leaving the visible set
        foreach (var id in _currentlyVisibleIds)
        {
            if (!newVisible.Contains(id) && _nodeGridIndex.TryGetValue(id, out int gIdx))
                { _gridOccupied[gIdx] = false; _gridOwner[gIdx] = -1; }
        }

        // Place newly visible nodes
        var stayingIds = _currentlyVisibleIds.Where(id => newVisible.Contains(id)).ToHashSet();
        var newNodes = newVisible.Where(id => !_currentlyVisibleIds.Contains(id)).ToList();
        if (newNodes.Count > 0)
        {
            PlaceNewlyVisible(newNodes, _focusId, stayingIds);
        }

        _currentlyVisibleIds = newVisible;
        await SendVisibleGraph();
    }

    private async Task RelayoutOnFocusChange(int newFocusId)
    {
        if (_focusId == newFocusId) return;
        _focusId = newFocusId;

        var newVisible = GetTopWeightNodes(newFocusId, _maxVisible).ToHashSet();

        // Free positions of nodes leaving the visible set
        foreach (var id in _currentlyVisibleIds)
        {
            if (!newVisible.Contains(id) && _nodeGridIndex.TryGetValue(id, out int gIdx))
                { _gridOccupied[gIdx] = false; _gridOwner[gIdx] = -1; }
        }

        var stayingIds = _currentlyVisibleIds.Where(id => newVisible.Contains(id)).ToHashSet();
        var newNodes = newVisible.Where(id => !_currentlyVisibleIds.Contains(id)).ToList();

        if (newNodes.Count > 0)
        {
            PlaceNewlyVisible(newNodes, newFocusId, stayingIds);
        }

        _currentlyVisibleIds = newVisible;
        await SendVisibleGraph();
    }

    private void PlaceNewlyVisible(List<int> newNodes, int focusId, HashSet<int> stayingIds)
    {
        // Pre-reserve old grid positions of new nodes so they can't be
        // stolen by other new nodes. Released on successful re-placement.
        foreach (var nodeId in newNodes)
        {
            if (_nodeGridIndex.TryGetValue(nodeId, out int oldIdx))
            {
                // Only reserve if spot is unclaimed or still ours
                if (_gridOwner[oldIdx] == -1 || _gridOwner[oldIdx] == nodeId)
                { _gridOccupied[oldIdx] = true; _gridOwner[oldIdx] = nodeId; }
            }
        }

        // Get focus position (it's a staying node, position locked)
        var focusPos = _cachedPositions.GetValueOrDefault(focusId);

        // All vacant grid indices, sorted by distance to focus
        var vacant = Enumerable.Range(0, _hexCartesian.Count)
            .Where(i => !_gridOccupied[i])
            .OrderBy(i =>
            {
                double dx = _hexCartesian[i].x - focusPos.x;
                double dy = _hexCartesian[i].y - focusPos.y;
                return dx * dx + dy * dy;
            })
            .ToList();

        // Focus-direct new nodes: place in closest vacant spots
        var focusDirect = newNodes
            .Where(id => _adj[id].Any(x => x.nb == focusId))
            .OrderByDescending(id => _adj[id].First(x => x.nb == focusId).w)
            .ToList();

        var others = newNodes.Except(focusDirect)
            .OrderByDescending(id => _adj[id]
                .Where(x => stayingIds.Contains(x.nb))
                .Select(x => x.w).DefaultIfEmpty(0).Max())
            .ToList();

        var placedSet = new HashSet<int>(stayingIds);

        // Place focus-direct nodes
        int vacIdx = 0;
        foreach (var nodeId in focusDirect)
        {
            if (vacIdx >= vacant.Count) break;
            int gIdx = vacant[vacIdx++];

            if (_nodeGridIndex.TryGetValue(nodeId, out int oldIdx) && oldIdx != gIdx
                && _gridOwner[oldIdx] == nodeId)
            { _gridOccupied[oldIdx] = false; _gridOwner[oldIdx] = -1; }

            _cachedPositions[nodeId] = _hexCartesian[gIdx];
            _gridOccupied[gIdx] = true;
            _gridOwner[gIdx] = nodeId;
            _nodeGridIndex[nodeId] = gIdx;
            placedSet.Add(nodeId);
        }

        // Place others by weighted centroid
        foreach (var nodeId in others)
        {
            var placedNb = _adj[nodeId].Where(x => placedSet.Contains(x.nb)).ToList();

            if (placedNb.Count > 0)
            {
                double sumW = 0, cx = 0, cy = 0;
                foreach (var (nb, w) in placedNb)
                {
                    sumW += w;
                    cx += w * _cachedPositions[nb].x;
                    cy += w * _cachedPositions[nb].y;
                }
                cx /= sumW;
                cy /= sumW;

                // Find closest remaining vacant spot to centroid
                int bestV = -1;
                double bestD = double.MaxValue;
                foreach (int vi in vacant.Skip(vacIdx))
                {
                    if (_gridOccupied[vi]) continue;
                    double dx = cx - _hexCartesian[vi].x;
                    double dy = cy - _hexCartesian[vi].y;
                    double d = dx * dx + dy * dy;
                    if (d < bestD) { bestD = d; bestV = vi; }
                }

                if (bestV >= 0)
                {
                    if (_nodeGridIndex.TryGetValue(nodeId, out int oldIdx) && oldIdx != bestV
                        && _gridOwner[oldIdx] == nodeId)
                    { _gridOccupied[oldIdx] = false; _gridOwner[oldIdx] = -1; }

                    _cachedPositions[nodeId] = _hexCartesian[bestV];
                    _gridOccupied[bestV] = true;
                    _gridOwner[bestV] = nodeId;
                    _nodeGridIndex[nodeId] = bestV;
                    placedSet.Add(nodeId);
                }
            }
            else if (vacIdx < vacant.Count)
            {
                // Isolated: take closest remaining vacant
                int gIdx = vacant[vacIdx++];

                if (_nodeGridIndex.TryGetValue(nodeId, out int oldIdx) && oldIdx != gIdx
                    && _gridOwner[oldIdx] == nodeId)
                { _gridOccupied[oldIdx] = false; _gridOwner[oldIdx] = -1; }

                _cachedPositions[nodeId] = _hexCartesian[gIdx];
                _gridOccupied[gIdx] = true;
                _gridOwner[gIdx] = nodeId;
                _nodeGridIndex[nodeId] = gIdx;
                placedSet.Add(nodeId);
            }
        }
    }

    private (double x, double y) VisualOffset(int nodeId, double rawX, double rawY)
    {
        // Stagger based on hex grid position to prevent label overlap
        double sx = 0, sy = 0;
        if (_nodeGridIndex.TryGetValue(nodeId, out int gIdx) && gIdx < _hexPoints.Count)
        {
            var (q, r) = _hexPoints[gIdx];
            if ((q & 1) != 0) sy -= 60;          // odd q → shift up
            if ((r & 1) != 0) sx += 16;          // odd r → shift right
        }

        // Deterministic jitter based on nodeId (prevents edge overlap)
        uint h = (uint)nodeId * 2654435761u;
        double jx = ((int)(h & 0xFFFF) / 65535.0 - 0.5) * 22;
        double jy = ((int)((h >> 16) & 0xFFFF) / 65535.0 - 0.5) * 22;

        return (rawX + sx + jx, rawY + sy + jy);
    }

    private async Task SendVisibleGraph()
    {
        _visibleNodeCount = _currentlyVisibleIds.Count;

        var nodes = _clusterMemories.Where(m => _currentlyVisibleIds.Contains(m.Id)).Select(m =>
        {
            var (rx, ry) = _cachedPositions[m.Id];
            var (x, y) = VisualOffset(m.Id, rx, ry);
            return (object)new
            {
                id = m.Id.ToString(),
                label = WrapLabel(m.Content),
                type = m.Type ?? "fact",
                title = $"#{m.Id} [{m.Type}] {m.Content}",
                importance = m.Importance,
                isDerived = m.IsDerived,
                isCore = m.Id == _currentCluster.CoreNodeId,
                isFocus = m.Id == _focusId,
                x = x, y = y
            };
        }).ToArray();

        var edges = _cachedEdges
            .Where(l => _currentlyVisibleIds.Contains(l.SourceId) && _currentlyVisibleIds.Contains(l.TargetId))
            .Select(l => (object)new
            {
                from = l.SourceId.ToString(),
                to = l.TargetId.ToString(),
                label = l.LinkType ?? "",
                width = l.Strength
            }).ToArray();

        var data = new { nodes, edges };

        if (!_graphRendered)
        {
            _dotNetRef?.Dispose();
            _dotNetRef = DotNetObjectReference.Create(this);

            await JS.InvokeVoidAsync("initMemoryGraph",
                "memory-graph-container", data, _focusId.ToString(), _dotNetRef);
            _graphRendered = true;
        }
        else
        {
            await JS.InvokeVoidAsync("updateMemoryGraph", data, _focusId.ToString());
        }

        StateHasChanged();
    }

    private List<int> GetTopWeightNodes(int focusId, int topN)
    {
        // BFS with cumulative weight product: path weight = product of edge strengths
        var weights = new Dictionary<int, double>();
        var prev = new Dictionary<int, int>(); // for debugging only
        var queue = new Queue<int>();
        weights[focusId] = 1.0;
        queue.Enqueue(focusId);

        while (queue.Count > 0)
        {
            var node = queue.Dequeue();
            var w = weights[node];
            if (!_nodeLinks.TryGetValue(node, out var links)) continue;
            foreach (var link in links)
            {
                var nb = link.SourceId == node ? link.TargetId : link.SourceId;
                if (!_currentCluster.NodeIds.Contains(nb)) continue;
                double edgeWeight = Math.Max(0.05, link.Strength);
                double newWeight = w * edgeWeight;
                if (!weights.ContainsKey(nb) || newWeight > weights[nb])
                {
                    weights[nb] = newWeight;
                    prev[nb] = node;
                    queue.Enqueue(nb);
                }
            }
        }

        return weights.OrderByDescending(kv => kv.Value).Take(topN).Select(kv => kv.Key).ToList();
    }

    // ======== 三角网格贪心布局 ========

    private static List<(int q, int r)> GenerateHexGrid(int maxRings)
    {
        var points = new List<(int q, int r)> { (0, 0) };
        for (int d = 1; d <= maxRings; d++)
        {
            int q = d, r = 0;
            (int dq, int dr)[] dirs = { (-1, 1), (-1, 0), (0, -1), (1, -1), (1, 0), (0, 1) };
            foreach (var (dq, dr) in dirs)
            {
                for (int step = 0; step < d; step++)
                {
                    points.Add((q, r));
                    q += dq;
                    r += dr;
                }
            }
        }
        return points;
    }

    private static (double x, double y) HexToCartesian(int q, int r, double spacing)
        => (spacing * (q + r * 0.5), spacing * (r * Math.Sqrt(3) / 2));

    private static int HexDist(int q, int r)
        => (Math.Abs(q) + Math.Abs(r) + Math.Abs(q + r)) / 2;

    private Dictionary<int, (double x, double y)> ComputeLayout(
        List<int> nodeIds, int coreId)
    {
        const double spacing = 150;
        int n = nodeIds.Count;

        // 1. Generate hex grid large enough for all nodes
        int maxRings = 1;
        while (1 + 3 * maxRings * (maxRings + 1) < Math.Max(n, 200)) maxRings++;

        _hexPoints = GenerateHexGrid(maxRings);
        _hexCartesian = _hexPoints.Select(h => HexToCartesian(h.q, h.r, spacing)).ToList();
        _gridOccupied = Enumerable.Repeat(false, _hexCartesian.Count).ToList();
        _gridOwner = Enumerable.Repeat(-1, _hexCartesian.Count).ToList();
        _nodeGridIndex.Clear();
        var pos = new Dictionary<int, (double x, double y)>();
        var remaining = new HashSet<int>(nodeIds);

        // 2. Place core at center
        pos[coreId] = _hexCartesian[0];
        _gridOccupied[0] = true;
        _gridOwner[0] = coreId;
        _nodeGridIndex[coreId] = 0;
        remaining.Remove(coreId);

        // 3. Index grid points by ring distance, sort clockwise
        var ringIndices = new Dictionary<int, List<int>>();
        for (int i = 1; i < _hexPoints.Count; i++)
        {
            int dist = HexDist(_hexPoints[i].q, _hexPoints[i].r);
            if (!ringIndices.ContainsKey(dist))
                ringIndices[dist] = new();
            ringIndices[dist].Add(i);
        }
        foreach (int r in ringIndices.Keys)
            ringIndices[r] = ringIndices[r]
                .OrderBy(i => Math.Atan2(_hexCartesian[i].y, _hexCartesian[i].x))
                .ToList();

        // 4. Focus-connected nodes: assign to rings by weight rank
        var focusDirect = _adj[coreId]
            .Where(x => remaining.Contains(x.nb))
            .OrderByDescending(x => x.w)
            .Select(x => x.nb)
            .ToList();

        int directIdx = 0;
        for (int ring = 1; ring <= maxRings && directIdx < focusDirect.Count; ring++)
        {
            if (!ringIndices.ContainsKey(ring)) continue;
            var slots = ringIndices[ring];
            int? prevId = null;

            for (int si = 0; si < slots.Count && directIdx < focusDirect.Count; si++)
            {
                int gIdx = slots[si];
                if (_gridOccupied[gIdx]) continue;

                int? bestNode = null;
                double bestW = -1;

                if (prevId.HasValue)
                {
                    for (int di = directIdx; di < focusDirect.Count; di++)
                    {
                        int cand = focusDirect[di];
                        if (!remaining.Contains(cand)) continue;
                        double w = _adj[cand].FirstOrDefault(x => x.nb == prevId.Value).w;
                        if (w > bestW) { bestW = w; bestNode = cand; }
                    }
                }

                if (bestNode == null)
                {
                    while (directIdx < focusDirect.Count && !remaining.Contains(focusDirect[directIdx]))
                        directIdx++;
                    if (directIdx < focusDirect.Count)
                        bestNode = focusDirect[directIdx];
                }

                if (bestNode.HasValue)
                {
                    pos[bestNode.Value] = _hexCartesian[gIdx];
                    _gridOccupied[gIdx] = true;
                    _gridOwner[gIdx] = bestNode.Value;
                    _nodeGridIndex[bestNode.Value] = gIdx;
                    remaining.Remove(bestNode.Value);
                    prevId = bestNode.Value;
                }
            }
        }

        // 5. Multi-hop nodes: weighted centroid → nearest vacant grid
        var multiHop = remaining.ToList();
        multiHop.Sort((a, b) =>
        {
            double maxA = _adj[a].Where(x => pos.ContainsKey(x.nb)).Select(x => x.w).DefaultIfEmpty(0).Max();
            double maxB = _adj[b].Where(x => pos.ContainsKey(x.nb)).Select(x => x.w).DefaultIfEmpty(0).Max();
            return maxB.CompareTo(maxA);
        });

        var vacant = Enumerable.Range(0, _hexCartesian.Count).Where(i => !_gridOccupied[i]).ToList();

        foreach (var nodeId in multiHop)
        {
            var placedNb = _adj[nodeId].Where(x => pos.ContainsKey(x.nb)).ToList();

            if (placedNb.Count > 0)
            {
                double sumW = 0, cx = 0, cy = 0;
                foreach (var (nb, w) in placedNb)
                {
                    sumW += w;
                    cx += w * pos[nb].x;
                    cy += w * pos[nb].y;
                }
                cx /= sumW;
                cy /= sumW;

                int bestV = -1;
                double bestD = double.MaxValue;
                foreach (int vi in vacant)
                {
                    if (_gridOccupied[vi]) continue;
                    double dx = cx - _hexCartesian[vi].x;
                    double dy = cy - _hexCartesian[vi].y;
                    double d = dx * dx + dy * dy;
                    if (d < bestD) { bestD = d; bestV = vi; }
                }

                pos[nodeId] = _hexCartesian[bestV];
                _gridOccupied[bestV] = true;
                _gridOwner[bestV] = nodeId;
                _nodeGridIndex[nodeId] = bestV;
                vacant.Remove(bestV);
            }
            else if (vacant.Count > 0)
            {
                pos[nodeId] = _hexCartesian[vacant[0]];
                _gridOccupied[vacant[0]] = true;
                _gridOwner[vacant[0]] = nodeId;
                _nodeGridIndex[nodeId] = vacant[0];
                vacant.RemoveAt(0);
            }
        }

        return pos;
    }

    /// <summary>Wrap text to 20 chars per line, max 3 lines.</summary>
    private static string WrapLabel(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";
        const int charsPerLine = 20;
        const int maxLines = 3;
        var lines = new List<string>();
        int pos = 0;

        while (pos < text.Length && lines.Count < maxLines)
        {
            int remaining = Math.Min(charsPerLine, text.Length - pos);
            if (pos + remaining >= text.Length)
            {
                lines.Add(text[pos..]);
                break;
            }
            // Try to break at natural boundary (space/punctuation)
            int end = pos + remaining;
            int breakAt = -1;
            for (int scan = Math.Min(end, text.Length - 1); scan > pos; scan--)
            {
                if (text[scan] == ' ' || text[scan] == '，' || text[scan] == '。'
                    || text[scan] == '、' || text[scan] == '；' || text[scan] == '：')
                {
                    breakAt = scan;
                    break;
                }
            }
            if (breakAt > pos)
                end = breakAt + 1;
            else if (lines.Count == maxLines - 1)
                end = Math.Min(pos + charsPerLine - 2, text.Length); // leave room for "…"

            lines.Add(text[pos..Math.Min(end, text.Length)]);
            pos = end;
        }

        var result = string.Join("\n", lines);
        if (pos < text.Length)
            result = result.TrimEnd() + "…";
        return result;
    }

    // ======== JS 回调 ========

    [JSInvokable]
    public async Task OnNodeSelected(int nodeId)
    {
        // Build detail panel data FIRST (before RelayoutOnFocusChange
        // triggers StateHasChanged via SendVisibleGraph)
        var mem = _clusterMemories.FirstOrDefault(m => m.Id == nodeId);
        if (mem != null)
        {
            var neighbors = new List<NeighborRef>();
            if (_nodeLinks.TryGetValue(nodeId, out var links))
            {
                foreach (var link in links)
                {
                    var nbId = link.SourceId == nodeId ? link.TargetId : link.SourceId;
                    if (_memDict.TryGetValue(nbId, out var nb) && _currentCluster.NodeIds.Contains(nbId))
                    {
                        neighbors.Add(new NeighborRef
                        {
                            Id = nbId,
                            Content = nb.Content,
                            Type = nb.Type ?? "fact"
                        });
                    }
                }
            }

            _selectedNode = new NodeDetail
            {
                Id = mem.Id,
                Content = mem.Content,
                Type = mem.Type ?? "fact",
                Importance = mem.Importance,
                Confidence = mem.Confidence ?? "high",
                IsCore = mem.Id == _currentCluster.CoreNodeId,
                IsDerived = mem.IsDerived,
                LinkCount = neighbors.Count,
                Neighbors = neighbors
            };
        }

        await RelayoutOnFocusChange(nodeId);
    }

