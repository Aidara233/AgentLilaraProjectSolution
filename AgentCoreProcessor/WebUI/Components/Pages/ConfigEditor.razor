@page "/config"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Config
@using Newtonsoft.Json.Linq
@using System.IO

<div class="page-title">
    <i class="bi bi-gear"></i> 配置编辑器
</div>

<div class="row">
    <!-- 左侧：配置组列表 -->
    <div class="col-md-3">
        <div class="card">
            <div class="card-header">配置组</div>
            <div style="padding:0.25rem;">
                @foreach (var (name, _) in configGroups)
                {
                    <button class="nav-link @(selectedGroup == name ? "active" : "")"
                            style="display:block; width:100%; text-align:left; padding:0.4rem 0.75rem; border-radius:var(--radius-sm); border:none; background:@(selectedGroup == name ? "var(--sidebar-active)" : "transparent"); color:@(selectedGroup == name ? "var(--accent)" : "var(--text-secondary)"); cursor:pointer; font-size:var(--font-size-sm); margin-bottom:0.15rem;"
                            @onclick="() => SelectGroup(name)">
                        @name
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- 右侧：键值编辑器 -->
    <div class="col-md-9">
        @if (string.IsNullOrEmpty(selectedGroup))
        {
            <div class="card">
                <div class="card-body text-muted-custom" style="text-align:center;">选择左侧配置组查看和编辑</div>
            </div>
        }
        else if (loadError != null)
        {
            <div style="background:var(--status-error-dim); color:var(--status-error); padding:0.75rem 1rem; border-radius:var(--radius-md);">
                @loadError
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>@selectedGroup</span>
                    <button class="btn-accent" @onclick="SaveConfig" disabled="@(!hasChanges)">
                        <i class="bi bi-save me-1"></i>保存
                    </button>
                </div>
                <div class="card-body p-0">
                    <table class="table-dark-custom">
                        <thead>
                            <tr>
                                <th style="width:35%">键</th>
                                <th>值</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (key, value) in editValues)
                            {
                                <tr>
                                    <td>
                                        <code style="color:var(--accent);">@key</code>
                                    </td>
                                    <td>
                                        @if (IsSensitive(key))
                                        {
                                            <div class="d-flex gap-1">
                                                <input type="@(revealedKeys.Contains(key) ? "text" : "password")"
                                                       class="form-control form-control-sm"
                                                       value="@value"
                                                       @onchange="e => OnValueChanged(key, e.Value?.ToString())" />
                                                <button class="btn-ghost" style="padding:0.3rem 0.5rem;" @onclick="() => ToggleReveal(key)">
                                                    <i class="bi @(revealedKeys.Contains(key) ? "bi-eye-slash" : "bi-eye")"></i>
                                                </button>
                                            </div>
                                        }
                                        else if (value == "true" || value == "false")
                                        {
                                            <label style="cursor:pointer;">
                                                <input type="checkbox" style="accent-color:var(--accent);"
                                                       checked="@(value == "true")"
                                                       @onchange="e => OnBoolChanged(key, e)" />
                                            </label>
                                        }
                                        else if (IsNumeric(value))
                                        {
                                            <input type="number" class="form-control form-control-sm" step="any"
                                                   value="@value"
                                                   @onchange="e => OnValueChanged(key, e.Value?.ToString())" />
                                        }
                                        else if (IsComplex(key))
                                        {
                                            <span class="text-muted-custom" style="font-size:var(--font-size-sm);">(复杂类型，请直接编辑文件)</span>
                                        }
                                        else
                                        {
                                            <input type="text" class="form-control form-control-sm"
                                                   value="@value"
                                                   @onchange="e => OnValueChanged(key, e.Value?.ToString())" />
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div style="background:@(statusIsError ? "var(--status-error-dim)" : "var(--status-ok-dim)"); color:@(statusIsError ? "var(--status-error)" : "var(--status-ok)"); padding:0.75rem 1rem; border-radius:var(--radius-md); margin-top:1rem; display:flex; align-items:center; justify-content:space-between;">
                    <span>@statusMessage</span>
                    <button class="btn-ghost" style="padding:0.2rem 0.5rem;" @onclick="() => statusMessage = null">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            }
        }
    </div>
</div>

@code {
    private static readonly Dictionary<string, string> configGroups = new()
    {
        ["base"] = Path.Combine(PathConfig.CoreConfigPath, "Base.json"),
        ["express"] = Path.Combine(PathConfig.CoreConfigPath, "ExpressCore.json"),
        ["working"] = Path.Combine(PathConfig.CoreConfigPath, "WorkingCore.json"),
        ["extraction"] = Path.Combine(PathConfig.CoreConfigPath, "MemoryExtractionCore.json"),
        ["consolidation"] = Path.Combine(PathConfig.CoreConfigPath, "ConsolidationCore.json"),
        ["weight"] = Path.Combine(PathConfig.CoreConfigPath, "WeightCore.json"),
        ["link"] = Path.Combine(PathConfig.CoreConfigPath, "LinkCore.json"),
        ["combine"] = Path.Combine(PathConfig.CoreConfigPath, "CombineCore.json"),
        ["review"] = Path.Combine(PathConfig.CoreConfigPath, "ReviewCore.json"),
        ["dream"] = Path.Combine(PathConfig.StoragePath, "Dream", "DreamConfig.json"),
        ["impulse"] = Path.Combine(PathConfig.StoragePath, "Engine", "ImpulseConfig.json"),
        ["trust"] = Path.Combine(PathConfig.StoragePath, "Engine", "TrustProgressionConfig.json"),
    };

    private static readonly HashSet<string> sensitiveKeys =
        new(StringComparer.OrdinalIgnoreCase) { "apiKey", "apikey", "api_key" };

    private string selectedGroup = "";
    private string? loadError;
    private Dictionary<string, string> editValues = new();
    private Dictionary<string, string> originalValues = new();
    private HashSet<string> complexKeys = new();
    private HashSet<string> revealedKeys = new();
    private bool hasChanges = false;
    private string? statusMessage;
    private bool statusIsError = false;

    private JObject? currentJson;
    private string? currentPath;

    private void SelectGroup(string name)
    {
        selectedGroup = name;
        loadError = null;
        statusMessage = null;
        hasChanges = false;
        revealedKeys.Clear();

        if (!configGroups.TryGetValue(name, out var path) || !File.Exists(path))
        {
            loadError = $"配置文件不存在: {path}";
            return;
        }

        try
        {
            currentPath = path;
            currentJson = JObject.Parse(File.ReadAllText(path));
            editValues = new();
            originalValues = new();
            complexKeys = new();

            foreach (var prop in currentJson.Properties())
            {
                if (prop.Value.Type == JTokenType.Object || prop.Value.Type == JTokenType.Array)
                {
                    complexKeys.Add(prop.Name);
                    editValues[prop.Name] = "";
                }
                else
                {
                    var val = prop.Value.ToString();
                    editValues[prop.Name] = val;
                    originalValues[prop.Name] = val;
                }
            }
        }
        catch (Exception ex)
        {
            loadError = $"解析失败: {ex.Message}";
        }
    }

    private void OnValueChanged(string key, string? newValue)
    {
        if (newValue == null) return;
        editValues[key] = newValue;
        hasChanges = editValues.Any(kv =>
            originalValues.TryGetValue(kv.Key, out var orig) && kv.Value != orig);
    }

    private void SaveConfig()
    {
        if (currentJson == null || currentPath == null) return;

        try
        {
            foreach (var (key, value) in editValues)
            {
                if (complexKeys.Contains(key)) continue;
                if (!currentJson.ContainsKey(key)) continue;

                var existing = currentJson[key]!;
                currentJson[key] = existing.Type switch
                {
                    JTokenType.Integer => long.TryParse(value, out var l) ? l : existing,
                    JTokenType.Float => double.TryParse(value, out var d) ? d : existing,
                    JTokenType.Boolean => bool.TryParse(value, out var b) ? b : existing,
                    _ => value
                };
            }

            File.WriteAllText(currentPath, currentJson.ToString(Newtonsoft.Json.Formatting.Indented));

            originalValues = new Dictionary<string, string>(editValues);
            hasChanges = false;
            statusMessage = "配置已保存";
            statusIsError = false;
        }
        catch (Exception ex)
        {
            statusMessage = $"保存失败: {ex.Message}";
            statusIsError = true;
        }
    }

    private void ToggleReveal(string key)
    {
        if (!revealedKeys.Remove(key)) revealedKeys.Add(key);
    }

    private static bool IsSensitive(string key) => sensitiveKeys.Contains(key);
    private bool IsComplex(string key) => complexKeys.Contains(key);

    private void OnBoolChanged(string key, ChangeEventArgs e)
    {
        OnValueChanged(key, (bool)e.Value! ? "true" : "false");
    }

    private static bool IsNumeric(string value)
    {
        return double.TryParse(value, out _) && value != "true" && value != "false";
    }
}
