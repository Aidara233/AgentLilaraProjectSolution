@page "/people"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Engine
@using AgentCoreProcessor.Database
@inject MasterEngine Engine

<div class="page-title">
    <i class="bi bi-people"></i> 人物目录
</div>

<div class="card">
    <div class="card-body p-0">
        @if (persons.Count == 0)
        {
            <div class="p-3 text-muted-custom" style="text-align:center;">无人物数据</div>
        }
        else
        {
            <table class="table-dark-custom">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>名称</th>
                        <th>信任等级</th>
                        <th>好感度</th>
                        <th>快速记忆</th>
                        <th>警报</th>
                        <th>创建时间</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in persons)
                    {
                        <tr class="@(flashId == p.Id ? "save-flash" : "")">
                            <td>@p.Id</td>
                            <td style="font-weight:500;">
                                @(string.IsNullOrEmpty(p.Name) ? "-" : p.Name)
                                @if (!string.IsNullOrEmpty(p.Aliases))
                                {
                                    <small class="text-muted-custom ms-1">(@p.Aliases)</small>
                                }
                            </td>
                            <td>
                                @if (editingPersonId == p.Id && editingField == "TrustLevel")
                                {
                                    <select class="inline-edit-select" @bind="editTrustLevel">
                                        @foreach (var lv in Enum.GetValues<TrustLevel>())
                                        {
                                            <option value="@lv">@lv</option>
                                        }
                                    </select>
                                    <span class="inline-edit-actions">
                                        <button class="save" @onclick="SavePersonEdit"><i class="bi bi-check"></i></button>
                                        <button class="cancel" @onclick="CancelEdit"><i class="bi bi-x"></i></button>
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-editable badge-status @TrustBadgeClass(p.TrustLevel)"
                                          @onclick="() => StartEditPerson(p, nameof(Person.TrustLevel))">
                                        @p.TrustLevel
                                    </span>
                                }
                            </td>
                            <td>
                                @if (editingPersonId == p.Id && editingField == "TrustProgress")
                                {
                                    <input type="number" step="0.1" class="inline-edit-input" style="width:70px;"
                                           @bind="editTrustProgress" />
                                    <span class="inline-edit-actions">
                                        <button class="save" @onclick="SavePersonEdit"><i class="bi bi-check"></i></button>
                                        <button class="cancel" @onclick="CancelEdit"><i class="bi bi-x"></i></button>
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-editable" @onclick="() => StartEditPerson(p, nameof(Person.TrustProgress))">
                                        @p.TrustProgress.ToString("F1")
                                    </span>
                                }
                            </td>
                            <td>
                                @if (editingPersonId == p.Id && editingField == "FastMemory")
                                {
                                    <input type="text" class="inline-edit-input" style="width:200px;"
                                           @bind="editFastMemory" />
                                    <span class="inline-edit-actions">
                                        <button class="save" @onclick="SavePersonEdit"><i class="bi bi-check"></i></button>
                                        <button class="cancel" @onclick="CancelEdit"><i class="bi bi-x"></i></button>
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-editable" title="@p.FastMemory"
                                          @onclick="() => StartEditPerson(p, nameof(Person.FastMemory))">
                                        @(string.IsNullOrEmpty(p.FastMemory) ? "-" : Truncate(p.FastMemory, 30))
                                    </span>
                                }
                            </td>
                            <td>
                                @if (editingPersonId == p.Id && editingField == "AlertLevel")
                                {
                                    <input type="number" min="0" max="4" class="inline-edit-input" style="width:50px;"
                                           @bind="editAlertLevel" />
                                    <span class="inline-edit-actions">
                                        <button class="save" @onclick="SavePersonEdit"><i class="bi bi-check"></i></button>
                                        <button class="cancel" @onclick="CancelEdit"><i class="bi bi-x"></i></button>
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-editable" @onclick="() => StartEditPerson(p, nameof(Person.AlertLevel))">
                                        @if (p.AlertLevel > 0)
                                        {
                                            <span class="badge-status badge-working">Lv@(p.AlertLevel)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted-custom">-</span>
                                        }
                                    </span>
                                }
                            </td>
                            <td>@p.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td>
                                <button class="btn-ghost" style="padding:0.2rem 0.5rem;"
                                        @onclick="() => ToggleDetail(p.Id)">
                                    <i class="bi @(expandedId == p.Id ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                </button>
                            </td>
                        </tr>
                        @if (expandedId == p.Id)
                        {
                            <tr>
                                <td colspan="8" style="background:var(--bg-tertiary); padding:1rem;">
                                    <div class="stat-label" style="margin-bottom:0.5rem;">关联账号</div>
                                    @if (linkedUsers.Count == 0)
                                    {
                                        <span class="text-muted-custom">无关联账号</span>
                                    }
                                    else
                                    {
                                        <table class="table-dark-custom" style="font-size:var(--font-size-sm);">
                                            <thead>
                                                <tr>
                                                    <th>平台</th>
                                                    <th>平台ID</th>
                                                    <th>显示名</th>
                                                    <th>权限</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var u in linkedUsers)
                                                {
                                                    <tr class="@(flashUserId == u.Id ? "save-flash" : "")">
                                                        <td>@u.Platform</td>
                                                        <td><code style="color:var(--accent);">@u.PlatformId</code></td>
                                                        <td>
                                                            @if (editingUserId == u.Id && editingField == "DisplayName")
                                                            {
                                                                <input type="text" class="inline-edit-input" style="width:120px;"
                                                                       @bind="editDisplayName" />
                                                                <span class="inline-edit-actions">
                                                                    <button class="save" @onclick="SaveUserEdit"><i class="bi bi-check"></i></button>
                                                                    <button class="cancel" @onclick="CancelEdit"><i class="bi bi-x"></i></button>
                                                                </span>
                                                            }
                                                            else
                                                            {
                                                                <span class="inline-editable"
                                                                      @onclick="() => StartEditUser(u, nameof(User.DisplayName))">
                                                                    @(string.IsNullOrEmpty(u.DisplayName) ? "-" : u.DisplayName)
                                                                </span>
                                                            }
                                                        </td>
                                                        <td>
                                                            @if (editingUserId == u.Id && editingField == "PermissionLevel")
                                                            {
                                                                <select class="inline-edit-select" @bind="editPermLevel">
                                                                    @foreach (var lv in Enum.GetValues<PermissionLevel>())
                                                                    {
                                                                        <option value="@lv">@lv</option>
                                                                    }
                                                                </select>
                                                                <span class="inline-edit-actions">
                                                                    <button class="save" @onclick="SaveUserEdit"><i class="bi bi-check"></i></button>
                                                                    <button class="cancel" @onclick="CancelEdit"><i class="bi bi-x"></i></button>
                                                                </span>
                                                            }
                                                            else
                                                            {
                                                                <span class="inline-editable badge-status @PermBadgeClass(u.PermissionLevel)"
                                                                      @onclick="() => StartEditUser(u, nameof(User.PermissionLevel))">
                                                                    @u.PermissionLevel
                                                                </span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private List<Person> persons = new();
    private List<User> linkedUsers = new();
    private int expandedId = 0;

    // 编辑状态
    private int editingPersonId = 0;
    private int editingUserId = 0;
    private string editingField = "";
    private int flashId = 0;
    private int flashUserId = 0;

    // Person 编辑值
    private TrustLevel editTrustLevel;
    private float editTrustProgress;
    private string editFastMemory = "";
    private int editAlertLevel;

    // User 编辑值
    private string editDisplayName = "";
    private PermissionLevel editPermLevel;

    protected override async Task OnInitializedAsync()
    {
        persons = await Engine.Session.GetAllPersonsAsync();
    }

    private async Task ToggleDetail(int personId)
    {
        if (expandedId == personId)
        {
            expandedId = 0;
            linkedUsers.Clear();
            return;
        }
        expandedId = personId;
        linkedUsers = await Engine.Session.GetUsersByPersonIdAsync(personId);
    }

    private void StartEditPerson(Person p, string field)
    {
        CancelEdit();
        editingPersonId = p.Id;
        editingField = field;
        editTrustLevel = p.TrustLevel;
        editTrustProgress = p.TrustProgress;
        editFastMemory = p.FastMemory ?? "";
        editAlertLevel = p.AlertLevel;
    }

    private void StartEditUser(User u, string field)
    {
        CancelEdit();
        editingUserId = u.Id;
        editingField = field;
        editDisplayName = u.DisplayName ?? "";
        editPermLevel = u.PermissionLevel;
    }

    private async Task SavePersonEdit()
    {
        var person = persons.FirstOrDefault(p => p.Id == editingPersonId);
        if (person == null) return;

        switch (editingField)
        {
            case "TrustLevel": person.TrustLevel = editTrustLevel; break;
            case "TrustProgress": person.TrustProgress = (float)editTrustProgress; break;
            case "FastMemory": person.FastMemory = editFastMemory; break;
            case "AlertLevel": person.AlertLevel = editAlertLevel; break;
        }

        await Engine.Session.UpdatePersonAsync(person);
        flashId = person.Id;
        editingPersonId = 0;
        editingField = "";
        _ = ClearFlashAsync(() => flashId = 0);
    }

    private async Task SaveUserEdit()
    {
        var user = linkedUsers.FirstOrDefault(u => u.Id == editingUserId);
        if (user == null) return;

        switch (editingField)
        {
            case "DisplayName": user.DisplayName = editDisplayName; break;
            case "PermissionLevel": user.PermissionLevel = editPermLevel; break;
        }

        await Engine.Session.UpdateUserAsync(user);
        flashUserId = user.Id;
        editingUserId = 0;
        editingField = "";
        _ = ClearFlashAsync(() => flashUserId = 0);
    }

    private void CancelEdit()
    {
        editingPersonId = 0;
        editingUserId = 0;
        editingField = "";
    }

    private async Task ClearFlashAsync(Action clear)
    {
        await Task.Delay(600);
        clear();
        await InvokeAsync(StateHasChanged);
    }

    private static string TrustBadgeClass(TrustLevel level) => level switch
    {
        TrustLevel.Hostile => "badge-working",
        TrustLevel.Wary => "badge-working",
        TrustLevel.Unknown => "",
        TrustLevel.Stranger => "",
        TrustLevel.Understanding => "badge-info",
        TrustLevel.Familiarity => "badge-info",
        TrustLevel.Trust => "badge-express",
        TrustLevel.AbsoluteTrust => "badge-express",
        _ => ""
    };

    private static string PermBadgeClass(PermissionLevel level) => level switch
    {
        PermissionLevel.Admin => "badge-working",
        PermissionLevel.Elevated => "badge-info",
        PermissionLevel.Default => "",
        PermissionLevel.Restricted => "",
        PermissionLevel.Blocked => "badge-working",
        _ => ""
    };

    private static string Truncate(string s, int max) => s.Length <= max ? s : s[..max] + "...";
}
