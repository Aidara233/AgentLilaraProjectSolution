@page "/images"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Engine
@using AgentCoreProcessor.Engine.Vision
@using AgentCoreProcessor.Database
@using AgentCoreProcessor.Adapter
@inject MasterEngine Engine

<div class="page-title">
    <i class="bi bi-image"></i> 图片管理
</div>

<div class="row g-2 mb-3">
    <div class="col-md-2">
        <select class="form-select form-select-sm" @bind="statusFilter" @bind:after="Refresh">
            <option value="">全部状态</option>
            <option value="pending">待处理</option>
            <option value="done">已完成</option>
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select form-select-sm" @bind="categoryFilter" @bind:after="Refresh">
            <option value="">全部分类</option>
            <option value="sticker">表情包</option>
            <option value="image">普通图片</option>
        </select>
    </div>
    <div class="col-md-3">
        <div class="d-flex gap-1">
            <input type="text" class="form-control form-control-sm" placeholder="搜索描述/OCR..." @bind="keyword" @onkeydown="OnSearchKey" />
            <button class="btn-ghost" @onclick="Refresh"><i class="bi bi-search"></i></button>
        </div>
    </div>
    <div class="col-md-3 ms-auto text-end">
        <span class="text-muted-custom small">共 @totalCount 张</span>
    </div>
</div>

<div class="d-flex" style="height:calc(100vh - 220px)">
    @* 左侧列表 *@
    <div class="flex-grow-1" style="overflow-y:auto; min-width:0">
        @if (images.Count == 0)
        {
            <div class="card"><div class="card-body text-center text-muted-custom">无图片</div></div>
        }
        else
        {
            <div class="card">
                <div class="card-body p-0">
                    @foreach (var img in images)
                    {
                        <div class="msg-item @(selectedHash == img.Hash ? "active" : "")" style="cursor:pointer" @onclick="() => Select(img)">
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:40px;height:40px;flex-shrink:0;background:#1a1a2e;border-radius:4px;overflow:hidden;display:flex;align-items:center;justify-content:center">
                                    @if (thumbnails.TryGetValue(img.Hash, out var thumb))
                                    {
                                        <img src="@thumb" style="max-width:40px;max-height:40px" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-image text-muted-custom"></i>
                                    }
                                </div>
                                <!-- PLACEHOLDER_LIST_ITEM -->
                                <div class="flex-grow-1" style="min-width:0">
                                    <div class="d-flex justify-content-between">
                                        <span class="small text-truncate" style="max-width:200px">@(img.Description ?? "<无描述>")</span>
                                        <span class="text-muted-custom small">ID:@img.Id</span>
                                    </div>
                                    <div class="d-flex gap-2 small text-muted-custom">
                                        <span>@FormatSize(img.FileSize)</span>
                                        @if (img.Category == "sticker") { <span class="badge-tag">表情包</span> }
                                        @if (img.HasText == true) { <span class="badge-tag">有文字</span> }
                                        @if (img.Description == null || img.HasText == null) { <span class="badge-tag" style="color:var(--warning)">待处理</span> }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-center gap-2 mt-2">
                <button class="btn-ghost" disabled="@(page <= 1)" @onclick="() => GoPage(page - 1)"><i class="bi bi-chevron-left"></i></button>
                <span class="small align-self-center">@(page) / @totalPages</span>
                <button class="btn-ghost" disabled="@(page >= totalPages)" @onclick="() => GoPage(page + 1)"><i class="bi bi-chevron-right"></i></button>
            </div>
        }
    </div>

    @* 右侧预览 *@
    @if (selected != null)
    {
        <div style="width:360px;flex-shrink:0;margin-left:12px;overflow-y:auto">
            <div class="card">
                <div class="card-body">
                    @if (previewBase64 != null)
                    {
                        <div class="text-center mb-2">
                            <img src="@previewBase64" style="max-width:100%;max-height:300px;border-radius:4px" />
                        </div>
                    }
                    <table class="table table-sm small mb-2">
                        <tr><td class="text-muted-custom">ID</td><td>@selected.Id</td></tr>
                        <tr><td class="text-muted-custom">哈希</td><td class="text-truncate" style="max-width:180px" title="@selected.Hash">@selected.Hash</td></tr>
                        <tr><td class="text-muted-custom">大小</td><td>@FormatSize(selected.FileSize)</td></tr>
                        <tr><td class="text-muted-custom">分类</td><td>@(selected.Category ?? "未分类")</td></tr>
                        <tr><td class="text-muted-custom">创建</td><td>@selected.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td></tr>
                        <tr><td class="text-muted-custom">引用次数</td><td>@selected.SeenCount</td></tr>
                    </table>

                    <div class="mb-2">
                        <label class="small text-muted-custom">描述</label>
                        <div class="p-2" style="background:var(--bg-secondary);border-radius:4px;min-height:40px">
                            @(selected.Description ?? "<无>")
                        </div>
                    </div>

                    @if (selected.HasText == true && !string.IsNullOrEmpty(selected.OcrText))
                    {
                        <div class="mb-2">
                            <label class="small text-muted-custom">OCR 文本</label>
                            <pre class="p-2 small" style="background:var(--bg-secondary);border-radius:4px;max-height:150px;overflow-y:auto;white-space:pre-wrap">@selected.OcrText</pre>
                        </div>
                    }

                    <div class="d-flex gap-1 flex-wrap">
                        <button class="btn-ghost small" @onclick="ReprocessVision" title="重新生成描述"><i class="bi bi-arrow-clockwise"></i> 重新描述</button>
                        <button class="btn-ghost small" @onclick="ReprocessOcr" title="重新 OCR"><i class="bi bi-fonts"></i> 重新OCR</button>
                        <button class="btn-ghost small" style="color:var(--danger)" @onclick="DeleteImage" title="删除图片"><i class="bi bi-trash"></i> 删除</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<ImageRecord> images = new();
    private Dictionary<string, string> thumbnails = new();
    private ImageRecord? selected;
    private string? selectedHash;
    private string? previewBase64;
    private string statusFilter = "";
    private string categoryFilter = "";
    private string keyword = "";
    private int page = 1;
    private int pageSize = 30;
    private int totalCount;
    private int totalPages => Math.Max(1, (int)Math.Ceiling((double)totalCount / pageSize));

    protected override async Task OnInitializedAsync() => await LoadPage();

    private async Task Refresh()
    {
        page = 1;
        await LoadPage();
    }

    private async Task LoadPage()
    {
        var sf = string.IsNullOrEmpty(statusFilter) ? null : statusFilter;
        var cf = string.IsNullOrEmpty(categoryFilter) ? null : categoryFilter;
        var kw = string.IsNullOrEmpty(keyword) ? null : keyword;

        totalCount = await ImageStorage.GetFilteredCountAsync(sf, cf, kw);
        images = await ImageStorage.GetPagedAsync((page - 1) * pageSize, pageSize, sf, cf, kw);

        thumbnails.Clear();
        foreach (var img in images)
        {
            var thumbPath = img.ThumbnailPath ?? img.LocalPath;
            if (!string.IsNullOrEmpty(thumbPath) && System.IO.File.Exists(thumbPath))
            {
                try
                {
                    var fi = new System.IO.FileInfo(thumbPath);
                    if (fi.Length > 200 * 1024) continue; // 跳过过大的缩略图
                    var bytes = await System.IO.File.ReadAllBytesAsync(thumbPath);
                    var ext = System.IO.Path.GetExtension(thumbPath).ToLower();
                    var mime = ext switch { ".png" => "image/png", ".gif" => "image/gif", ".webp" => "image/webp", _ => "image/jpeg" };
                    thumbnails[img.Hash] = $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
                }
                catch { }
            }
        }

        if (selected != null && !images.Any(i => i.Hash == selected.Hash))
        {
            selected = null;
            selectedHash = null;
            previewBase64 = null;
        }
    }

    private async Task Select(ImageRecord img)
    {
        selected = img;
        selectedHash = img.Hash;
        previewBase64 = null;

        var path = img.ThumbnailPath ?? img.LocalPath;
        if (!string.IsNullOrEmpty(path) && System.IO.File.Exists(path))
        {
            try
            {
                var bytes = await System.IO.File.ReadAllBytesAsync(path);
                var ext = System.IO.Path.GetExtension(path).ToLower();
                var mime = ext switch { ".png" => "image/png", ".gif" => "image/gif", ".webp" => "image/webp", _ => "image/jpeg" };
                previewBase64 = $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
            }
            catch { }
        }
    }

    private async Task ReprocessVision()
    {
        if (selected == null) return;
        await ImageStorage.ClearDescriptionAsync(selected.Hash);
        selected.Description = null;
        SignalVisionEngine();
        StateHasChanged();
    }

    private async Task ReprocessOcr()
    {
        if (selected == null) return;
        await ImageStorage.ClearOcrAsync(selected.Hash);
        selected.HasText = null;
        selected.OcrText = null;
        SignalVisionEngine();
        StateHasChanged();
    }

    private async Task DeleteImage()
    {
        if (selected == null) return;
        await ImageStorage.DeleteAsync(selected.Hash);
        images.Remove(selected);
        selected = null;
        selectedHash = null;
        previewBase64 = null;
        totalCount--;
        StateHasChanged();
    }

    private void SignalVisionEngine()
    {
        var check = Engine.GetSpawnCheck<VisionEngineSpawnCheck>();
        check?.ActiveInstance?.SignalGate();
    }

    private async Task GoPage(int p)
    {
        page = p;
        await LoadPage();
    }

    private void OnSearchKey(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = Refresh();
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes}B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1}KB";
        return $"{bytes / (1024.0 * 1024):F1}MB";
    }
}
