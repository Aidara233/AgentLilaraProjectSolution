@page "/adapters/file"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.Adapter
@inject AdapterManager Adapters
@implements IDisposable

<div class="page-title">
    <i class="bi bi-folder"></i> 适配器 — File
</div>

<div class="row g-2 mb-4 align-items-center">
    @foreach (var inst in instances)
    {
        <div class="col-auto">
            <button class="@(inst.Id == selectedId ? "btn-primary-custom" : "btn-ghost")"
                    style="padding:0.3rem 0.8rem; font-size:0.85rem;"
                    @onclick="() => Select(inst.Id)">
                @inst.Id
            </button>
        </div>
    }
</div>

@if (selected == null)
{
    <div class="page-placeholder">
        <i class="bi bi-folder"></i>
        <span>无 File 适配器实例（通常由 --file/--test 模式创建）</span>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-4"><StatCard Label="状态" Value="@(selected.Enabled ? "运行中" : "已停止")" /></div>
        <div class="col-md-4"><StatCard Label="收到" Value="@selected.MessagesReceived.ToString()" /></div>
        <div class="col-md-4"><StatCard Label="发送" Value="@selected.MessagesSent.ToString()" /></div>
    </div>
    <div class="card">
        <div class="card-header"><i class="bi bi-info-circle me-1 text-accent"></i> 信息</div>
        <div class="card-body">
            <p class="text-muted-custom">File 适配器通过文件轮询收发消息，用于自动化测试和调试。</p>
        </div>
    </div>
}

@code {
    private List<AdapterStatus> instances = new();
    private string selectedId = "";
    private AdapterStatus? selected;
    private System.Threading.Timer? timer;

    protected override void OnInitialized()
    {
        Refresh();
        if (instances.Count > 0) Select(instances[0].Id);
        timer = new System.Threading.Timer(_ => { Refresh(); InvokeAsync(StateHasChanged); }, null, 3000, 3000);
    }

    private void Refresh() => instances = Adapters.GetAllStatuses()
        .Where(s => s.Platform.Equals("File", StringComparison.OrdinalIgnoreCase)).ToList();
    private void Select(string id) { selectedId = id; selected = instances.FirstOrDefault(i => i.Id == id); }
    public void Dispose() => timer?.Dispose();
}
