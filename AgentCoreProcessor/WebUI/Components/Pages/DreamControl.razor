@page "/dream"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.WebUI.Services
@using AgentCoreProcessor.Engine
@inject SystemMonitor Monitor
@inject EventBus Bus
@implements IDisposable

<h4 class="mb-3">做梦状态</h4>

@if (dream == null)
{
    <div class="alert alert-secondary">做梦系统未加载</div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body py-2">
                    <div class="text-muted small">当前状态</div>
                    <div class="fw-bold @(dream.HasActiveDream ? "text-primary" : "")">
                        @(dream.HasActiveDream ? "做梦中" : "清醒")
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body py-2">
                    <div class="text-muted small">待执行级别</div>
                    <div class="fw-bold">@dream.PendingLevel</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body py-2">
                    <div class="text-muted small">上次走神</div>
                    <div class="fw-bold">@(dream.LastDaydreamTime?.ToString("HH:mm:ss") ?? "从未")</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body py-2">
                    <div class="text-muted small">强制标志</div>
                    <div class="fw-bold @(dream.ForceFlag ? "text-warning" : "")">
                        @(dream.ForceFlag ? "已设置" : "无")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 控制按钮 -->
    <div class="card">
        <div class="card-header py-2 fw-semibold">
            <i class="bi bi-sliders me-1"></i> 操作
        </div>
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-warning btn-sm" @onclick="ForceSleep">
                    <i class="bi bi-moon me-1"></i> 强制睡觉
                </button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="ForceNap">
                    <i class="bi bi-cloud me-1"></i> 强制小睡
                </button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="ForceDaydream">
                    <i class="bi bi-cloud-haze me-1"></i> 强制走神
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert alert-info mt-3 alert-dismissible fade show">
            @statusMessage
            <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
        </div>
    }
}

@code {
    private DreamStateSnapshot? dream;
    private string? statusMessage;

    protected override void OnInitialized()
    {
        dream = Monitor.Current.DreamState;
        Monitor.OnStateChanged += OnStateChanged;
    }

    private void OnStateChanged()
    {
        dream = Monitor.Current.DreamState;
        InvokeAsync(StateHasChanged);
    }

    private void ForceSleep()
    {
        Bus.PublishSignal("force-sleep");
        statusMessage = "已发送强制大睡信号";
    }

    private void ForceNap()
    {
        Bus.PublishSignal("force-sleep", "nap");
        statusMessage = "已发送强制小睡信号";
    }

    private void ForceDaydream()
    {
        Bus.PublishSignal("force-sleep", "daydream");
        statusMessage = "已发送强制走神信号";
    }

    public void Dispose()
    {
        Monitor.OnStateChanged -= OnStateChanged;
    }
}
