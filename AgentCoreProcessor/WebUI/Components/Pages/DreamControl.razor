@page "/dream"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.WebUI.Services
@using AgentCoreProcessor.Engine
@inject SystemMonitor Monitor
@inject EventBus Bus
@implements IDisposable

<h4 class="mb-3">做梦控制</h4>

@if (dream == null)
{
    <div class="alert alert-secondary">做梦系统未加载</div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body py-2">
                    <div class="text-muted small">当前状态</div>
                    <div class="fw-bold @(dream.HasActiveDream ? "text-primary" : "")">
                        @(dream.HasActiveDream ? "做梦中" : "清醒")
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body py-2">
                    <div class="text-muted small">睡眠许可</div>
                    <div class="fw-bold">
                        @if (dream.DreamPermission)
                        {
                            <span class="text-success">已授予</span>
                        }
                        else if (dream.PermissionRequestTime != null)
                        {
                            <span class="text-warning">等待中</span>
                            <small class="text-muted ms-1">
                                (@((DateTime.Now - dream.PermissionRequestTime.Value).TotalMinutes.ToString("F0"))m)
                            </small>
                        }
                        else
                        {
                            <span class="text-muted">未请求</span>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body py-2">
                    <div class="text-muted small">上次大睡</div>
                    <div class="fw-bold">@(dream.LastDeepSleepTime?.ToString("MM-dd HH:mm") ?? "从未")</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body py-2">
                    <div class="text-muted small">上次走神</div>
                    <div class="fw-bold">@(dream.LastDaydreamTime?.ToString("HH:mm:ss") ?? "从未")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body py-2">
                    <div class="text-muted small">睡意偏移</div>
                    <div class="fw-bold">@dream.ScoreOffset.ToString("F1")</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body py-2">
                    <div class="text-muted small">红色警报</div>
                    <div class="fw-bold @(dream.CustomRedAlert ? "text-danger" : "")">
                        @(dream.CustomRedAlert ? "已触发" : "正常")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 控制按钮 -->
    <div class="card">
        <div class="card-header py-2 fw-semibold">
            <i class="bi bi-sliders me-1"></i> 操作
        </div>
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2 mb-3">
                <button class="btn btn-primary btn-sm" @onclick="GrantPermission"
                        disabled="@dream.DreamPermission">
                    <i class="bi bi-check-circle me-1"></i> 授予睡眠许可
                </button>
                <button class="btn btn-warning btn-sm" @onclick="ForceSleep">
                    <i class="bi bi-moon me-1"></i> 强制睡觉
                </button>
                <button class="btn btn-danger btn-sm" @onclick="TriggerRedAlert"
                        disabled="@dream.CustomRedAlert">
                    <i class="bi bi-exclamation-triangle me-1"></i> 触发红色警报
                </button>
            </div>

            <div class="d-flex align-items-center gap-2">
                <label class="form-label mb-0">睡意偏移:</label>
                <input type="number" class="form-control form-control-sm" style="width:100px"
                       step="0.5" @bind="scoreOffsetInput" />
                <button class="btn btn-outline-primary btn-sm" @onclick="SetScoreOffset">
                    设置
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert alert-info mt-3 alert-dismissible fade show">
            @statusMessage
            <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
        </div>
    }
}

@code {
    private DreamStateSnapshot? dream;
    private float scoreOffsetInput = 0f;
    private string? statusMessage;

    protected override void OnInitialized()
    {
        dream = Monitor.Current.DreamState;
        scoreOffsetInput = dream?.ScoreOffset ?? 0f;
        Monitor.OnStateChanged += OnStateChanged;
    }

    private void OnStateChanged()
    {
        dream = Monitor.Current.DreamState;
        InvokeAsync(StateHasChanged);
    }

    private void GrantPermission()
    {
        Bus.PublishSignal("dream-permission");
        statusMessage = "睡眠许可已授予";
    }

    private void ForceSleep()
    {
        Bus.PublishSignal("force-sleep");
        statusMessage = "已发送强制睡觉信号";
    }

    private void TriggerRedAlert()
    {
        Bus.PublishSignal("red-alert");
        statusMessage = "红色警报已触发";
    }

    private void SetScoreOffset()
    {
        Bus.PublishSignal("sleep-score-offset", scoreOffsetInput.ToString("F1"));
        statusMessage = $"睡意偏移已设置为 {scoreOffsetInput:F1}";
    }

    public void Dispose()
    {
        Monitor.OnStateChanged -= OnStateChanged;
    }
}
