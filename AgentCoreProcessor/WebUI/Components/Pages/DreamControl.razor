@page "/dream"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using AgentCoreProcessor.WebUI.Services
@using AgentCoreProcessor.Engine
@inject SystemMonitor Monitor
@inject EventBus Bus
@implements IDisposable

<div class="page-title">
    <i class="bi bi-moon-stars"></i> 做梦状态
</div>

@if (dream == null)
{
    <div style="background:var(--bg-tertiary); color:var(--text-muted); padding:0.75rem 1rem; border-radius:var(--radius-md);">
        做梦系统未加载
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <StatCard Label="当前状态"
                      Value="@(dream.HasActiveDream ? "做梦中" : "清醒")"
                      CssClass="@(dream.HasActiveDream ? "info" : "idle")"
                      ValueClass="@(dream.HasActiveDream ? "" : "ok")" />
        </div>
        <div class="col-md-3">
            <StatCard Label="待执行级别"
                      Value="@dream.PendingLevel.ToString()"
                      CssClass="info" />
        </div>
        <div class="col-md-3">
            <StatCard Label="上次走神"
                      Value="@(dream.LastDaydreamTime?.ToString("HH:mm:ss") ?? "从未")"
                      CssClass="info" />
        </div>
        <div class="col-md-3">
            <StatCard Label="强制标志"
                      Value="@(dream.ForceFlag ? "已设置" : "无")"
                      CssClass="@(dream.ForceFlag ? "busy" : "idle")"
                      ValueClass="@(dream.ForceFlag ? "warn" : "")" />
        </div>
    </div>

    @if (dream.HasActiveDream && dream.CurrentFragment != null)
    {
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-activity me-1 text-accent"></i> 实时进度
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-2">
                    <span class="badge-status badge-info">@dream.CurrentFragment</span>
                    <span class="text-muted-custom">
                        片段 @(dream.FragmentsCompleted + 1) / @dream.FragmentsTotal
                    </span>
                    @if (dream.CurrentFragmentStartTime.HasValue)
                    {
                        <span class="text-muted-custom">
                            已耗时 @((int)(DateTime.Now - dream.CurrentFragmentStartTime.Value).TotalSeconds)s
                        </span>
                    }
                </div>
                @if (!string.IsNullOrEmpty(dream.CurrentInputDescription))
                {
                    <div style="font-size:0.85rem; color:var(--text-secondary); padding:0.4rem 0.6rem; background:var(--bg-secondary); border-radius:4px;">
                        @dream.CurrentInputDescription
                    </div>
                }
            </div>
        </div>

        @if (dream.LastFragmentSummary != null)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-check2-circle me-1 text-accent"></i> 上一片段结果
                    <span class="badge-status badge-express ms-2">@dream.LastFragmentType</span>
                    <span class="text-muted-custom ms-2">@dream.LastFragmentSummary</span>
                </div>
                @if (dream.LastFragmentDetails != null && dream.LastFragmentDetails.Count > 0)
                {
                    <div class="card-body p-0" style="max-height:200px; overflow-y:auto;">
                        @foreach (var d in dream.LastFragmentDetails)
                        {
                            <div class="msg-item" style="padding:0.3rem 1rem; font-size:0.83rem;">
                                <span class="badge-status badge-express">@d.Action</span>
                                @if (d.MemoryId != null) { <span class="text-muted-custom">#@d.MemoryId</span> }
                                @if (d.OldValue != null && d.NewValue != null) { <span>@d.OldValue → @d.NewValue</span> }
                                @if (d.Note != null) { <span class="text-muted-custom">@d.Note</span> }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }

    <div class="card">
        <div class="card-header">
            <i class="bi bi-sliders me-1 text-accent"></i> 操作
        </div>
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
                <button class="btn-accent" @onclick="ForceSleep">
                    <i class="bi bi-moon me-1"></i> 强制睡觉
                </button>
                <button class="btn-ghost" @onclick="ForceNap">
                    <i class="bi bi-cloud me-1"></i> 强制小睡
                </button>
                <button class="btn-ghost" @onclick="ForceDaydream">
                    <i class="bi bi-cloud-haze me-1"></i> 强制走神
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div style="background:var(--status-info-dim); color:var(--status-info); padding:0.75rem 1rem; border-radius:var(--radius-md); margin-top:1rem; display:flex; align-items:center; justify-content:space-between;">
            <span>@statusMessage</span>
            <button class="btn-ghost" style="padding:0.2rem 0.5rem;" @onclick="() => statusMessage = null">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }
}

@code {
    private DreamStateSnapshot? dream;
    private string? statusMessage;

    protected override void OnInitialized()
    {
        dream = Monitor.Current.DreamState;
        Monitor.OnStateChanged += OnStateChanged;
    }

    private void OnStateChanged()
    {
        dream = Monitor.Current.DreamState;
        InvokeAsync(StateHasChanged);
    }

    private void ForceSleep()
    {
        Bus.PublishSignal("force-sleep");
        statusMessage = "已发送强制大睡信号";
    }

    private void ForceNap()
    {
        Bus.PublishSignal("force-sleep", "nap");
        statusMessage = "已发送强制小睡信号";
    }

    private void ForceDaydream()
    {
        Bus.PublishSignal("force-sleep", "daydream");
        statusMessage = "已发送强制走神信号";
    }

    public void Dispose()
    {
        Monitor.OnStateChanged -= OnStateChanged;
    }
}
